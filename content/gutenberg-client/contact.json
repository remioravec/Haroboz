https://haroboz.com/mentions-legales/\" class=\"text-sm text-gray-300 hover:text-white\">Mentions légales</a></li></ul></div>\n            </div>\n            <div class=\"border-t border-white/10 mt-10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4\">\n                <p class=\"text-sm text-gray-400\">&copy; 2026 Haroboz — Luc Desbois | Photographe Art Masculin | Marseille, Toulon, Nice, Paris</p>\n                <div class=\"flex items-center gap-4\"><a href=\"https://www.instagram.com/hbozart/\" target=\"_blank\" class=\"text-gray-400 hover:text-white\"><i data-lucide=\"instagram\" class=\"w-5 h-5\"></i></a><a href=\"https://haroboz.com/mentions-legales/\" class=\"text-sm text-gray-400 hover:text-white\">Mentions légales</a></div>\n            </div>\n        </div>\n    </footer>\n\n    <!-- POPUP -->\n    <div id=\"booking-popup\" class=\"fixed inset-0 z-[100] flex items-center justify-center p-4 popup-hidden\">\n        <div class=\"absolute inset-0 bg-brand/60 backdrop-blur-sm\" onclick=\"closePopup()\"></div>\n        <div id=\"popup-content\" class=\"relative bg-white rounded-2xl shadow-2xl max-w-lg w-full max-h-[90vh] overflow-y-auto\">\n            <div class=\"bg-brand rounded-t-2xl p-6 text-center relative\"><button onclick=\"closePopup()\" class=\"absolute top-4 right-4 text-white/70 hover:text-white cursor-pointer\"><i data-lucide=\"x\" class=\"w-6 h-6\"></i></button><h3 class=\"text-xl font-serif text-white font-bold\">Réservez votre séance</h3><p class=\"text-white/70 text-sm mt-1\">Réponse confidentielle sous 24h</p></div>\n            <form id=\"booking-form\" class=\"p-6\" onsubmit=\"handleSubmit(event)\"><div class=\"space-y-4\"><div><label class=\"block text-sm font-medium text-brand mb-1\">Prénom *</label><input type=\"text\" required placeholder=\"Votre prénom\" name=\"prenom\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-brand placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand\"></di