  "content_raw": "<style>\n\n        .mega-menu-content{visibility:hidden;opacity:0;transform:translateY(10px);transition:all .3s ease-in-out}\n        .mega-menu-item:hover .mega-menu-content{visibility:visible;opacity:1;transform:translateY(0);pointer-events:auto}\n        #mobile-menu{transition:transform .3s ease-in-out}\n        .menu-open{transform:translateX(0)!important}\n        #booking-popup{transition:opacity .3s ease,visibility .3s ease}\n        #booking-popup.popup-hidden{opacity:0;visibility:hidden}\n        #booking-popup.popup-visible{opacity:1;visibility:visible}\n        #popup-content{transition:transform .3s ease,opacity .3s ease}\n        #booking-popup.popup-hidden #popup-content{transform:scale(.95) translateY(20px);opacity:0}\n        #booking-popup.popup-visible #popup-content{transform:scale(1) translateY(0);opacity:1}\n        @keyframes pulse-ring{0%{transform:scale(1);opacity:1}80%,100%{transform:scale(1.4);opacity:0}}\n        .pulse-ring::before{content:'';position:absolute;inset:-4px;border-radius:9999px;border:2px solid currentColor;animation:pulse-ring 2s ease-out infinite}\n        .faq-content{max-height:0;overflow:hidden;transition:max-height .3s ease}\n    \n</style>\n<div class=\"haroboz-page\">\n<!-- HEADER -->\n    <header id=\"main-header\" class=\"fixed top-0 left-0 w-full z-50 bg-white shadow-sm transition-all duration-300\">\n        <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n            <div class=\"flex justify-between items-center h-20\">\n                <div class=\"flex-shrink-0\"><a href=\"https://haroboz.com/\" class=\"font-serif text-2xl lg:text-3xl font-bold tracking-tight text-brand\">HAROBOZ</a></div>\n                <nav class=\"hidden lg:flex space-x-8 h-full items-center\">\n                    <div class=\"mega-menu-item relative h-full flex items-center\"><button class=\"flex items-center text-sm font-medium hover:text-brand-light transition-colors py-8\">Nos Séances <i data-lucide=\"chevron-down\" class=\"ml-1 w-4 h-4\"></i></button><div class=\"mega-menu-content absolute top-20 left-1/2 -translate-x-1/2 w-64 bg-white shadow-xl rounded-b-lg border-t border-gray-100\"><div class=\"py-2\"><a href=\"https://haroboz.com/packs-shooting/portrait-studio/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand\">Portrait en Studio</a><a href=\"https://haroboz.com/packs-shooting/shooting-exterieur/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand\">Shooting en Extérieur</a><a href=\"https://haroboz.com/packs-shooting/photo-domicile/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand\">Photo à Domicile</a><a href=\"https://haroboz.com/packs-shooting/shooting-duo-couple/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand\">Shooting Duo &amp; Couple</a></div></div></div>\n                    <div class=\"mega-menu-item relative h-full flex items-center\"><button class=\"flex items-center text-sm font-medium hover:text-brand-light transition-colors py-8\">Votre Objectif <i data-lucide=\"chevron-down\" class=\"ml-1 w-4 h-4\"></i></button><div class=\"mega-menu-content absolute top-20 left-1/2 -translate-x-1/2 w-80 bg-white shadow-xl rounded-b-lg border-t border-gray-100\"><div class=\"py-2\"><a href=\"https://haroboz.com/votre-experience/retrouver-confiance-corps/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand\">Confiance &amp; Acceptation</a><a href=\"https://haroboz.com/votre-experience/book-modele-professionnel/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand\">Book Professionnel</a><a href=\"https://haroboz.com/votre-experience/cadeau-couple-original/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand\">Immortaliser son Couple</a><a href=\"https://haroboz.com/votre-experience/premier-shooting-nu/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand\">Cadeau &amp; Célébration</a></div></div></div>\n                    <div class=\"mega-menu-item relative h-full flex items-center\"><button class=\"flex items-center text-sm font-medium hover:text-brand-light transition-colors py-8\">Où me trouver ? <i data-lucide=\"chevron-down\" class=\"ml-1 w-4 h-4\"></i></button><div class=\"mega-menu-content absolute top-20 left-1/2 -translate-x-1/2 w-48 bg-white shadow-xl rounded-b-lg border-t border-gray-100\"><div class=\"py-2\"><a href=\"https://haroboz.com/photographe/photographe-marseille/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Marseille</a><a href=\"https://haroboz.com/photographe/photographe-toulon/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Toulon</a><a href=\"https://haroboz.com/photographe/photographe-nice/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand\">Nice</a><a href=\"https://haroboz.com/photographe/photographe-paris/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Paris</a></div></div></div>\n                    <div class=\"mega-menu-item relative h-full flex items-center\">\n                    <button class=\"flex items-center text-sm font-medium hover:text-brand-light transition-colors py-8\">L'Oeuvre <i data-lucide=\"chevron-down\" class=\"ml-1 w-4 h-4\"></i></button>\n                    <div class=\"mega-menu-content absolute top-20 left-1/2 -translate-x-1/2 w-64 bg-white shadow-xl rounded-b-lg border-t border-gray-100 overflow-hidden\">\n                        <div class=\"py-2\">\n                            <a href=\"https://haroboz.com/portfolio/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Toutes les oeuvres</a>\n                            <a href=\"https://haroboz.com/portfolio/galerie-portraits-hommes/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Portraits</a>\n                            <a href=\"https://haroboz.com/portfolio/#nus\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Nus &amp; Attributs</a>\n                            <a href=\"https://haroboz.com/portfolio/galerie-couples/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Couples &amp; Duos</a>\n                            <a href=\"https://haroboz.com/portfolio/#creation\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Création d'art</a>\n                            <a href=\"https://haroboz.com/portfolio/#reportages\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Reportages</a>\n                        </div>\n                    </div>\n                </div>\n                    <a href=\"https://haroboz.com/a-propos/\" class=\"text-sm font-medium hover:text-brand-light\">L'Univers</a>\n                </nav>\n                <div class=\"hidden lg:flex items-center\"><button onclick=\"openPopup()\" class=\"bg-brand text-white px-6 py-2.5 rounded-full text-sm font-medium hover:bg-brand-light shadow-md flex items-center cursor-pointer\"><i data-lucide=\"calendar\" class=\"w-4 h-4 mr-2\"></i> Prendre RDV gratuit</button></div>\n                <div class=\"flex items-center lg:hidden\"><button id=\"mobile-menu-btn\" class=\"text-brand hover:text-brand-light p-2\"><i data-lucide=\"menu\" class=\"w-7 h-7\"></i></button></div>\n            </div>\n        </div>\n    </header>\n\n    <!-- MOBILE MENU -->\n    <div id=\"mobile-menu\" class=\"fixed inset-y-0 right-0 w-full max-w-sm bg-white shadow-2xl z-50 transform translate-x-full overflow-y-auto\">\n        <div class=\"p-6\">\n            <div class=\"flex items-center justify-between mb-8\"><span class=\"font-serif text-2xl font-bold text-brand\">HAROBOZ</span><button id=\"close-menu-btn\" class=\"text-gray-500 hover:text-brand\"><i data-lucide=\"x\" class=\"w-7 h-7\"></i></button></div>\n            <nav class=\"space-y-2\">\n                <div class=\"border-b border-gray-100 py-3\"><button class=\"flex justify-between items-center w-full text-left font-medium text-brand mobile-accordion-btn\">Nos Séances <i data-lucide=\"chevron-down\" class=\"w-4 h-4\"></i></button><div class=\"hidden mt-3 space-y-3 pl-4 border-l-2 border-brand-50\"><a href=\"https://haroboz.com/packs-shooting/portrait-studio/\" class=\"block text-sm text-gray-600 hover:text-brand\">Portrait en Studio</a><a href=\"https://haroboz.com/packs-shooting/shooting-exterieur/\" class=\"block text-sm text-gray-600 hover:text-brand\">Shooting en Extérieur</a><a href=\"https://haroboz.com/packs-shooting/photo-domicile/\" class=\"block text-sm text-gray-600 hover:text-brand\">Photo à Domicile</a><a href=\"https://haroboz.com/packs-shooting/shooting-duo-couple/\" class=\"block text-sm text-gray-600 hover:text-brand\">Shooting Duo &amp; Couple</a></div></div>\n                <div class=\"border-b border-gray-100 py-3\"><button class=\"flex justify-between items-center w-full text-left font-medium text-brand mobile-accordion-btn\">Votre Objectif <i data-lucide=\"chevron-down\" class=\"w-4 h-4\"></i></button><div class=\"hidden mt-3 space-y-3 pl-4 border-l-2 border-brand-50\"><a href=\"https://haroboz.com/votre-experience/retrouver-confiance-corps/\" class=\"block text-sm text-gray-600 hover:text-brand\">Confiance &amp; Acceptation</a><a href=\"https://haroboz.com/votre-experience/book-modele-professionnel/\" class=\"block text-sm text-gray-600 hover:text-brand\">Book Professionnel</a><a href=\"https://haroboz.com/votre-experience/cadeau-couple-original/\" class=\"block text-sm text-gray-600 hover:text-brand\">Immortaliser son Couple</a><a href=\"https://haroboz.com/votre-experience/premier-shooting-nu/\" class=\"block text-sm text-gray-600 hover:text-brand\">Cadeau &amp; Célébration</a></div></div>\n                <div class=\"border-b border-gray-100 py-3\"><button class=\"flex justify-between items-center w-full text-left font-medium text-brand mobile-accordion-btn\">Où me trouver ? <i data-lucide=\"chevron-down\" class=\"w-4 h-4\"></i></button><div class=\"hidden mt-3 space-y-3 pl-4 border-l-2 border-brand-50\"><a href=\"https://haroboz.com/photographe/photographe-marseille/\" class=\"block text-sm text-gray-600 hover:text-brand\">Marseille</a><a href=\"https://haroboz.com/photographe/photographe-toulon/\" class=\"block text-sm text-gray-600 hover:text-brand\">Toulon</a><a href=\"https://haroboz.com/photographe/photographe-nice/\" class=\"block text-sm text-gray-600 hover:text-brand\">Nice</a><a href=\"https://haroboz.com/photographe/photographe-paris/\" class=\"block text-sm text-gray-600 hover:text-brand\">Paris</a></div></div>\n                <div class=\"border-b border-gray-100 py-3\"><button class=\"flex justify-between items-center w-full text-left font-medium text-brand mobile-accordion-btn\">L'Oeuvre <i data-lucide=\"chevron-down\" class=\"w-4 h-4\"></i></button><div class=\"hidden mt-3 space-y-3 pl-4 border-l-2 border-brand-50\"><a href=\"https://haroboz.com/portfolio/\" class=\"block text-sm text-gray-600 hover:text-brand\">Toutes les oeuvres</a><a href=\"https://haroboz.com/portfolio/galerie-portraits-hommes/\" class=\"block text-sm text-gray-600 hover:text-brand\">Portraits</a><a href=\"https://haroboz.com/portfolio/#nus\" class=\"block text-sm text-gray-600 hover:text-brand\">Nus &amp; Attributs</a><a href=\"https://haroboz.com/portfolio/galerie-couples/\" class=\"block text-sm text-gray-600 hover:text-brand\">Couples &amp; Duos</a><a href=\"https://haroboz.com/portfolio/#creation\" class=\"block text-sm text-gray-600 hover:text-brand\">Création d'art</a><a href=\"https://haroboz.com/portfolio/#reportages\" class=\"block text-sm text-gray-600 hover:text-brand\">Reportages</a></div></div>\n                <div class=\"border-b border-gray-100 py-3\"><a href=\"https://haroboz.com/a-propos/\" class=\"block font-medium text-brand\">L'Univers</a></div>\n            </nav>\n            <div class=\"mt-8\"><button onclick=\"openPopup(); toggleMobileMenu();\" class=\"w-full bg-brand text-white px-6 py-4 rounded-xl font-medium hover:bg-brand-light shadow-md flex justify-center items-center cursor-pointer\"><i data-lucide=\"calendar\" class=\"w-5 h-5 mr-2\"></i> Prendre RDV gratuit</button></div>\n        </div>\n    </div>\n    <div id=\"mobile-overlay\" class=\"fixed inset-0 bg-brand bg-opacity-50 z-40 hidden\"></div>\n\n    <main class=\"w-full\">\n\n        <!-- HERO -->\n        <section class=\"bg-brand pt-28 lg:pt-32 pb-12 lg:pb-16\">\n            <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <nav class=\"mb-6\" aria-label=\"Fil d'Ariane\">\n                    <ol class=\"flex items-center space-x-2 text-sm text-white/60\" itemscope itemtype=\"https://schema.org/BreadcrumbList\">\n                        <li itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\"><a itemprop=\"item\" href=\"https://haroboz.com/\" class=\"hover:text-white\"><span itemprop=\"name\">Accueil</span></a><meta itemprop=\"position\" content=\"1\"></li>\n                        <li class=\"text-white/40\">/</li>\n                        <li itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\"><span itemprop=\"name\" class=\"text-white/80\">Contact</span><meta itemprop=\"position\" content=\"2\"></li>\n                    </ol>\n                </nav>\n                <p class=\"text-white/70 text-sm font-medium tracking-wider uppercase mb-3\">Premier échange confidentiel</p>\n                <h1 class=\"text-3xl md:text-5xl font-serif font-bold text-white mb-4\">Contactez Haroboz</h1>\n                <p class=\"text-lg text-white/80 max-w-2xl\">Que vous ayez une question, une envie ou simplement besoin d'être rassuré avant de franchir le pas, Luc est à votre écoute. Chaque échange est confidentiel, sans engagement et sans jugement.</p>\n            </div>\n        </section>\n\n        <!-- CONTACT FORM + INFO -->\n        <section class=\"py-12 lg:py-20 bg-white\">\n            <div class=\"max-w-6xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <div class=\"grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-16\">\n\n                    <!-- FORMULAIRE -->\n                    <div class=\"lg:col-span-3\">\n                        <h2 class=\"text-2xl md:text-3xl font-serif text-brand mt-0 mb-4\">Envoyez-nous un message</h2>\n                        <p class=\"text-gray-600 leading-relaxed mb-6\">Remplissez le formulaire ci-dessous et Luc vous répondra personnellement sous 24 heures. Toutes les informations partagées restent strictement confidentielles.</p>\n\n                        <form class=\"space-y-5\" action=\"#\" method=\"post\" onsubmit=\"handleContactSubmit(event)\">\n                            <div>\n                                <label for=\"hrb-nom\" class=\"block text-sm font-medium text-brand mb-1\">Nom et prénom <span class=\"text-red-500\">*</span></label>\n                                <input type=\"text\" id=\"hrb-nom\" name=\"nom\" required placeholder=\"Votre nom\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-brand placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand\">\n                            </div>\n                            <div>\n                                <label for=\"hrb-email\" class=\"block text-sm font-medium text-brand mb-1\">Adresse email <span class=\"text-red-500\">*</span></label>\n                                <input type=\"email\" id=\"hrb-email\" name=\"email\" required placeholder=\"votre@email.com\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-brand placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand\">\n                            </div>\n                            <div>\n                                <label for=\"hrb-telephone\" class=\"block text-sm font-medium text-brand mb-1\">Téléphone</label>\n                                <input type=\"tel\" id=\"hrb-telephone\" name=\"telephone\" placeholder=\"06 XX XX XX XX\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-brand placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand\">\n                            </div>\n                            <div>\n                                <label for=\"hrb-pack\" class=\"block text-sm font-medium text-brand mb-1\">Pack qui vous intéresse</label>\n                                <select id=\"hrb-pack\" name=\"pack\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-brand bg-white focus:outline-none focus:ring-2 focus:ring-brand\">\n                                    <option value=\"\">Sélectionnez un pack (optionnel)</option>\n                                    <option value=\"portrait-studio\">Portrait Studio Marseille</option>\n                                    <option value=\"exterieur\">Shooting Extérieur</option>\n                                    <option value=\"duo-couple\">Shooting Duo &amp; Couple</option>\n                                    <option value=\"domicile\">Photo à Domicile</option>\n                                    <option value=\"book-modele\">Book Modèle Professionnel</option>\n                                    <option value=\"carte-cadeau\">Carte Cadeau</option>\n                                    <option value=\"tirages\">Tirages d'Art uniquement</option>\n                                    <option value=\"autre\">Autre / Je ne sais pas encore</option>\n                                </select>\n                            </div>\n                            <div>\n                                <label for=\"hrb-message\" class=\"block text-sm font-medium text-brand mb-1\">Votre message <span class=\"text-red-500\">*</span></label>\n                                <textarea id=\"hrb-message\" name=\"message\" rows=\"6\" required placeholder=\"Dites-nous ce qui vous amène, vos envies, vos questions... Tout est confidentiel.\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-brand placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand resize-none\"></textarea>\n                            </div>\n                            <button type=\"submit\" class=\"w-full bg-brand text-white py-4 rounded-xl font-bold hover:bg-brand-light shadow-lg flex items-center justify-center cursor-pointer\"><i data-lucide=\"send\" class=\"w-5 h-5 mr-2\"></i> Envoyer mon message</button>\n                            <p class=\"text-xs text-gray-400 text-center\">En soumettant ce formulaire, vous acceptez que vos données soient traitées conformément à notre politique de confidentialité. Aucune information ne sera partagée avec des tiers. <a href=\"https://haroboz.com/mentions-legales/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4 transition-colors\">Mentions légales</a>.</p>\n                        </form>\n                        <div id=\"contact-success\" class=\"hidden text-center py-12\">\n                            <div class=\"w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4\"><i data-lucide=\"check-circle\" class=\"w-8 h-8 text-green-600\"></i></div>\n                            <h3 class=\"text-2xl font-serif text-brand mb-2\">Message envoyé !</h3>\n                            <p class=\"text-gray-600\">Luc vous répondra personnellement sous 24 heures.</p>\n                        </div>\n                    </div>\n\n                    <!-- COORDONNEES -->\n                    <div class=\"lg:col-span-2\">\n                        <h2 class=\"text-2xl md:text-3xl font-serif text-brand mt-0 mb-6\">Nos coordonnées</h2>\n\n                        <div class=\"space-y-6\">\n                            <div class=\"bg-brand-50 rounded-2xl p-6\">\n                                <div class=\"flex items-center gap-3 mb-2\"><i data-lucide=\"phone\" class=\"w-5 h-5 text-brand\"></i><h3 class=\"text-xl md:text-2xl font-serif text-brand\">Téléphone</h3></div>\n                                <p class=\"text-gray-600 leading-relaxed mb-2\">Pour un échange direct et confidentiel&nbsp;:</p>\n                                <p class=\"text-xl font-semibold\"><a href=\"tel:+33688704041\" class=\"text-brand hover:text-brand-light\">06 88 70 40 41</a></p>\n                                <p class=\"text-sm text-gray-500 mt-1\">Du lundi au samedi, 9h &mdash; 19h</p>\n                            </div>\n\n                            <div class=\"bg-brand-50 rounded-2xl p-6\">\n                                <div class=\"flex items-center gap-3 mb-2\"><i data-lucide=\"mail\" class=\"w-5 h-5 text-brand\"></i><h3 class=\"text-xl md:text-2xl font-serif text-brand\">Email</h3></div>\n                                <p class=\"text-gray-600 leading-relaxed mb-2\">Pour toute demande écrite&nbsp;:</p>\n                                <p class=\"text-xl font-semibold\"><a href=\"mailto:lucdfka@icloud.com\" class=\"text-brand hover:text-brand-light\">lucdfka@icloud.com</a></p>\n                                <p class=\"text-sm text-gray-500 mt-1\">Réponse sous 24 heures</p>\n                            </div>\n\n                            <div class=\"bg-brand-50 rounded-2xl p-6\">\n                                <div class=\"flex items-center gap-3 mb-2\"><i data-lucide=\"map-pin\" class=\"w-5 h-5 text-brand\"></i><h3 class=\"text-xl md:text-2xl font-serif text-brand\">Localisation</h3></div>\n                                <p class=\"text-gray-600 leading-relaxed\"><strong>Marseille, Toulon, Nice, Paris</strong></p>\n                                <p class=\"text-gray-600 leading-relaxed\">Studio privé. Déplacements possibles dans l'ensemble du sud de la France et sur Paris.</p>\n                            </div>\n\n                            <div class=\"bg-brand-50 rounded-2xl p-6\">\n                                <div class=\"flex items-center gap-3 mb-2\"><i data-lucide=\"instagram\" class=\"w-5 h-5 text-brand\"></i><h3 class=\"text-xl md:text-2xl font-serif text-brand\">Instagram</h3></div>\n                                <p class=\"text-gray-600 leading-relaxed mb-2\">Suivez notre univers visuel&nbsp;:</p>\n                                <p class=\"text-xl font-semibold\"><a href=\"https://www.instagram.com/hbozart/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"text-brand hover:text-brand-light\">@hbozart</a></p>\n                            </div>\n\n                            <div class=\"bg-brand-50 rounded-2xl p-6\">\n                                <div class=\"flex items-center gap-3 mb-2\"><i data-lucide=\"shield-check\" class=\"w-5 h-5 text-brand\"></i><h3 class=\"text-xl md:text-2xl font-serif text-brand\">Confidentialité garantie</h3></div>\n                                <p class=\"text-gray-600 leading-relaxed\">Chaque échange avec Haroboz est traité avec la plus grande discrétion. Que vous nous contactiez par téléphone, email ou formulaire, vos informations personnelles et le contenu de vos messages restent strictement confidentiels. Nous ne publions jamais les coordonnées de nos clients et ne partageons aucune donnée avec des tiers.</p>\n                            </div>\n                        </div>\n                    </div>\n\n                </div>\n            </div>\n        </section>\n\n        <!-- SECTION RASSURANCE -->\n        <section class=\"py-12 lg:py-20 bg-gray-50\">\n            <div class=\"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <h2 class=\"text-2xl md:text-3xl font-serif text-brand mt-0 mb-4\">Ce premier échange, comment ça se passe ?</h2>\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Nous savons que prendre contact pour un shooting de nu masculin peut sembler intimidant. C'est parfaitement normal, et Luc comprend cette appréhension mieux que quiconque. Voici ce à quoi vous pouvez vous attendre&nbsp;:</p>\n\n                <h3 class=\"text-xl md:text-2xl font-serif text-brand mt-8 mb-3\">Un échange humain et bienveillant</h3>\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Pas de script commercial, pas de pression. Luc répond personnellement à chaque message et à chaque appel. Il prend le temps de comprendre votre démarche, vos envies, vos éventuelles inquiétudes. Aucune question n'est ridicule, et aucun sujet n'est tabou. Cet échange est le fondement d'une séance réussie.</p>\n\n                <h3 class=\"text-xl md:text-2xl font-serif text-brand mt-8 mb-3\">Sans engagement</h3>\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Ce premier contact ne vous engage à rien. Vous pouvez poser toutes vos questions, demander un devis personnalisé, prendre le temps de réfléchir. Certains clients nous contactent plusieurs semaines &mdash; voire plusieurs mois &mdash; avant de finaliser leur réservation. Nous respectons votre rythme.</p>\n\n                <h3 class=\"text-xl md:text-2xl font-serif text-brand mt-8 mb-3\">Adapté à vos préférences</h3>\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Vous préférez écrire&nbsp;? Utilisez le formulaire ou envoyez un email. Vous avez besoin d'entendre une voix&nbsp;? Appelez directement. Vous êtes plus à l'aise sur les réseaux sociaux&nbsp;? Envoyez un message privé sur Instagram. L'important est que vous vous sentiez à l'aise dans le mode de communication que vous choisissez.</p>\n            </div>\n        </section>\n\n        <!-- LIENS UTILES -->\n        <section class=\"py-12 lg:py-20 bg-white\">\n            <div class=\"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <h2 class=\"text-2xl md:text-3xl font-serif text-brand mt-0 mb-4\">Avant de nous contacter</h2>\n                <p class=\"text-gray-600 leading-relaxed mb-6\">Pour préparer votre échange avec Luc, vous pouvez consulter ces pages qui répondent aux questions les plus fréquentes&nbsp;:</p>\n                <ul class=\"space-y-3 my-6\">\n                    <li class=\"flex items-start gap-3 text-gray-600\"><i data-lucide=\"check\" class=\"w-5 h-5 text-brand flex-shrink-0 mt-0.5\"></i><span><a href=\"https://haroboz.com/packs-shooting/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4 transition-colors\">Nos Packs Shooting</a> &mdash; Découvrez les différentes formules disponibles</span></li>\n                    <li class=\"flex items-start gap-3 text-gray-600\"><i data-lucide=\"check\" class=\"w-5 h-5 text-brand flex-shrink-0 mt-0.5\"></i><span><a href=\"https://haroboz.com/votre-experience/premier-shooting-nu/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4 transition-colors\">Votre Premier Shooting</a> &mdash; Tout ce qu'il faut savoir avant le jour J</span></li>\n                    <li class=\"flex items-start gap-3 text-gray-600\"><i data-lucide=\"check\" class=\"w-5 h-5 text-brand flex-shrink-0 mt-0.5\"></i><span><a href=\"https://haroboz.com/votre-experience/retrouver-confiance-corps/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4 transition-colors\">Retrouver Confiance en Son Image</a> &mdash; Pour ceux qui hésitent encore</span></li>\n                    <li class=\"flex items-start gap-3 text-gray-600\"><i data-lucide=\"check\" class=\"w-5 h-5 text-brand flex-shrink-0 mt-0.5\"></i><span><a href=\"https://haroboz.com/portfolio/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4 transition-colors\">Notre Portfolio</a> &mdash; Exemples de réalisations</span></li>\n                    <li class=\"flex items-start gap-3 text-gray-600\"><i data-lucide=\"check\" class=\"w-5 h-5 text-brand flex-shrink-0 mt-0.5\"></i><span><a href=\"https://haroboz.com/portfolio/temoignages-clients/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4 transition-colors\">Témoignages Clients</a> &mdash; L'expérience vue par ceux qui l'ont vécue</span></li>\n                    <li class=\"flex items-start gap-3 text-gray-600\"><i data-lucide=\"check\" class=\"w-5 h-5 text-brand flex-shrink-0 mt-0.5\"></i><span><a href=\"https://haroboz.com/boutique/carte-cadeau/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4 transition-colors\">Carte Cadeau</a> &mdash; Pour offrir l'expérience Haroboz</span></li>\n                </ul>\n            </div>\n        </section>\n\n        <!-- CTA -->\n        <section class=\"bg-brand py-16 lg:py-20\">\n            <div class=\"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center\">\n                <h2 class=\"text-2xl md:text-3xl font-serif text-white mb-3\">Le premier pas est toujours le plus courageux</h2>\n                <p class=\"text-white/70 text-lg mb-8\">Shooting privé et confidentiel &mdash; 06 88 70 40 41</p>\n                <a href=\"tel:+33688704041\" class=\"bg-white text-brand px-8 py-4 rounded-full text-lg font-semibold hover:bg-gray-100 shadow-lg inline-flex items-center\"><i data-lucide=\"phone\" class=\"w-5 h-5 mr-2\"></i> Appelez maintenant</a>\n            </div>\n        </section>\n\n    </main>\n\n    <!-- FOOTER -->\n    <footer class=\"bg-brand text-white border-t border-brand-light/20\">\n        <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16\">\n            <div class=\"grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12\">\n                <div><div class=\"font-serif text-lg font-bold mb-4\">Nos Packs</div><ul class=\"space-y-2\"><li><a href=\"https://haroboz.com/packs-shooting/portrait-studio/\" class=\"text-sm text-gray-300 hover:text-white\">Portrait Studio</a></li><li><a href=\"https://haroboz.com/packs-shooting/shooting-exterieur/\" class=\"text-sm text-gray-300 hover:text-white\">Shooting Extérieur</a></li><li><a href=\"https://haroboz.com/packs-shooting/shooting-duo-couple/\" class=\"text-sm text-gray-300 hover:text-white\">Du