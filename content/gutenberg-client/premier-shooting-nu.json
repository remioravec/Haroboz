     <a href=\"https://haroboz.com/votre-experience/book-modele-professionnel/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Book Professionnel</a>\n                            <a href=\"https://haroboz.com/votre-experience/cadeau-couple-original/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Immortaliser son Couple</a>\n                            <a href=\"https://haroboz.com/votre-experience/premier-shooting-nu/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Cadeau &amp; Célébration</a>\n                        </div></div>\n                    </div>\n                    <div class=\"mega-menu-item relative h-full flex items-center\">\n                        <button class=\"flex items-center text-sm font-medium hover:text-brand-light transition-colors py-8\">Où me trouver ? <i data-lucide=\"chevron-down\" class=\"ml-1 w-4 h-4\"></i></button>\n                        <div class=\"mega-menu-content absolute top-20 left-1/2 -translate-x-1/2 w-48 bg-white shadow-xl rounded-b-lg border-t border-gray-100\"><div class=\"py-2\">\n                            <a href=\"https://haroboz.com/photographe/photographe-marseille/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Marseille</a>\n                            <a href=\"https://haroboz.com/photographe/photographe-toulon/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Toulon</a>\n                            <a href=\"https://haroboz.com/photographe/photographe-nice/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Nice</a>\n                            <a href=\"https://haroboz.com/photographe/photographe-paris/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Paris</a>\n                        </div></div>\n                    </div>\