rtraits</a>\n                            <a href=\"https://haroboz.com/portfolio/#nus\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Nus &amp; Attributs</a>\n                            <a href=\"https://haroboz.com/portfolio/galerie-couples/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Couples &amp; Duos</a>\n                            <a href=\"https://haroboz.com/portfolio/#creation\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Création d'art</a>\n                            <a href=\"https://haroboz.com/portfolio/#reportages\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Reportages</a>\n                        </div>\n                    </div>\n                </div>\n                    <a href=\"https://haroboz.com/a-propos/\" class=\"text-sm font-medium hover:text-brand-light transition-colors\">L'Univers</a>\n                </nav>\n                <div class=\"hidden lg:flex items-center\"><button onclick=\"openPopup()\" class=\"bg-brand text-white px-6 py-2.5 rounded-full text-sm font-medium hover:bg-brand-light shadow-md flex items-center cursor-pointer\"><i data-lucide=\"calendar\" class=\"w-4 h-4 mr-2\"></i> Prendre RDV gratuit</button></div>\n                <div class=\"flex items-center lg:hidden\"><button id=\"mobile-menu-btn\" class=\"text-brand hover:text-brand-light p-2\"><i data-lucide=\"menu\" class=\"w-7 h-7\"></i></button></div>\n            </div>\n        </div>\n    </header>\n\n    <!-- MOBILE MENU -->\n    <div id=\"mobile-menu\" class=\"fixed inset-y-0 right-0 w-full max-w-sm bg-white shadow-2xl z-50 transform translate-x-full overflow-y-auto\">\n        <div class=\"p-6\">\n            <div class=\"flex items-center justify-between mb-8\"><span class=\"font-serif text-2xl font-bold text-brand\">HAROBOZ</span><button id=\"close-menu-btn\" class=\"text-gray-500 hover:text-brand\"><i data-lucide=\"x\" class=\"w-7 h-7\"></i></button></div>\n            <nav class=\"space-y-2\">\n                <div class=\"border-b border-gray-100 py-3\"><button class=\"flex justify-between items-center w-full text-left font-medium text-brand mobile-accordion-btn\">Nos Séances <i data-lucide=\"chevron-down\" class=\"w-4 h-4\"></i></button><div class=\"hidden mt-3 space-y-3 pl-4 border-l-2 border-brand-50\"><a href=\"https://haroboz.com/packs-shooting/portrait-studio/\" class=\"block text-sm text-gray-600 hover:text-brand\">Portrait en Studio</a><a href=\"https://haroboz.com/packs-shooting/shooting-exterieur/\" class=\"block text-sm text-gray-600 hover:text-brand\">Shooting en Extérieur</a><a href=\"https://haroboz.com/packs-shooting/photo-domicile/\" class=\"block text-sm text-gray-600 hover:text-brand\">Photo à Domicile</a><a href=\"https://haroboz.com/packs-shooting/shooting-duo-couple/\" class=\"block text-sm text-gray-600 hover:text-brand\">Shooting Duo &amp; Couple</a></div></div>\n                <div class=\"border-b border-gray-100 py-3\"><button class=\"flex justify-between items-center w-full text-left font-medium text-brand mobile-accordion-btn\">Votre Objectif <i data-lucide=\"chevron-down\" class=\"w-4 h-4\"></i></button><div class=\"hidden mt-3 space-y-3 pl-4 border-l-2 border-brand-50\"><a href=\"https://haroboz.com/votre-experience/retrouver-confiance-corps/\" class=\"block text-sm text-gray-600 hover:text-brand\">Confiance &amp; Acceptation</a><a href=\"https://haroboz.com/votre-experience/book-modele-professionnel/\" class=\"block text-sm text-gray-600 hover:text-brand\">Book Professionnel</a><a href=\"https://haroboz.com/votre-experience/cadeau-couple-original/\" class=\"block text-sm text-gray-600 hover:text-brand\">Immortaliser son Couple</a><a href=\"https://haroboz.com/votre-experience/premier-shooting-nu/\" class=\"block text-sm text-gray-600 hover:text-brand\">Cadeau &amp; Célébration</a></div></div>\n                <div class=\"border-b border-gray-100 py-3\"><button class=\"flex justify-between items-center w-full text-left font-medium text-brand mobile-accordion-btn\">Où me trouver ? <i data-lucide=\"chevron-down\" class=\"w-4 h-4\"></i></button><div class=\"hidden mt-3 space-y-3 pl-4 border-l-2 border-brand-50\"><a href=\"https://haroboz.com/photographe/photographe-marseille/\" class=\"block text-sm text-gray-600 hover:text-brand\">Marseille</a><a href=\"https://haroboz.com/photographe/photographe-toulon/\" class=\"block text-sm text-gray-600 hover:text-brand\">Toulon</a><a href=\"https://haroboz.com/photographe/photographe-nice/\" class=\"block text-sm text-gray-600 hover:text-brand\">Nice</a><a href=\"https://haroboz.com/photographe/photographe-paris/\" class=\"block text-sm text-gray-600 hover:text-brand\">Paris</a></div></div>\n                <div class=\"border-b border-gray-100 py-3\"><button class=\"flex justify-between items-center w-full text-left font-medium text-brand mobile-accordion-btn\">L'Oeuvre <i data-lucide=\"chevron-down\" class=\"w-4 h-4\"></i></button><div class=\"hidden mt-3 space-y-3 pl-4 border-l-2 border-brand-50\"><a href=\"https://haroboz.com/portfolio/\" class=\"block text-sm text-gray-600 hover:text-brand\">Toutes les oeuvres</a><a href=\"https://haroboz.com/portfolio/galerie-portraits-hommes/\" class=\"block text-sm text-gray-600 hover:text-brand\">Portraits</a><a href=\"https://haroboz.com/portfolio/#nus\" class=\"block text-sm text-gray-600 hover:text-brand\">Nus &amp; Attributs</a><a href=\"https://haroboz.com/portfolio/galerie-couples/\" class=\"block text-sm text-gray-600 hover:text-brand\">Couples &amp; Duos</a><a href=\"https://haroboz.com/portfolio/#creation\" class=\"block text-sm text-gray-600 hover:text-brand\">Création d'art</a><a href=\"https://haroboz.com/portfolio/#reportages\" class=\"block text-sm text-gray-600 hover:text-brand\">Reportages</a></div></div>\n                <div class=\"border-b border-gray-100 py-3\"><a href=\"https://haroboz.com/a-propos/\" class=\"block font-medium text-brand\">L'Univers</a></div>\n            </nav>\n            <div class=\"mt-8\"><button onclick=\"openPopup(); toggleMobileMenu();\" class=\"w-full bg-brand text-white px-6 py-4 rounded-xl font-medium hover:bg-brand-light shadow-md flex justify-center items-center cursor-pointer\"><i data-lucide=\"calendar\" class=\"w-5 h-5 mr-2\"></i> Prendre RDV gratuit</button></div>\n        </div>\n    </div>\n    <div id=\"mobile-overlay\" class=\"fixed inset-0 bg-brand bg-opacity-50 z-40 hidden\"></div>\n\n    <main class=\"w-full\">\n        <!-- PAGE HERO -->\n        <section class=\"bg-brand pt-28 lg:pt-32 pb-12 lg:pb-16 relative overflow-hidden\">\n            <div class=\"absolute top-0 right-0 -translate-y-1/3 translate-x-1/4 w-96 h-96 bg-brand-light rounded-full opacity-30 blur-3xl\"></div>\n            <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10\">\n                <nav class=\"text-sm text-white/60 mb-6\" aria-label=\"Fil d'Ariane\">\n                    <a href=\"https://haroboz.com/\" class=\"hover:text-white\">Accueil</a> <span class=\"mx-2\">&rsaquo;</span> <a href=\"https://haroboz.com/photographe/\" class=\"hover:text-white\">Nos Lieux</a> <span class=\"mx-2\">&rsaquo;</span> <span class=\"text-white/90\">Nice</span>\n                </nav>\n                <h1 class=\"text-3xl md:text-4xl lg:text-5xl font-serif font-bold text-white mb-4\">Photographe Nu Masculin à Nice</h1>\n                <p class=\"text-white/70 text-base md:text-lg max-w-2xl\">Nice vibre d'une énergie solaire et méditerranéenne unique. Entre la Baie des Anges et les ruelles colorées du Vieux-Nice, Luc Desbois crée des portraits d'art masculins d'une intensité lumineuse.</p>\n            </div>\n        </section>\n\n        <!-- SEO CONTENT -->\n        \n        <section class=\"py-12 lg:py-16 bg-white\">\n            <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <div class=\"grid lg:grid-cols-2 gap-10 lg:gap-16 items-center\">\n                    <div>\n                        <h2 class=\"text-2xl md:text-3xl font-serif text-brand mb-4\">Nice, la lumière des peintres au service du portrait</h2>\n\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Henri Matisse s'y est installé pour peindre. Yves Klein y est né. La lumière de Nice a inspiré des générations entières d'artistes, et ce n'est pas un hasard. La capitale azuréenne bénéficie d'un ensoleillement exceptionnel &mdash; plus de 300 jours de soleil par an &mdash; et d'une qualité de lumière que les photographes du monde entier lui envient. C'est cette lumière que <a href=\"https://haroboz.com/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4 transition-colors\">Haroboz</a> met au service de votre portrait d'art à Nice.</p>\n\n                <p class=\"text-gray-600 leading-relaxed mb-4\">La Promenade des Anglais, avec sa courbe majestueuse le long de la Baie des Anges, offre un cadre grandiose. Aux premières heures du matin, avant l'afflux des promeneurs, la lumière rasante dessine des ombres longues sur les galets et baigne les façades Belle Époque d'une teinte rose dorée. Luc y réalise des séances extérieures d'une beauté cinématographique, dans des segments discrets du littoral que les touristes ne fréquentent pas.</p>\n\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Le Vieux-Nice est un terrain de jeu photographique d'une richesse inépuisable. Le Cours Saleya avec ses façades ocre et terracotta, les passages couverts du quartier de la cathédrale, les escaliers qui montent vers la Colline du Château... Chaque ruelle offre un jeu d'ombre et de lumière différent, un cadrage naturel que Luc exploite avec la précision d'un directeur de la photographie. La Colline du Château elle-même, avec ses cascades, ses ruines et sa vue panoramique sur la ville, constitue un lieu de shooting saisissant.</p>\n\n                \n                    </div>\n                    <div>\n                        <img src=\"https://haroboz.com/wp-content/uploads/2026/04/IMG_1549-1-scaled.png\" alt=\"Haroboz — Photographie d'art\" class=\"aspect-[4/3] rounded-2xl object-cover w-full shadow-lg\" loading=\"lazy\">\n                    </div>\n                </div>\n            </div>\n        </section>\n        <section class=\"py-8 bg-brand-50 border-y border-brand/10\">\n            <div class=\"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-4\">\n                <p class=\"text-brand font-serif text-lg md:text-xl text-center sm:text-left\">Envie de vivre cette expérience ?</p>\n                <button onclick=\"openPopup()\" class=\"bg-brand text-white px-6 py-3 rounded-full text-sm font-medium hover:bg-brand-light transition-colors shadow-md flex items-center cursor-pointer whitespace-nowrap\">\n                    <i data-lucide=\"calendar\" class=\"w-4 h-4 mr-2\"></i> Prendre RDV gratuit\n                </button>\n            </div>\n        </section>\n        <section class=\"py-12 lg:py-16 bg-gray-50\">\n            <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <div class=\"grid lg:grid-cols-2 gap-10 lg:gap-16 items-center\">\n                    <div class=\"order-2 lg:order-1\">\n                        <img src=\"https://haroboz.com/wp-content/uploads/2026/03/Photoroom_20251222_144602.png\" alt=\"Haroboz — Photographie d'art\" class=\"aspect-[4/3] rounded-2xl object-cover w-full shadow-lg\" loading=\"lazy\">\n                    </div>\n                    <div class=\"order-1 lg:order-2\">\n                        <h2 class=\"text-2xl md:text-3xl font-serif text-brand mb-4\">Une séance adaptée à l'énergie niçoise</h2>\n\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Nice a une atmosphère unique parmi nos lieux de shooting. L'énergie y est vive, solaire, résolument urbaine. Luc adapte sa direction artistique à cette particularité. Les séances niçoises ont souvent une tonalité plus dynamique, plus contrastée, jouant avec la géométrie des architectures baroques et la vivacité des couleurs méditerranéennes. Le résultat : des portraits qui respirent la vie, la confiance et l'affirmation de soi.</p>\n\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Pour ceux qui recherchent davantage de calme, le port de Nice et la colline de Cimiez offrent des alternatives plus intimes. Les jardins du monastère de Cimiez, avec leurs oliviers et leur vue plongeante sur la ville, permettent des séances dans un environnement paisible et verdoyant. Le port, avec ses façades colorées et ses bateaux de pêche, apporte une touche d'authenticité maritime.</p>\n\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Quel que soit le lieu choisi à Nice, votre expérience inclut l'entretien préalable confidentiel, la direction artistique complète, le coaching de pose bienveillant et un <a href=\"https://haroboz.com/boutique/tirages-art-edition-limitee/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4 transition-colors\">tirage d'art signé</a>. Vous pouvez aussi combiner votre séance niçoise avec un <a href=\"https://haroboz.com/packs-shooting/portrait-studio/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4 transition-colors\">portrait en studio</a> pour un résultat encore plus riche et varié.</p>\n\n                \n                    </div>\n                </div>\n            </div>\n        </section>\n        <!-- RÉALISATIONS — Mini galerie -->\n        <section class=\"py-12 md:py-16 bg-gray-50 border-y border-gray-100\">\n            <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <div class=\"text-center mb-8\">\n                    <span class=\"text-xs font-bold tracking-widest text-gray-400 uppercase block mb-2\">Réalisations</span>\n                    <h3 class=\"text-2xl md:text-3xl font-serif text-brand\">Un aperçu de nos créations</h3>\n                </div>\n                <div class=\"grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4\">\n                    <img src=\"https://haroboz.com/wp-content/uploads/2025/11/IMG_2919.png\" alt=\"Réalisation Haroboz\" class=\"aspect-[3/4] rounded-2xl object-cover w-full shadow-md hover:shadow-xl transition-shadow duration-300\" loading=\"lazy\">\n                    <img src=\"https://haroboz.com/wp-content/uploads/2026/04/Photoroom_20250615_213259-1-scaled.png\" alt=\"Réalisation Haroboz\" class=\"aspect-[3/4] rounded-2xl object-cover w-full shadow-md hover:shadow-xl transition-shadow duration-300\" loading=\"lazy\">\n                    <img src=\"https://haroboz.com/wp-content/uploads/2025/12/Photoroom_20250414_131832.png\" alt=\"Réalisation Haroboz\" class=\"aspect-[3/4] rounded-2xl object-cover w-full shadow-md hover:shadow-xl transition-shadow duration-300 hidden md:block\" loading=\"lazy\">\n                    <img src=\"https://haroboz.com/wp-content/uploads/2025/12/Photoroom_20251011_225926.png\" alt=\"Réalisation Haroboz\" class=\"aspect-[3/4] rounded-2xl object-cover w-full shadow-md hover:shadow-xl transition-shadow duration-300 hidden md:block\" loading=\"lazy\">\n                </div>\n                <div class=\"text-center mt-8\">\n                    <a href=\"https://haroboz.com/portfolio/\" class=\"inline-flex items-center text-brand font-medium hover:text-brand-light transition-colors group\">\n                        <span>Voir toutes les réalisations</span>\n                        <i data-lucide=\"arrow-right\" class=\"w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform\"></i>\n                    </a>\n                </div>\n            </div>\n        </section>\n        <section class=\"py-12 lg:py-16 bg-white\">\n            <div class=\"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <h2 class=\"text-2xl md:text-3xl font-serif text-brand mb-4\">Nos autres lieux de shooting</h2>\n\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Luc Desbois intervient dans quatre villes. Au-delà de Nice, découvrez nos autres lieux :</p>\n\n                <ul class=\"space-y-3 my-6\">\n                    <li class=\"flex items-start gap-3 text-gray-600\"><i data-lucide=\"check\" class=\"w-5 h-5 text-brand flex-shrink-0 mt-0.5\"></i><span><a href=\"https://haroboz.com/photographe/photographe-marseille/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4 transition-colors\">Photographe art masculin à Marseille</a> &mdash; Calanques, MuCEM et lumière méditerranéenne</span></li>\n                    <li class=\"flex items-start gap-3 text-gray-600\"><i data-lucide=\"check\" class=\"w-5 h-5 text-brand flex-shrink-0 mt-0.5\"></i><span><a href=\"https://haroboz.com/photographe/photographe-toulon/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4 transition-colors\">Photographe art masculin à Toulon</a> &mdash; Rade, Mont Faron et charme provençal</span></li>\n                    <li class=\"flex items-start gap-3 text-gray-600\"><i data-lucide=\"check\" class=\"w-5 h-5 text-brand flex-shrink-0 mt-0.5\"></i><span><a href=\"https://haroboz.com/photographe/photographe-paris/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4 transition-colors\">Photographe art masculin à Paris</a> &mdash; Studios privés et lumière parisienne</span></li>\n                </ul>\n            \n            </div>\n        </section>\n\n        <!-- FAQ -->\n        \n        <!-- TIRAGES D'ART — Mise en avant -->\n        <section class=\"py-14 md:py-20 bg-white border-t border-gray-100\">\n            <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <div class=\"grid lg:grid-cols-2 gap-10 lg:gap-16 items-center\">\n                    <div>\n                        <span class=\"text-xs font-bold tracking-widest text-brand/60 uppercase block mb-3\">Inclus dans chaque pack</span>\n                        <h3 class=\"text-2xl md:text-3xl font-serif text-brand mb-4\">Votre tirage d'art Fine Art</h3>\n                        <p class=\"text-gray-600 leading-relaxed mb-4\">Chaque séance Haroboz aboutit à une œuvre tangible : un tirage d'art signé et numéroté, imprimé sur papier Hahnemühle avec des encres pigmentaires de qualité muséale. Ce n'est pas un simple fichier numérique — c'est un objet d'art que vous conserverez toute votre vie.</p>\n                        <div class=\"flex flex-wrap gap-4 mb-6\">\n                            <div class=\"flex items-center gap-2 text-sm text-gray-500\">\n                                <i data-lucide=\"printer\" class=\"w-4 h-4 text-brand\"></i>\n                                <span>Papier Fine Art Hahnemühle</span>\n                            </div>\n                            <div class=\"flex items-center gap-2 text-sm text-gray-500\">\n                                <i data-lucide=\"pen-tool\" class=\"w-4 h-4 text-brand\"></i>\n                                <span>Signé & numéroté</span>\n                            </div>\n                            <div class=\"flex items-center gap-2 text-sm text-gray-500\">\n                                <i data-lucide=\"shield-check\" class=\"w-4 h-4 text-brand\"></i>\n                                <span>Édition limitée</span>\n                            </div>\n                        </div>\n                        <a href=\"https://haroboz.com/boutique/tirages-art-edition-limitee/\" class=\"inline-flex items-center text-brand font-medium hover:text-brand-light transition-colors group\">\n                            <span>Découvrir nos tirages d'art</span>\n                            <i data-lucide=\"arrow-right\" class=\"w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform\"></i>\n                        </a>\n                    </div>\n                    <div class=\"grid grid-cols-2 gap-3\">\n                        <img src=\"https://haroboz.com/wp-content/uploads/2026/04/IMG_5047-1-scaled.png\" alt=\"Tirage d'art Fine Art encadré\" class=\"rounded-2xl aspect-[3/4] object-cover w-full shadow-lg\" loading=\"lazy\">\n                        <img src=\"https://haroboz.com/wp-content/uploads/2026/04/IMG_5963-1-scaled.png\" alt=\"Galerie de tirages d'art\" class=\"rounded-2xl aspect-[3/4] object-cover w-full shadow-lg mt-6\" loading=\"lazy\">\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        <section class=\"py-12 lg:py-16 bg-gray-50\" itemscope itemtype=\"https://schema.org/FAQPage\">\n            <div class=\"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <h2 class=\"text-2xl md:text-3xl font-serif text-brand mb-8 text-center\">Questions fréquentes &mdash; Shooting à Nice</h2>\n                <div class=\"space-y-3\">\n                    <div class=\"faq-card bg-white rounded-xl shadow-sm border border-gray-100\" itemscope itemprop=\"mainEntity\" itemtype=\"https://schema.org/Question\">\n                        <button onclick=\"toggleFaq(this)\" class=\"w-full flex justify-between items-center p-5 text-left cursor-pointer\">\n                            <span class=\"font-medium text-brand pr-4\" itemprop=\"name\">Avez-vous un studio à Nice ?</span>\n                            <i data-lucide=\"chevron-down\" class=\"faq-chevron w-5 h-5 text-gray-400 flex-shrink-0 transition-transform duration-200\"></i>\n                        </button>\n                        <div class=\"faq-content px-5 pb-5\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https://schema.org/Answer\">\n                            <p class=\"text-gray-600 leading-relaxed\" itemprop=\"text\">Les séances niçoises se déroulent principalement en extérieur, dans les lieux les plus photogéniques de la ville. Si vous souhaitez une séance en studio, nous disposons d'espaces privés accessibles sur rendez-vous. Contactez-nous pour organiser votre séance selon vos préférences.</p>\n                        </div>\n                    </div>\n\n                    <div class=\"faq-card bg-white rounded-xl shadow-sm border border-gray-100\" itemscope itemprop=\"mainEntity\" itemtype=\"https://schema.org/Question\">\n                        <button onclick=\"toggleFaq(this)\" class=\"w-full flex justify-between items-center p-5 text-left cursor-pointer\">\n                            <span class=\"font-medium text-brand pr-4\" itemprop=\"name\">Les séances en extérieur à Nice sont-elles discrètes ?</span>\n                            <i data-lucide=\"chevron-down\" class=\"faq-chevron w-5 h-5 text-gray-400 flex-shrink-0 transition-transform duration-200\"></i>\n                        </button>\n                        <div class=\"faq-content px-5 pb-5\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https://schema.org/Answer\">\n                            <p class=\"text-gray-600 leading-relaxed\" itemprop=\"text\">Oui. Nice est une grande ville, mais Luc connaît des lieux confidentiels : segments isolés de la côte, passages peu fréquentés du Vieux-Nice, jardins privés accessibles sur rendez-vous. Toutes les séances en extérieur sont planifiées aux heures les plus calmes. La discrétion est toujours garantie.</p>\n                        </div>\n                    </div>\n\n                    <div class=\"faq-card bg-white rounded-xl shadow-sm border border-gray-100\" itemscope itemprop=\"mainEntity\" itemtype=\"https://schema.org/Question\">\n                        <button onclick=\"toggleFaq(this)\" class=\"w-full flex justify-between items-center p-5 text-left cursor-pointer\">\n                            <span class=\"font-medium text-brand pr-4\" itemprop=\"name\">Peut-on combiner extérieur et studio ?</span>\n                            <i data-lucide=\"chevron-down\" class=\"faq-chevron w-5 h-5 text-gray-400 flex-shrink-0 transition-transform duration-200\"></i>\n                        </button>\n                        <div class=\"faq-content px-5 pb-5\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https://schema.org/Answer\">\n                            <p class=\"text-gray-600 leading-relaxed\" itemprop=\"text\">Absolument, et c'est même une option très appréciée. Vous commencez par un extérieur à Nice le matin, profitant de la lumière matinale, puis enchaînez avec une séance en studio l'après-midi. Deux ambiances, deux univers visuels, pour un résultat encore plus riche et varié.</p>\n                        </div>\n                    </div>\n\n                    <div class=\"faq-card bg-white rounded-xl shadow-sm border border-gray-100\" itemscope itemprop=\"mainEntity\" itemtype=\"https://schema.org/Question\">\n                        <button onclick=\"toggleFaq(this)\" class=\"w-full flex justify-between items-center p-5 text-left cursor-pointer\">\n                            <span class=\"font-medium text-brand pr-4\" itemprop=\"name\">Je séjourne à Nice, le déplacement est-il inclus ?</span>\n                            <i data-lucide=\"chevron-down\" class=\"faq-chevron w-5 h-5 text-gray-400 flex-shrink-0 transition-transform duration-200\"></i>\n                        </button>\n                        <div class=\"faq-content px-5 pb-5\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https://schema.org/Answer\">\n                            <p class=\"text-gray-600 leading-relaxed\" itemprop=\"text\">Le déplacement à Nice est inclus dans nos packs pour les séances en extérieur. Aucun supplément ne s'applique pour les lieux situés dans la commune de Nice et ses environs immédiats. Contactez-nous pour les détails selon le pack choisi.</p>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </section>\n\n        <!-- CTA -->\n        <section class=\"bg-brand py-16 lg:py-20 relative overflow-hidden\">\n            <div class=\"absolute top-0 right-0 -translate-y-1/2 translate-x-1/3 w-96 h-96 bg-brand-light rounded-full opacity-50 blur-3xl\"></div>\n            <div class=\"absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/3 w-96 h-96 bg-[#3a00a8] rounded-full opacity-50 blur-3xl\"></div>\n            <div class=\"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10\">\n                <h2 class=\"text-3xl md:text-4xl font-serif text-white mb-4\">Votre shooting d'art à Nice</h2>\n                <p class=\"text-brand-50 text-base md:text-lg mb-8 max-w-2xl mx-auto\">Lumière méditerranéenne, direction artistique et tirage signé inclus</p>\n                <button onclick=\"openPopup()\" class=\"bg-white text-brand px-8 py-4 rounded-full text-lg font-bold hover:bg-gray-100 shadow-xl flex items-center justify-center cursor-pointer mx-auto\"><i data-lucide=\"calendar\" class=\"w-5 h-5 mr-2\"></i> Être rappelé sous 24h</button>\n            </div>\n        </section>\n    </main>\n\n    <!-- FOOTER -->\n    <footer class=\"bg-brand text-white border-t border-brand-light/20\">\n        <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16\">\n            <div class=\"grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12\">\n                <div><div class=\"font-serif text-lg font-bold mb-4\">Nos Packs</div><ul class=\"space-y-2\"><li><a href=\"https://haroboz.com/packs-shooting/portrait-studio/\" class=\"text-sm text-gray-300 hover:text-white\">Portrait Studio</a></li><li><a href=\"https://haroboz.com/packs-shooting/shooting-exterieur/\" class=\"text-sm text-gray-300 hover:text-white\">Shooting Extérieur</a></li><li><a href=\"https://haroboz.com/packs-shooting/shooting-duo-couple/\" class=\"text-sm text-gray-300 hover:text-white\">Duo &amp; Couple</a></li><li><a href=\"https://haroboz.com/packs-shooting/photo-domicile/\" class=\"text-sm text-gray-300 hover:text-white\">Photo à Domicile</a></li></ul></div>\n                <div><div class=\"font-serif text-lg font-bold mb-4\">Lieux</div><ul class=\"space-y-2\"><li><a href=\"https://haroboz.com/photographe/photographe-marseille/\" class=\"text-sm text-gray-300 hover:text-white\">Marseille</a></li><li><a href=\"https://haroboz.com/photographe/photographe-toulon/\" class=\"text-sm text-gray-300 hover:text-white\">Toulon</a></li><li><a href=\"https://haroboz.com/photographe/photographe-nice/\" class=\"text-sm text-gray-300 hover:text-white\">Nice</a></li><li><a href=\"https://haroboz.com/photographe/photographe-paris/\" class=\"text-sm text-gray-300 hover:text-white\">Paris</a></li></ul></div>\n                <div><div class=\"font-serif text-lg font-bold mb-4\">Expérience</div><ul class=\"space-y-2\"><li><a href=\"https://haroboz.com/votre-experience/premier-shooting-nu/\" class=\"text-sm text-gray-300 hover:text-white\">Premier Shooting</a></li><li><a href=\"https://haroboz.com/votre-experience/retrouver-confiance-corps/\" class=\"text-sm text-gray-300 hover:text-white\">Retrouver Confiance</a></li><li><a href=\"https://haroboz.com/votre-experience/book-modele-professionnel/\" class=\"text-sm text-gray-300 hover:text-white\">Book Modèle Pro</a></li><li><a href=\"https://haroboz.com/portfolio/temoignages-clients/\" class=\"text-sm text-gray-300 hover:text-white\">Témoignages</a></li></ul></div>\n                <div><div class=\"font-serif text-lg font-bold mb-4\">Haroboz</div><ul class=\"space-y-2\"><li><a href=\"https://haroboz.com/a-propos/\" class=\"text-sm text-gray-300 hover:text-white\">À Propos</a></li><li><a href=\"https://haroboz.com/portfolio/\" class=\"text-sm text-gray-300 hover:text-white\">Réalisations</a></li><li><a href=\"https://haroboz.com/contact/\" class=\"text-sm text-gray-300 hover:text-white\">Contact</a></li><li><a href=\"https://haroboz.com/mentions-legales/\" class=\"text-sm text-gray-300 hover:text-white\">Mentions légales</a></li></ul></div>\n            </div>\n            <div class=\"border-t border-white/10 mt-10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4\">\n                <p class=\"text-sm text-gray-400\">&copy; 2026 Haroboz &mdash; Luc Desbois | Photographe Art Masculin | Marseille, Toulon, Nice, Paris</p>\n                <div class=\"flex items-center gap-4\"><a href=\"https://www.instagram.com/hbozart/\" target=\"_blank\" class=\"text-gray-400 hover:text-white\"><i data-lucide=\"instagram\" class=\"w-5 h-5\"></i></a><a href=\"https://haroboz.com/mentions-legales/\" class=\"text-sm text-gray-400 hover:text-white\">Mentions légales</a></div>\n            </div>\n        </div>\n    </footer>\n\n    <!-- POPUP -->\n    <div id=\"booking-popup\" class=\"fixed inset-0 z-[100] flex items-center justify-center p-4 popup-hidden\">\n        <div class=\"absolute inset-0 bg-brand/60 backdrop-blur-sm\" onclick=\"closePopup()\"></div>\n        <div id=\"popup-content\" class=\"relative bg-white rounded-2xl shadow-2xl max-w-lg w-full max-h-[90vh] overflow-y-auto\">\n            <div class=\"bg-brand rounded-t-2xl p-6 text-center relative\"><button onclick=\"closePopup()\" class=\"absolute top-4 right-4 text-white/70 hover:text-white cursor-pointer\"><i data-lucide=\"x\" class=\"w-6 h-6\"></i></button><h3 class=\"text-xl font-serif text-white font-bold\">Réservez votre séance</h3><p class=\"text-white/70 text-sm mt-1\">Réponse confidentielle sous 24h</p></div>\n            <form id=\"booking-form\" class=\"p-6\" onsubmit=\"handleSubmit(event)\">\n                <div class=\"space-y-4\">\n                    <div><label class=\"block text-sm font-medium text-brand mb-1\">Prénom *</label><input type=\"text\" required placeholder=\"Votre prénom\" name=\"prenom\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-brand placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand\"></div>\n                    <div><label class=\"block text-sm font-medium text-brand mb-1\">Email *</label><input type=\"email\" required placeholder=\"votre@email.com\" name=\"email\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-brand placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand\"></div>\n                    <div><label class=\"block text-sm font-medium text-brand mb-1\">Téléphone *</label><input type=\"tel\" required placeholder=\"06 XX XX XX XX\" name=\"telephone\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-brand placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand\"></div>\n                    <div><label class=\"block text-sm font-medium text-brand mb-1\">Message</label><textarea rows=\"3\" placeholder=\"Parlez-moi de votre projet...\" name=\"message\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-brand placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand resize-none\"></textarea></div>\n                </div>\n                <button type=\"submit\" class=\"w-full mt-6 bg-brand text-white py-4 rounded-xl font-bold hover:bg-brand-light shadow-lg flex items-center justify-center cursor-pointer\"><i data-lucide=\"send\" class=\"w-5 h-5 mr-2\"></i> Envoyer ma demande</button>\n                <p class=\"text-center text-xs text-gray-400 mt-3\"><i data-lucide=\"lock\" class=\"w-3 h-3 inline\"></i> 100% confidentiel</p>\n            </form>\n            <div id=\"popup-success\" class=\"hidden p-8 text-center\"><div class=\"w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4\"><i data-lucide=\"check-circle\" class=\"w-8 h-8 text-green-600\"></i></div><h3 class=\"text-2xl font-serif text-brand mb-2\">Demande envoyée !</h3><p class=\"text-gray-600 mb-6\">Je vous recontacte sous 24h.</p><button onclick=\"closePopup()\" class=\"bg-brand text-white px-6 py-3 rounded-xl font-medium hover:bg-brand-light cursor-pointer\">Fermer</button></div>\n        </div>\n    </div>\n\n    <div id=\"floating-cta\" class=\"fixed bottom-6 right-6 z-50 opacity-0 translate-y-4 transition-all duration-300 pointer-events-none\">\n        <button onclick=\"openPopup()\" class=\"relative bg-brand text-white w-14 h-14 md:w-auto md:h-auto md:px-6 md:py-3 rounded-full shadow-2xl hover:bg-brand-light flex items-center justify-center cursor-pointer pulse-ring text-brand\"><i data-lucide=\"calendar\" class=\"w-6 h-6 md:w-5 md:h-5 md:mr-2\"></i><span class=\"hidden md:inline font-medium\">Prendre RDV</span></button>\n    </div>\n</div>",
