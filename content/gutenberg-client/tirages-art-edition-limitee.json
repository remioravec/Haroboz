ansition-colors\">Immortaliser son Couple</a><a href=\"https://haroboz.com/votre-experience/premier-shooting-nu/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Cadeau &amp; Célébration</a></div></div></div>\n                    <div class=\"mega-menu-item relative h-full flex items-center\"><button class=\"flex items-center text-sm font-medium hover:text-brand-light transition-colors py-8\">Où me trouver ? <i data-lucide=\"chevron-down\" class=\"ml-1 w-4 h-4\"></i></button><div class=\"mega-menu-content absolute top-20 left-1/2 -translate-x-1/2 w-48 bg-white shadow-xl rounded-b-lg border-t border-gray-100\"><div class=\"py-2\"><a href=\"https://haroboz.com/photographe/photographe-marseille/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Marseille</a><a href=\"https://haroboz.com/photographe/photographe-toulon/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Toulon</a><a href=\"https://haroboz.com/photographe/photographe-nice/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Nice</a><a href=\"https://haroboz.com/photographe/photographe-paris/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Paris</a></div></div></div>\n                    <div class=\"mega-menu-item relative h-full flex items-center\"><button class=\"flex items-center text-sm font-medium hover:text-brand-light transition-colors py-8\">L'Oeuvre <i data-lucide=\"chevron-down\" class=\"ml-1 w-4 h-4\"></i></button><div class=\"mega-menu-content absolute top-20 left-1/2 -translate-x-1/2 w-64 bg-white shadow-xl rounded-b-lg border-t border-gray-100 overflow-hidden\"><div class=\"py-2\"><a href=\"https://haroboz.com/portfolio/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Toutes les oeuvres</a><a href=\"https://haroboz.com/portfolio/galerie-portraits-hommes/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Portraits</a><a href=\"https://haroboz.com/portfolio/#nus\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Nus &amp; Attributs</a><a href=\"https://haroboz.com/portfolio/galerie-couples/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Couples &amp; Duos</a><a href=\"https://haroboz.com/portfolio/#creation\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Création d'art</a><a href=\"https://haroboz.com/portfolio/#reportages\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Reportages</a></div></div></div>\n                    <a href=\"https://haroboz.com/a-propos/\" class=\"text-sm font-medium hover:text-brand-light transition-colors\">L'Univers</a>\n                </nav>\n                <div class=\"hidden lg:flex items-center\"><button onclick=\"openPopup()\" class=\"bg-brand text-white px-6 py-2.5 rounded-full text-sm font-medium hover:bg-brand-light shadow-md flex items-center cursor-pointer\"><i data-lucide=\"calendar\" class=\"w-4 h-4 mr-2\"></i> Prendre RDV gratuit</button></div>\n                <div class=\"flex items-center lg:hidden\"><button id=\"mobile-menu-btn\" class=\"text-brand hover:text-brand-light p-2\"><i data-lucide=\"menu\" class=\"w-7 h-7\"></i></button></div>\n            </div>\n        </div>\n    </header>\n\n    <!-- MOBILE MENU -->\n    <div id=\"mobile-menu\" class=\"fixed inset-y-0 right-0 w-full max-w-sm bg-white shadow-2xl z-50 transform translate-x-full overflow-y-auto\">\n        <div class=\"p-6\">\n            <div class=\"flex items-center justify-between mb-8\"><span class=\"font-serif text-2xl font-bold text-brand\">HAROBOZ</span><button id=\"close-menu-btn\" class=\"text-gray-500 hover:text-brand\"><i data-lucide=\"x\" class=\"w-7 h-7\"></i></button></div>\n            <nav class=\"space-y-2\">\n                <div class=\"border-b border-gray-100 py-3\"><button class=\"flex justify-between items-center w-full text-left font-medium text-brand mobile-accordion-btn\">Nos Séances <i data-lucide=\"chevron-down\" class=\"w-4 h-4\"></i></button><div class=\"hidden mt-3 space-y-3 pl-4 border-l-2 border-brand-50\"><a href=\"https://haroboz.com/packs-shooting/portrait-studio/\" class=\"block text-sm text-gray-600 hover:text-brand\">Portrait en Studio</a><a href=\"https://haroboz.com/packs-shooting/shooting-exterieur/\" class=\"block text-sm text-gray-600 hover:text-brand\">Shooting en Extérieur</a><a href=\"https://haroboz.com/packs-shooting/photo-domicile/\" class=\"block text-sm text-gray-600 hover:text-brand\">Photo à Domicile</a><a href=\"https://haroboz.com/packs-shooting/shooting-duo-couple/\" class=\"block text-sm text-gray-600 hover:text-brand\">Shooting Duo &amp; Couple</a></div></div>\n                <div class=\"border-b border-gray-100 py-3\"><button class=\"flex justify-between items-center w-full text-left font-medium text-brand mobile-accordion-btn\">Votre Objectif <i data-lucide=\"chevron-down\" class=\"w-4 h-4\"></i></button><div class=\"hidden mt-3 space-y-3 pl-4 border-l-2 border-brand-50\"><a href=\"https://haroboz.com/votre-experience/retrouver-confiance-corps/\" class=\"block text-sm text-gray-600 hover:text-brand\">Confiance &amp; Acceptation</a><a href=\"https://haroboz.com/votre-experience/book-modele-professionnel/\" class=\"block text-sm text-gray-600 hover:text-brand\">Book Professionnel</a><a href=\"https://haroboz.com/votre-experience/cadeau-couple-original/\" class=\"block text-sm text-gray-600 hover:text-brand\">Immortaliser son Couple</a><a href=\"https://haroboz.com/votre-experience/premier-shooting-nu/\" class=\"block text-sm text-gray-600 hover:text-brand\">Cadeau &amp; Célébration</a></div></div>\n                <div class=\"border-b border-gray-100 py-3\"><button class=\"flex justify-between items-center w-full text-left font-medium text-brand mobile-accordion-btn\">Où me trouver ? <i data-lucide=\"chevron-down\" class=\"w-4 h-4\"></i></button><div class=\"hidden mt-3 space-y-3 pl-4 border-l-2 border-brand-50\"><a href=\"https://haroboz.com/photographe/photographe-marseille/\" class=\"block text-sm text-gray-600 hover:text-brand\">Marseille</a><a href=\"https://haroboz.com/photographe/photographe-toulon/\" class=\"block text-sm text-gray-600 hover:text-brand\">Toulon</a><a href=\"https://haroboz.com/photographe/photographe-nice/\" class=\"block text-sm text-gray-600 hover:text-brand\">Nice</a><a href=\"https://haroboz.com/photographe/photographe-paris/\" class=\"block text-sm text-gray-600 hover:text-brand\">Paris</a></div></div>\n                <div class=\"border-b border-gray-100 py-3\"><button class=\"flex justify-between items-center w-full text-left font-medium text-brand mobile-accordion-btn\">L'Oeuvre <i data-lucide=\"chevron-down\" class=\"w-4 h-4\"></i></button><div class=\"hidden mt-3 space-y-3 pl-4 border-l-2 border-brand-50\"><a href=\"https://haroboz.com/portfolio/\" class=\"block text-sm text-gray-600 hover:text-brand\">Toutes les oeuvres</a><a href=\"https://haroboz.com/portfolio/galerie-portraits-hommes/\" class=\"block text-sm text-gray-600 hover:text-brand\">Portraits</a><a href=\"https://haroboz.com/portfolio/#nus\" class=\"block text-sm text-gray-600 hover:text-brand\">Nus &amp; Attributs</a><a href=\"https://haroboz.com/portfolio/galerie-couples/\" class=\"block text-sm text-gray-600 hover:text-brand\">Couples &amp; Duos</a><a href=\"https://haroboz.com/portfolio/#creation\" class=\"block text-sm text-gray-600 hover:text-brand\">Création d'art</a><a href=\"https://haroboz.com/portfolio/#reportages\" class=\"block text-sm text-gray-600 hover:text-brand\">Reportages</a></div></div>\n                <div class=\"border-b border-gray-100 py-3\"><a href=\"https://haroboz.com/a-propos/\" class=\"block font-medium text-brand\">L'Univers</a></div>\n            </nav>\n            <div class=\"mt-8\"><button onclick=\"openPopup(); toggleMobileMenu();\" class=\"w-full bg-brand text-white px-6 py-4 rounded-xl font-medium hover:bg-brand-light shadow-md flex justify-center items-center cursor-pointer\"><i data-lucide=\"calendar\" class=\"w-5 h-5 mr-2\"></i> Prendre RDV gratuit</button></div>\n        </div>\n    </div>\n    <div id=\"mobile-overlay\" class=\"fixed inset-0 bg-brand bg-opacity-50 z-40 hidden\"></div>\n\n    <main class=\"w-full\">\n\n        <!-- HERO -->\n        <section class=\"bg-brand pt-28 lg:pt-32 pb-16 lg:pb-20\">\n            <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <nav class=\"mb-8\" aria-label=\"Fil d'Ariane\">\n                    <ol class=\"flex items-center space-x-2 text-sm text-white/60\" itemscope itemtype=\"https://schema.org/BreadcrumbList\">\n                        <li itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\"><a itemprop=\"item\" href=\"https://haroboz.com/\" class=\"hover:text-white\"><span itemprop=\"name\">Accueil</span></a><meta itemprop=\"position\" content=\"1\"></li>\n                        <li><i data-lucide=\"chevron-right\" class=\"w-4 h-4\"></i></li>\n                        <li itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\"><a itemprop=\"item\" href=\"https://haroboz.com/boutique/\" class=\"hover:text-white\"><span itemprop=\"name\">Boutique</span></a><meta itemprop=\"position\" content=\"2\"></li>\n                        <li><i data-lucide=\"chevron-right\" class=\"w-4 h-4\"></i></li>\n                        <li itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\"><span itemprop=\"name\" class=\"text-white/90\">Tirages d'Art Édition Limitée</span><meta itemprop=\"position\" content=\"3\"></li>\n                    </ol>\n                </nav>\n                <p class=\"text-white/70 text-sm font-medium tracking-widest uppercase mb-4\">De la photographie à l'oeuvre d'art</p>\n                <h1 class=\"text-4xl md:text-5xl lg:text-6xl font-serif font-bold text-white mb-6\">Tirages d'Art en Édition Limitée</h1>\n                <p class=\"text-lg md:text-xl text-white/80 max-w-2xl leading-relaxed\">Chaque tirage Haroboz est une pièce unique, numérotée et signée par Luc Desbois. Six supports d'exception pour transformer votre portrait en oeuvre de collection, imprimée avec une exigence de qualité muséale.</p>\n            </div>\n        </section>\n\n        <!-- INTRODUCTION -->\n        <section class=\"py-12 lg:py-20 bg-white\">\n            <div class=\"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <h2 class=\"text-2xl md:text-3xl font-serif text-brand mt-12 mb-4\">L'art du tirage, prolongement de la séance</h2>\n\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Chez <a href=\"https://haroboz.com/boutique/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4\">Haroboz</a>, la photographie ne s'arr&ecirc;te pas au déclenchement. Le tirage d'art est le prolongement naturel et essentiel de chaque <a href=\"https://haroboz.com/packs-shooting/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4\">séance photo</a>. C'est l'étape qui transforme une image numérique en un objet précieux, un souvenir tangible que vous pourrez contempler, toucher et conserver toute votre vie.</p>\n\n                <p class=\"text-gray-600 leading-relaxed mb-4\"><a href=\"https://haroboz.com/a-propos/luc-desbois-photographe/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4\">Luc Desbois</a> accorde à cette étape la m&ecirc;me attention qu'à la prise de vue elle-m&ecirc;me. Chaque photo est minutieusement retouchée — avec subtilité, toujours dans le respect de l'authenticité du modèle — puis calibrée spécifiquement pour le support choisi. Car un tirage sur papier fine art ne se prépare pas de la m&ecirc;me manière qu'un tirage sur plexiglas ou sur métal&nbsp;: chaque matériau possède ses propres caractéristiques de rendu, de profondeur et de luminosité.</p>\n\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Nos partenaires d'impression, basés en France, sont des artisans reconnus dans le monde de la photographie d'art. Ils partagent notre exigence de perfection et utilisent des encres pigmentaires de qualité archivale, garantissant une durabilité exceptionnelle de vos tirages. Explorer notre <a href=\"https://haroboz.com/portfolio/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4\">portfolio</a> vous donnera un aper&ccedil;u du rendu final de nos images.</p>\n            </div>\n        </section>\n\n        <!-- LES 6 SUPPORTS -->\n        <section class=\"py-12 lg:py-20 bg-gray-50\">\n            <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <h2 class=\"text-2xl md:text-3xl font-serif text-brand text-center mb-12\">Six supports d'exception</h2>\n\n                <div class=\"grid md:grid-cols-2 lg:grid-cols-3 gap-8\">\n\n                    <div class=\"bg-white rounded-2xl shadow-sm border border-gray-100 p-8 hover:shadow-lg transition-shadow duration-300\">\n                        <div class=\"w-12 h-12 bg-brand-50 rounded-xl flex items-center justify-center mb-6\"><i data-lucide=\"file-text\" class=\"w-6 h-6 text-brand\"></i></div>\n                        <h3 class=\"text-xl font-serif font-semibold text-brand mb-3\">Papier d'Art Fine Art</h3>\n                        <p class=\"text-gray-600 leading-relaxed\">Le support noble par excellence. Notre papier fine art 100&nbsp;% coton, de grammage élevé, offre un rendu velouté aux noirs profonds et aux blancs lumineux. Idéal pour les portraits en clair-obscur, il confère à chaque image une douceur et une profondeur remarquables. Toucher soyeux, finition mate, qualité muséale garantie plus de 100 ans.</p>\n                    </div>\n\n                    <div class=\"bg-white rounded-2xl shadow-sm border border-gray-100 p-8 hover:shadow-lg transition-shadow duration-300\">\n                        <div class=\"w-12 h-12 bg-brand-50 rounded-xl flex items-center justify-center mb-6\"><i data-lucide=\"layers\" class=\"w-6 h-6 text-brand\"></i></div>\n                        <h3 class=\"text-xl font-serif font-semibold text-brand mb-3\">Plexiglas Mat</h3>\n                        <p class=\"text-gray-600 leading-relaxed\">L'élégance contemporaine. L'impression directe sur plexiglas mat offre des couleurs intenses et une profondeur saisissante, sans les reflets parasites du plexiglas brillant. Ce support donne l'impression que l'image flotte dans la matière, créant un effet visuel sophistiqué et moderne. Parfait pour les intérieurs design.</p>\n                    </div>\n\n                    <div class=\"bg-white rounded-2xl shadow-sm border border-gray-100 p-8 hover:shadow-lg transition-shadow duration-300\">\n                        <div class=\"w-12 h-12 bg-brand-50 rounded-xl flex items-center justify-center mb-6\"><i data-lucide=\"hexagon\" class=\"w-6 h-6 text-brand\"></i></div>\n                        <h3 class=\"text-xl font-serif font-semibold text-brand mb-3\">Métal Brossé</h3>\n                        <p class=\"text-gray-600 leading-relaxed\">La puissance brute du métal au service de l'image. L'impression sur aluminium brossé apporte une texture industrielle et un éclat métallique unique à vos portraits. Les hautes lumières brillent d'un éclat naturel tandis que les ombres gagnent en densité. Un support audacieux qui magnifie les compositions graphiques et les corps sculptés.</p>\n                    </div>\n\n                    <div class=\"bg-white rounded-2xl shadow-sm border border-gray-100 p-8 hover:shadow-lg transition-shadow duration-300\">\n                        <div class=\"w-12 h-12 bg-brand-50 rounded-xl flex items-center justify-center mb-6\"><i data-lucide=\"frame\" class=\"w-6 h-6 text-brand\"></i></div>\n                        <h3 class=\"text-xl font-serif font-semibold text-brand mb-3\">Toile Canvas</h3>\n                        <p class=\"text-gray-600 leading-relaxed\">L'héritage pictural. La toile canvas évoque immédiatement le monde de la peinture et confère à votre portrait un caractère artistique affirmé. La texture tissée adoucit les transitions et ajoute une dimension organique à l'image. Montée sur ch&acirc;ssis bois, votre photo devient littéralement un tableau, pr&ecirc;t à orner votre mur.</p>\n                    </div>\n\n                    <div class=\"bg-white rounded-2xl shadow-sm border border-gray-100 p-8 hover:shadow-lg transition-shadow duration-300\">\n                        <div class=\"w-12 h-12 bg-brand-50 rounded-xl flex items-center justify-center mb-6\"><i data-lucide=\"wind\" class=\"w-6 h-6 text-brand\"></i></div>\n                        <h3 class=\"text-xl font-serif font-semibold text-brand mb-3\">Voile de Soie</h3>\n                        <p class=\"text-gray-600 leading-relaxed\">La sensualité à l'état pur. Ce support rare et précieux offre une transparence éthérée qui transforme chaque portrait en apparition. La lumière traverse la soie et anime l'image selon l'éclairage ambiant, créant une oeuvre vivante qui évolue au fil de la journée. Un choix d'exception pour les amateurs de pièces uniques et poétiques.</p>\n                    </div>\n\n                    <div class=\"bg-white rounded-2xl shadow-sm border border-gray-100 p-8 hover:shadow-lg transition-shadow duration-300\">\n                        <div class=\"w-12 h-12 bg-brand-50 rounded-xl flex items-center justify-center mb-6\"><i data-lucide=\"gem\" class=\"w-6 h-6 text-brand\"></i></div>\n                        <h3 class=\"text-xl font-serif font-semibold text-brand mb-3\">Verre</h3>\n                        <p class=\"text-gray-600 leading-relaxed\">La pureté absolue. L'impression sur verre offre une netteté et une brillance incomparables. Les couleurs atteignent une saturation et une profondeur que nul autre support ne peut égaler. Rétroéclairé, le tirage sur verre révèle des détails invisibles à l'oeil nu et transforme votre portrait en véritable vitrail contemporain.</p>\n                    </div>\n\n                </div>\n            </div>\n        </section>\n\n        <!-- PROCESSUS -->\n        <section class=\"py-12 lg:py-20 bg-white\">\n            <div class=\"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <h2 class=\"text-2xl md:text-3xl font-serif text-brand mt-12 mb-4\">Le processus de commande</h2>\n\n                <h3 class=\"text-xl font-serif text-brand mt-8 mb-3\">1. Sélection dans votre galerie privée</h3>\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Après votre séance, toutes vos photos sont déposées dans votre <a href=\"https://haroboz.com/boutique/galerie-privee-client/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4\">galerie privée sécurisée</a>. Prenez le temps de les parcourir, de les comparer, de les montrer à un proche de confiance. Aucune pression, aucun délai imposé&nbsp;: vous choisissez à votre rythme les images qui vous touchent le plus.</p>\n\n                <h3 class=\"text-xl font-serif text-brand mt-8 mb-3\">2. Choix du support et du format</h3>\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Une fois vos photos sélectionnées, Luc vous accompagne dans le choix du support et du format les plus adaptés à chaque image et à votre intérieur. Chaque combinaison image-support est unique, et nous prenons le temps de vous conseiller pour un résultat optimal.</p>\n\n                <h3 class=\"text-xl font-serif text-brand mt-8 mb-3\">3. Impression et contr&ocirc;le qualité</h3>\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Votre tirage est réalisé par nos partenaires artisans, puis soumis à un contr&ocirc;le qualité rigoureux. Chaque exemplaire est numéroté, signé par <a href=\"https://haroboz.com/a-propos/luc-desbois-photographe/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4\">Luc Desbois</a> et accompagné d'un certificat d'authenticité. Livraison soignée dans un emballage sur mesure, directement à votre adresse.</p>\n            </div>\n        </section>\n\n        <!-- ÉDITION LIMITÉE -->\n        <section class=\"py-12 lg:py-20 bg-gray-50\">\n            <div class=\"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <h2 class=\"text-2xl md:text-3xl font-serif text-brand mt-12 mb-4\">Pourquoi l'édition limitée ?</h2>\n\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Chaque tirage Haroboz est produit en <strong>édition strictement limitée</strong>. Ce choix n'est pas une stratégie commerciale&nbsp;: c'est une conviction artistique. En limitant le nombre d'exemplaires, nous garantissons l'exclusivité de chaque oeuvre et sa valeur dans le temps. Votre portrait n'est pas une reproduction de masse, c'est une pièce unique, porteuse de sens et de mémoire.</p>\n\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Cette démarche s'inscrit dans la philosophie globale de Haroboz&nbsp;: chaque détail compte, chaque étape est soignée, chaque client est traité avec le respect et l'attention qu'il mérite. De la <a href=\"https://haroboz.com/votre-experience/premier-shooting-nu/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4\">première prise de contact</a> à la réception de votre oeuvre, l'expérience est pensée pour &ecirc;tre inoubliable.</p>\n\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Vous souhaitez offrir un tirage d'art ou une séance complète&nbsp;? Découvrez notre <a href=\"https://haroboz.com/boutique/carte-cadeau/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4\">carte cadeau</a>, le moyen le plus élégant de partager l'univers Haroboz avec un proche.</p>\n            </div>\n        </section>\n\n        \n        <!-- RÉALISATIONS — Mini galerie -->\n        <section class=\"py-12 md:py-16 bg-gray-50 border-y border-gray-100\">\n            <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <div class=\"text-center mb-8\">\n                    <span class=\"text-xs font-bold tracking-widest text-gray-400 uppercase block mb-2\">Réalisations</span>\n                    <h3 class=\"text-2xl md:text-3xl font-serif text-brand\">Un aperçu de nos créations</h3>\n                </div>\n                <div class=\"grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4\">\n                    <img src=\"https://haroboz.com/wp-content/uploads/2025/12/Photoroom_20250405_115755.png\" alt=\"Réalisation Haroboz\" class=\"aspect-[3/4] rounded-2xl object-cover w-full shadow-md hover:shadow-xl transition-shadow duration-300\" loading=\"lazy\">\n                    <img src=\"https://haroboz.com/wp-content/uploads/2026/02/Photoroom_20260217_122033.png\" alt=\"Réalisation Haroboz\" class=\"aspect-[3/4] rounded-2xl object-cover w-full shadow-md hover:shadow-xl transition-shadow duration-300\" loading=\"lazy\">\n                    <img src=\"https://haroboz.com/wp-content/uploads/2026/04/IMG_0267-1-scaled.png\" alt=\"Réalisation Haroboz\" class=\"aspect-[3/4] rounded-2xl object-cover w-full shadow-md hover:shadow-xl transition-shadow duration-300 hidden md:block\" loading=\"lazy\">\n                    <img src=\"https://haroboz.com/wp-content/uploads/2026/03/Photoroom_20260213_102220.png\" alt=\"Réalisation Haroboz\" class=\"aspect-[3/4] rounded-2xl object-cover w-full shadow-md hover:shadow-xl transition-shadow duration-300 hidden md:block\" loading=\"lazy\">\n                </div>\n                <div class=\"text-center mt-8\">\n                    <a href=\"https://haroboz.com/portfolio/\" class=\"inline-flex items-center text-brand font-medium hover:text-brand-light transition-colors group\">\n                        <span>Voir toutes les réalisations</span>\n                        <i data-lucide=\"arrow-right\" class=\"w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform\"></i>\n                    </a>\n                </div>\n            </div>\n        </section>\n\n<!-- CTA -->\n        <section class=\"bg-brand py-16 lg:py-20\">\n            <div class=\"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center\">\n                <h2 class=\"text-3xl md:text-4xl font-serif font-bold text-white mb-4\">Créez votre oeuvre d'art personnelle</h2>\n                <p class=\"text-white/70 text-lg mb-8\">Tirages numérotés et signés depuis Marseille, dans le sud de la France</p>\n                <button onclick=\"openPopup()\" class=\"bg-white text-brand px-8 py-4 rounded-full text-lg font-medium hover:bg-gray-100 shadow-lg inline-flex items-center cursor-pointer\"><i data-lucide=\"calendar\" class=\"w-5 h-5 mr-2\"></i> Contactez-nous pour un devis</button>\n            </div>\n        </section>\n\n    </main>\n\n    <!-- FOOTER -->\n    <footer class=\"bg-brand text-white border-t border-brand-light/20\">\n        <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16\">\n            <div class=\"grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12\">\n                <div><div class=\"font-serif text-lg font-bold mb-4\">Nos Packs</div><ul class=\"space-y-2\"><li><a href=\"https://haroboz.com/packs-shooting/portrait-studio/\" class=\"text-sm text-gray-300 hover:text-white\">Portrait Studio</a></li><li><a href=\"https://haroboz.com/packs-shooting/shooting-exterieur/\" class=\"text-sm text-gray-300 hover:text-white\">Shooting Extérieur</a></li><li><a href=\"https://haroboz.com/packs-shooting/shooting-duo-couple/\" class=\"text-sm text-gray-300 hover:text-white\">Duo &amp; Couple</a></li><li><a href=\"https://haroboz.com/packs-shooting/photo-domicile/\" class=\"text-sm text-gray-300 hover:text-white\">Photo à Domicile</a></li></ul></div>\n                <div><div class=\"font-serif text-lg font-bold mb-4\">Lieux</div><ul class=\"space-y-2\"><li><a href=\"https://haroboz.com/photographe/photographe-marseille/\" class=\"text-sm text-gray-300 hover:text-white\">Marseille</a></li><li><a href=\"https://haroboz.com/photographe/photographe-toulon/\" class=\"text-sm text-gray-300 hover:text-white\">Toulon</a></li><li><a href=\"https://haroboz.com/photographe/photographe-nice/\" class=\"text-sm text-gray-300 hover:text-white\">Nice</a></li><li><a href=\"https://haroboz.com/photographe/photographe-paris/\" class=\"text-sm text-gray-300 hover:text-white\">Paris</a></li></ul></div>\n                <div><div class=\"font-serif text-lg font-bold mb-4\">Expérience</div><ul class=\"space-y-2\"><li><a href=\"https://haroboz.com/votre-experience/premier-shooting-nu/\" class=\"text-sm text-gray-300 hover:text-white\">Premier Shooting</a></li><li><a href=\"https://haroboz.com/votre-experience/retrouver-confiance-corps/\" class=\"text-sm text-gray-300 hover:text-white\">Retrouver Confiance</a></li><li><a href=\"https://haroboz.com/votre-experience/book-modele-professionnel/\" class=\"text-sm text-gray-300 hover:text-white\">Book Modèle Pro</a></li><li><a href=\"https://haroboz.com/portfolio/temoignages-clients/\" class=\"text-sm text-gray-300 hover:text-white\">Témoignages</a></li></ul></div>\n                <div><div class=\"font-serif text-lg font-bold mb-4\">Haroboz</div><ul class=\"space-y-2\"><li><a href=\"https://haroboz.com/a-propos/\" class=\"text-sm text-gray-300 hover:text-white\">&Agrave; Propos</a></li><li><a href=\"https://haroboz.com/portfolio/\" class=\"text-sm text-gray-300 hover:text-white\">Réalisations</a></li><li><a href=\"https://haroboz.com/contact/\" class=\"text-sm text-gray-300 hover:text-white\">Contact</a></li><li><a href=\"https://haroboz.com/mentions-legales/\" class=\"text-sm text-gray-300 hover:text-white\">Mentions légales</a></li></ul></div>\n            </div>\n            <div class=\"border-t border-white/10 mt-10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4\">\n                <p class=\"text-sm text-gray-400\">&copy; 2026 Haroboz — Luc Desbois | Photographe Art Masculin | Marseille, Toulon, Nice, Paris</p>\n                <div class=\"flex items-center gap-4\"><a href=\"https://www.instagram.com/hbozart/\" target=\"_blank\" class=\"text-gray-400 hover:text-white\"><i data-lucide=\"instagram\" class=\"w-5 h-5\"></i></a><a href=\"https://haroboz.com/mentions-legales/\" class=\"text-sm text-gray-400 hover:text-white\">Mentions légales</a></div>\n            </div>\n        </div>\n    </footer>\n\n    <!-- POPUP -->\n    <div id=\"booking-popup\" class=\"fixed inset-0 z-[100] flex items-center justify-center p-4 popup-hidden\">\n        <div class=\"absolute inset-0 bg-brand/60 backdrop-blur-sm\" onclick=\"closePopup()\"></div>\n        <div id=\"popup-content\" class=\"relative bg-white rounded-2xl shadow-2xl max-w-lg w-full max-h-[90vh] overflow-y-auto\">\n            <div class=\"bg-brand rounded-t-2xl p-6 text-center relative\"><button onclick=\"closePopup()\" class=\"absolute top-4 right-4 text-white/70 hover:text-white cursor-pointer\"><i data-lucide=\"x\" class=\"w-6 h-6\"></i></button><h3 class=\"text-xl font-serif text-white font-bold\">Réservez votre séance</h3><p class=\"text-white/70 text-sm mt-1\">Réponse confidentielle sous 24h</p></div>\n            <form id=\"booking-form\" class=\"p-6\" onsubmit=\"handleSubmit(event)\"><div class=\"space-y-4\"><div><label class=\"block text-sm font-medium text-brand mb-1\">Prénom *</label><input type=\"text\" required placeholder=\"Votre prénom\" name=\"prenom\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-brand placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand\"></div><div><label class=\"block text-sm font-medium text-brand mb-1\">Email *</label><input type=\"email\" required placeholder=\"votre@email.com\" name=\"email\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-brand placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand\"></div><div><label class=\"block text-sm font-medium text-brand mb-1\">Téléphone *</label><input type=\"tel\" required placeholder=\"06 XX XX XX XX\" name=\"telephone\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-brand placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand\"></div><div><label class=\"block text-sm font-medium text-brand mb-1\">Message</label><textarea rows=\"3\" placeholder=\"Parlez-moi de votre projet...\" name=\"message\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-brand placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand resize-none\"></textarea></div></div><button type=\"submit\" class=\"w-full mt-6 bg-brand text-white py-4 rounded-xl font-bold hover:bg-brand-light shadow-lg flex items-center justify-center cursor-pointer\"><i data-lucide=\"send\" class=\"w-5 h-5 mr-2\"></i> Envoyer ma demande</button><p class=\"text-center text-xs text-gray-400 mt-3\"><i data-lucide=\"lock\" class=\"w-3 h-3 inline\"></i> 100% confidentiel</p></form>\n            <div id=\"popup-success\" class=\"hidden p-8 text-center\"><div class=\"w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4\"><i data-lucide=\"check-circle\" class=\"w-8 h-8 text-green-600\"></i></div><h3 class=\"text-2xl font-serif text-brand mb-2\">Demande envoyée !</h3><p class=\"text-gray-600 mb-6\">Je vous recontacte sous 24h.</p><button onclick=\"closePopup()\" class=\"bg-brand text-white px-6 py-3 rounded-xl font-medium hover:bg-brand-light cursor-pointer\">Fermer</button></div>\n        </div>\n    </div>\n    <div id=\"floating-cta\" class=\"fixed bottom-6 right-6 z-50 opacity-0 translate-y-4 transition-all duration-300 pointer-events-none\"><button onclick=\"openPopup()\" class=\"relative bg-brand text-white w-14 h-14 md:w-auto md:h-auto md:px-6 md:py-3 rounded-full shadow-2xl hover:bg-brand-light flex items-center justify-center cursor-pointer pulse-ring text-brand\"><i data-lucide=\"calendar\" class=\"w-6 h-6 md:w-5 md:h-5 md:mr-2\"></i><span class=\"hidden md:inline font-medium\">Prendre RDV</span></button></div>\n</div>",
