  "content_raw": "<style>\n\n        .mega-menu-content { visibility: hidden; opacity: 0; transform: translateY(10px); transition: all 0.3s ease-in-out; }\n        .mega-menu-item:hover .mega-menu-content { visibility: visible; opacity: 1; transform: translateY(0); pointer-events: auto; }\n        #mobile-menu { transition: transform 0.3s ease-in-out; }\n        .menu-open { transform: translateX(0) !important; }\n        #booking-popup { transition: opacity 0.3s ease, visibility 0.3s ease; }\n        #booking-popup.popup-hidden { opacity: 0; visibility: hidden; }\n        #booking-popup.popup-visible { opacity: 1; visibility: visible; }\n        #popup-content { transition: transform 0.3s ease, opacity 0.3s ease; }\n        #booking-popup.popup-hidden #popup-content { transform: scale(0.95) translateY(20px); opacity: 0; }\n        #booking-popup.popup-visible #popup-content { transform: scale(1) translateY(0); opacity: 1; }\n        @keyframes pulse-ring { 0% { transform: scale(1); opacity: 1; } 80%, 100% { transform: scale(1.4); opacity: 0; } }\n        .pulse-ring::before { content: ''; position: absolute; inset: -4px; border-radius: 9999px; border: 2px solid currentColor; animation: pulse-ring 2s ease-out infinite; }\n        .faq-content { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }\n    \n</style>\n<div class=\"haroboz-page\">\n<!-- HEADER -->\n    <header id=\"main-header\" class=\"fixed top-0 left-0 w-full z-50 bg-white shadow-sm transition-all duration-300\">\n        <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n            <div class=\"flex justify-between items-center h-20\">\n                <div class=\"flex-shrink-0\"><a href=\"https://haroboz.com/\" class=\"font-serif text-2xl lg:text-3xl font-bold tracking-tight text-brand\">HAROBOZ</a></div>\n                <nav class=\"hidden lg:flex space-x-8 h-full items-center\">\n                    <div class=\"mega-menu-item relative h-full flex items-center\"><button clas