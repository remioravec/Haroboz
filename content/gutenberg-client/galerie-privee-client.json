ace-y-2\">\n                <div class=\"border-b border-gray-100 py-3\"><button class=\"flex justify-between items-center w-full text-left font-medium text-brand mobile-accordion-btn\">Nos Séances <i data-lucide=\"chevron-down\" class=\"w-4 h-4\"></i></button><div class=\"hidden mt-3 space-y-3 pl-4 border-l-2 border-brand-50\"><a href=\"https://haroboz.com/packs-shooting/portrait-studio/\" class=\"block text-sm text-gray-600 hover:text-brand\">Portrait en Studio</a><a href=\"https://haroboz.com/packs-shooting/shooting-exterieur/\" class=\"block text-sm text-gray-600 hover:text-brand\">Shooting en Extérieur</a><a href=\"https://haroboz.com/packs-shooting/photo-domicile/\" class=\"block text-sm text-gray-600 hover:text-brand\">Photo à Domicile</a><a href=\"https://haroboz.com/packs-shooting/shooting-duo-couple/\" class=\"block text-sm text-gray-600 hover:text-brand\">Shooting Duo &amp; Couple</a></div></div>\n                <div class=\"border-b border-gray-100 py-3\"><button class=\"flex justify-between items-center w-full text-left font-medium text-brand mobile-accordion-btn\">Votre Objectif <i data-lucide=\"chevron-down\" class=\"w-4 h-4\"></i></button><div class=\"hidden mt-3 space-y-3 pl-4 border-l-2 border-brand-50\"><a href=\"https://haroboz.com/votre-experience/retrouver-confiance-corps/\" class=\"block text-sm text-gray-600 hover:text-brand\">Confiance &amp; Acceptation</a><a href=\"https://haroboz.com/votre-experience/book-modele-professionnel/\" class=\"block text-sm text-gray-600 hover:text-brand\">Book Professionnel</a><a href=\"https://haroboz.com/votre-experience/cadeau-couple-original/\" class=\"block text-sm text-gray-600 hover:text-brand\">Immortaliser son Couple</a><a href=\"https://haroboz.com/votre-experience/premier-shooting-nu/\" class=\"block text-sm text-gray-600 hover:text-brand\">Cadeau &amp; Célébration</a></div></div>\n                <div class=\"border-b border-gray-100 py-3\"><button class=\"flex justify-between items-center w-full text-left font-medium text-brand mobile-accordion-btn\">Où me trouver ? <i data-lucide=\"chevron-down\" class=\"w-4 h-4\"></i></button><div class=\"hidden mt-3 space-y-3 pl-4 border-l-2 border-brand-50\"><a href=\"https://haroboz.com/photographe/photographe-marseille/\" class=\"block text-sm text-gray-600 hover:text-brand\">Marseille</a><a href=\"https://haroboz.com/photographe/photographe-toulon/\" class=\"block text-sm text-gray-600 hover:text-brand\">Toulon</a><a href=\"https://haroboz.com/photographe/photographe-nice/\" class=\"block text-sm text-gray-600 hover:text-brand\">Nice</a><a href=\"https://haroboz.com/photographe/photographe-paris/\" class=\"block text-sm text-gray-600 hover:text-brand\">Paris</a></div></div>\n                <div class=\"border-b border-gray-100 py-3\"><button class=\"flex justify-between items-center w-full text-left font-medium text-brand mobile-accordion-btn\">L'Oeuvre <i data-lucide=\"chevron-down\" class=\"w-4 h-4\"></i></button><div class=\"hidden mt-3 space-y-3 pl-4 border-l-2 border-brand-50\"><a href=\"https://haroboz.com/portfolio/\" class=\"block text-sm text-gray-600 hover:text-brand\">Toutes les oeuvres</a><a href=\"https://haroboz.com/portfolio/galerie-portraits-hommes/\" class=\"block text-sm text-gray-600 hover:text-brand\">Portraits</a><a href=\"https://haroboz.com/portfolio/#nus\" class=\"block text-sm text-gray-600 hover:text-brand\">Nus &amp; Attributs</a><a href=\"https://haroboz.com/portfolio/galerie-couples/\" class=\"block text-sm text-gray-600 hover:text-brand\">Couples &amp; Duos</a><a href=\"https://haroboz.com/portfolio/#creation\" class=\"block text-sm text-gray-600 hover:text-brand\">Création d'art</a><a href=\"https://haroboz.com/portfolio/#reportages\" class=\"block text-sm text-gray-600 hover:text-brand\">Reportages</a></div></div>\n                <div class=\"border-b border-gray-100 py-3\"><a href=\"https://haroboz.com/a-propos/\" class=\"block font-medium text-brand\">L'Univers</a></div>\n            </nav>\n            <div class=\"mt-8\"><button onclick=\"openPopup(); toggleMobileMenu();\" class=\"w-full bg-brand text-white px-6 py-4 rounded-xl font-medium hover:bg-brand-light shadow-md flex justify-center items-center cursor-pointer\"><i data-lucide=\"calendar\" class=\"w-5 h-5 mr-2\"></i> Prendre RDV gratuit</button></div>\n        </div>\n    </div>\n    <div id=\"mobile-overlay\" class=\"fixed inset-0 bg-brand bg-opacity-50 z-40 hidden\"></div>\n\n    <main class=\"w-full\">\n\n        <!-- HERO -->\n        <section class=\"bg-brand pt-28 lg:pt-32 pb-16 lg:pb-20\">\n            <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <nav class=\"mb-8\" aria-label=\"Fil d'Ariane\">\n                    <ol class=\"flex items-center space-x-2 text-sm text-white/60\" itemscope itemtype=\"https://schema.org/BreadcrumbList\">\n                        <li itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\"><a itemprop=\"item\" href=\"https://haroboz.com/\" class=\"hover:text-white\"><span itemprop=\"name\">Accueil</span></a><meta itemprop=\"position\" content=\"1\"></li>\n                        <li><i data-lucide=\"chevron-right\" class=\"w-4 h-4\"></i></li>\n                        <li itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\"><a itemprop=\"item\" href=\"https://haroboz.com/boutique/\" class=\"hover:text-white\"><span itemprop=\"name\">Boutique</span></a><meta itemprop=\"position\" content=\"2\"></li>\n                        <li><i data-lucide=\"chevron-right\" class=\"w-4 h-4\"></i></li>\n                        <li itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\"><span itemprop=\"name\" class=\"text-white/90\">Galerie Privée Client</span><meta itemprop=\"position\" content=\"3\"></li>\n                    </ol>\n                </nav>\n                <p class=\"text-white/70 text-sm font-medium tracking-widest uppercase mb-4\">Votre espace confidentiel et sécurisé</p>\n                <h1 class=\"text-4xl md:text-5xl lg:text-6xl font-serif font-bold text-white mb-6\">Votre Galerie Privée</h1>\n                <p class=\"text-lg md:text-xl text-white/80 max-w-2xl leading-relaxed\">Après votre séance avec Haroboz, retrouvez l'ensemble de vos photos dans un espace en ligne protégé. Prenez le temps de choisir, commandez vos tirages et gardez le contr&ocirc;le total sur vos images.</p>\n            </div>\n        </section>\n\n        <!-- INTRODUCTION -->\n        <section class=\"py-12 lg:py-20 bg-white\">\n            <div class=\"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <h2 class=\"text-2xl md:text-3xl font-serif text-brand mt-12 mb-4\">La confidentialité au coeur de notre engagement</h2>\n\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Chez <a href=\"https://haroboz.com/boutique/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4\">Haroboz</a>, la <strong>discrétion</strong> n'est pas une option marketing&nbsp;: c'est le fondement m&ecirc;me de notre relation avec chaque client. La galerie privée en est la concrétisation technologique. Dès que <a href=\"https://haroboz.com/a-propos/luc-desbois-photographe/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4\">Luc Desbois</a> a terminé le traitement de vos images, elles sont déposées dans un espace en ligne accessible uniquement par vous, via un lien personnel et un mot de passe sécurisé.</p>\n\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Cette galerie a été con&ccedil;ue pour que le moment de la découverte de vos photos soit aussi intense et intime que la séance elle-m&ecirc;me. Pas de pression, pas de délai artificiel&nbsp;: vous prenez le temps qu'il vous faut pour revisiter vos images, les comparer, les partager avec un proche de confiance si vous le souhaitez, avant de faire votre sélection finale pour le <a href=\"https://haroboz.com/boutique/tirages-art-edition-limitee/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4\">tirage d'art</a>.</p>\n\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Chaque galerie est hébergée sur des serveurs sécurisés, avec un chiffrement de bout en bout. Vos photos ne sont jamais indexées par les moteurs de recherche, ne sont jamais utilisées à des fins promotionnelles sans votre accord explicite, et ne sont jamais partagées avec des tiers. Vous &ecirc;tes le seul ma&icirc;tre de vos images.</p>\n            </div>\n        </section>\n\n        <!-- FONCTIONNALITÉS -->\n        <section class=\"py-12 lg:py-20 bg-gray-50\">\n            <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <h2 class=\"text-2xl md:text-3xl font-serif text-brand text-center mb-12\">Ce que vous offre votre galerie</h2>\n\n                <div class=\"grid md:grid-cols-3 gap-8\">\n\n                    <div class=\"bg-white rounded-2xl shadow-sm border border-gray-100 p-8 text-center hover:shadow-lg transition-shadow duration-300\">\n                        <div class=\"w-14 h-14 bg-brand rounded-full flex items-center justify-center mx-auto mb-6\"><span class=\"text-white text-xl font-bold\">1</span></div>\n                        <h3 class=\"text-xl font-serif font-semibold text-brand mb-3\">Découverte</h3>\n                        <p class=\"text-gray-600 leading-relaxed\">Quelques jours après votre <a href=\"https://haroboz.com/packs-shooting/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4\">séance photo</a>, vous recevez un lien confidentiel par email. Connectez-vous et découvrez l'ensemble de vos photos retouchées, en haute résolution, dans une interface claire et épurée. Le moment de la découverte est souvent riche en émotions&nbsp;: laissez-vous le temps de savourer.</p>\n                    </div>\n\n                    <div class=\"bg-white rounded-2xl shadow-sm border border-gray-100 p-8 text-center hover:shadow-lg transition-shadow duration-300\">\n                        <div class=\"w-14 h-14 bg-brand rounded-full flex items-center justify-center mx-auto mb-6\"><span class=\"text-white text-xl font-bold\">2</span></div>\n                        <h3 class=\"text-xl font-serif font-semibold text-brand mb-3\">Sélection</h3>\n                        <p class=\"text-gray-600 leading-relaxed\">Marquez vos photos favorites, comparez-les, créez vos sélections. Vous pouvez prendre plusieurs jours — ou plusieurs semaines — pour affiner votre choix. Luc reste disponible pour vous conseiller sur les images les plus adaptées à chaque format et support de tirage.</p>\n                    </div>\n\n                    <div class=\"bg-white rounded-2xl shadow-sm border border-gray-100 p-8 text-center hover:shadow-lg transition-shadow duration-300\">\n                        <div class=\"w-14 h-14 bg-brand rounded-full flex items-center justify-center mx-auto mb-6\"><span class=\"text-white text-xl font-bold\">3</span></div>\n                        <h3 class=\"text-xl font-serif font-semibold text-brand mb-3\">Commande</h3>\n                        <p class=\"text-gray-600 leading-relaxed\">Une fois votre sélection finalisée, commandez vos <a href=\"https://haroboz.com/boutique/tirages-art-edition-limitee/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4\">tirages d'art</a> directement depuis votre galerie. Choisissez le support — papier fine art, plexiglas, métal, toile, voile de soie ou verre — et le format qui sublimera chaque image. Livraison soignée à votre adresse.</p>\n                    </div>\n\n                </div>\n            </div>\n        </section>\n\n        <!-- SÉCURITÉ DÉTAILLÉE -->\n        <section class=\"py-12 lg:py-20 bg-white\">\n            <div class=\"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <h2 class=\"text-2xl md:text-3xl font-serif text-brand mt-12 mb-4\">Notre engagement sécurité</h2>\n\n                <h3 class=\"text-xl font-serif text-brand mt-8 mb-3\">Accès protégé</h3>\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Votre galerie est accessible via un lien unique et un mot de passe personnel. Aucune autre personne — pas m&ecirc;me d'autres clients Haroboz — ne peut accéder à votre espace. Vous pouvez modifier votre mot de passe à tout moment.</p>\n\n                <h3 class=\"text-xl font-serif text-brand mt-8 mb-3\">Hébergement sécurisé</h3>\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Vos images sont stockées sur des serveurs conformes aux normes RGPD, avec un chiffrement SSL/TLS. Les données sont sauvegardées quotidiennement pour éviter toute perte. Aucun tiers — employé, partenaire ou sous-traitant — n'a accès à vos photos sans votre autorisation.</p>\n\n                <h3 class=\"text-xl font-serif text-brand mt-8 mb-3\">Droit à l'effacement</h3>\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Conformément à la réglementation européenne, vous pouvez demander la suppression complète de vos images à tout moment. Il vous suffit de nous contacter par email ou téléphone, et vos photos seront définitivement effacées de nos serveurs sous 48 heures. Votre vie privée est notre priorité absolue.</p>\n\n                <h3 class=\"text-xl font-serif text-brand mt-8 mb-3\">Contr&ocirc;le de publication</h3>\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Si vous souhaitez que certaines de vos photos soient intégrées à notre <a href=\"https://haroboz.com/portfolio/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4\">portfolio</a> public, nous vous soumettrons un formulaire de consentement détaillé précisant exactement quelles images seront utilisées, dans quel contexte et pour quelle durée. Vous conservez un droit de retrait permanent.</p>\n            </div>\n        </section>\n\n        <!-- FAQ -->\n        <section class=\"py-12 lg:py-20 bg-gray-50\" itemscope itemtype=\"https://schema.org/FAQPage\">\n            <div class=\"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <h2 class=\"text-2xl md:text-3xl font-serif text-brand text-center mb-12\">Questions fréquentes</h2>\n\n                <div class=\"space-y-4\">\n\n                    <div class=\"faq-card bg-white rounded-xl shadow-sm border border-gray-100\" itemscope itemprop=\"mainEntity\" itemtype=\"https://schema.org/Question\">\n                        <button onclick=\"toggleFaq(this)\" class=\"w-full flex justify-between items-center p-6 text-left cursor-pointer\">\n                            <h3 class=\"text-base font-semibold text-brand pr-4\" itemprop=\"name\">Combien de temps ma galerie reste-t-elle accessible ?</h3>\n                            <i data-lucide=\"chevron-down\" class=\"faq-chevron w-5 h-5 text-brand flex-shrink-0 transition-transform duration-300\"></i>\n                        </button>\n                        <div class=\"faq-content\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https://schema.org/Answer\">\n                            <p class=\"px-6 pb-6 text-gray-600 leading-relaxed\" itemprop=\"text\">Votre galerie privée reste accessible pendant 6 mois après le dép&ocirc;t de vos photos. Ce délai vous laisse largement le temps de faire votre sélection et de commander vos tirages. Une extension est possible sur demande.</p>\n                        </div>\n                    </div>\n\n                    <div class=\"faq-card bg-white rounded-xl shadow-sm border border-gray-100\" itemscope itemprop=\"mainEntity\" itemtype=\"https://schema.org/Question\">\n                        <button onclick=\"toggleFaq(this)\" class=\"w-full flex justify-between items-center p-6 text-left cursor-pointer\">\n                            <h3 class=\"text-base font-semibold text-brand pr-4\" itemprop=\"name\">Puis-je partager ma galerie avec un proche ?</h3>\n                            <i data-lucide=\"chevron-down\" class=\"faq-chevron w-5 h-5 text-brand flex-shrink-0 transition-transform duration-300\"></i>\n                        </button>\n                        <div class=\"faq-content\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https://schema.org/Answer\">\n                            <p class=\"px-6 pb-6 text-gray-600 leading-relaxed\" itemprop=\"text\">Oui, vous pouvez partager le lien et le mot de passe de votre galerie avec la personne de votre choix. C'est vous qui décidez qui peut voir vos photos. Nous vous recommandons cependant de limiter le partage aux personnes de confiance.</p>\n                        </div>\n                    </div>\n\n                    <div class=\"faq-card bg-white rounded-xl shadow-sm border border-gray-100\" itemscope itemprop=\"mainEntity\" itemtype=\"https://schema.org/Question\">\n                        <button onclick=\"toggleFaq(this)\" class=\"w-full flex justify-between items-center p-6 text-left cursor-pointer\">\n                            <h3 class=\"text-base font-semibold text-brand pr-4\" itemprop=\"name\">Mes photos peuvent-elles &ecirc;tre téléchargées depuis la galerie ?</h3>\n                            <i data-lucide=\"chevron-down\" class=\"faq-chevron w-5 h-5 text-brand flex-shrink-0 transition-transform duration-300\"></i>\n                        </button>\n                        <div class=\"faq-content\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https://schema.org/Answer\">\n                            <p class=\"px-6 pb-6 text-gray-600 leading-relaxed\" itemprop=\"text\">Les photos affichées dans la galerie sont en haute résolution pour appréciation, mais protégées contre le téléchargement non autorisé. Les fichiers numériques en pleine résolution sont disponibles en option, selon les conditions de votre pack.</p>\n                        </div>\n                    </div>\n\n                </div>\n            </div>\n        </section>\n\n        \n        <!-- RÉALISATIONS — Mini galerie -->\n        <section class=\"py-12 md:py-16 bg-gray-50 border-y border-gray-100\">\n            <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <div class=\"text-center mb-8\">\n                    <span class=\"text-xs font-bold tracking-widest text-gray-400 uppercase block mb-2\">Réalisations</span>\n                    <h3 class=\"text-2xl md:text-3xl font-serif text-brand\">Un aperçu de nos créations</h3>\n                </div>\n                <div class=\"grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4\">\n                    <img src=\"https://haroboz.com/wp-content/uploads/2025/11/IMG_2919.png\" alt=\"Réalisation Haroboz\" class=\"aspect-[3/4] rounded-2xl object-cover w-full shadow-md hover:shadow-xl transition-shadow duration-300\" loading=\"lazy\">\n                    <img src=\"https://haroboz.com/wp-content/uploads/2026/04/Photoroom_20250615_213259-1-scaled.png\" alt=\"Réalisation Haroboz\" class=\"aspect-[3/4] rounded-2xl object-cover w-full shadow-md hover:shadow-xl transition-shadow duration-300\" loading=\"lazy\">\n                    <img src=\"https://haroboz.com/wp-content/uploads/2025/12/Photoroom_20250414_131832.png\" alt=\"Réalisation Haroboz\" class=\"aspect-[3/4] rounded-2xl object-cover w-full shadow-md hover:shadow-xl transition-shadow duration-300 hidden md:block\" loading=\"lazy\">\n                    <img src=\"https://haroboz.com/wp-content/uploads/2025/12/Photoroom_20251011_225926.png\" alt=\"Réalisation Haroboz\" class=\"aspect-[3/4] rounded-2xl object-cover w-full shadow-md hover:shadow-xl transition-shadow duration-300 hidden md:block\" loading=\"lazy\">\n                </div>\n                <div class=\"text-center mt-8\">\n                    <a href=\"https://haroboz.com/portfolio/\" class=\"inline-flex items-center text-brand font-medium hover:text-brand-light transition-colors group\">\n                        <span>Voir toutes les réalisations</span>\n                        <i data-lucide=\"arrow-right\" class=\"w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform\"></i>\n                    </a>\n                </div>\n            </div>\n        </section>\n\n<!-- CTA -->\n        <section class=\"bg-brand py-16 lg:py-20\">\n            <div class=\"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center\">\n                <h2 class=\"text-3xl md:text-4xl font-serif font-bold text-white mb-4\">Vivez l'expérience Haroboz en toute sérénité</h2>\n                <p class=\"text-white/70 text-lg mb-8\">Shooting privé et galerie sécurisée — Marseille, Toulon, Nice, Paris</p>\n                <button onclick=\"openPopup()\" class=\"bg-white text-brand px-8 py-4 rounded-full text-lg font-medium hover:bg-gray-100 shadow-lg inline-flex items-center cursor-pointer\"><i data-lucide=\"calendar\" class=\"w-5 h-5 mr-2\"></i> Réservez votre expérience</button>\n            </div>\n        </section>\n\n    </main>\n\n    <!-- FOOTER -->\n    <footer class=\"bg-brand text-white border-t border-brand-light/20\">\n        <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16\">\n            <div class=\"grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12\">\n                <div><div class=\"font-serif text-lg font-bold mb-4\">Nos Packs</div><ul class=\"space-y-2\"><li><a href=\"https://haroboz.com/packs-shooting/portrait-studio/\" class=\"text-sm text-gray-300 hover:text-white\">Portrait Studio</a></li><li><a href=\"https://haroboz.com/packs-shooting/shooting-exterieur/\" class=\"text-sm text-gray-300 hover:text-white\">Shooting Extérieur</a></li><li><a href=\"https://haroboz.com/packs-shooting/shooting-duo-couple/\" class=\"text-sm text-gray-300 hover:text-white\">Duo &amp; Couple</a></li><li><a href=\"https://haroboz.com/packs-shooting/photo-domicile/\" class=\"text-sm text-gray-300 hover:text-white\">Photo à Domicile</a></li></ul></div>\n                <div><div class=\"font-serif text-lg font-bold mb-4\">Li