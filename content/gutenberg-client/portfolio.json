er:bg-brand-50 hover:text-brand transition-colors\">Portraits</a>\n                            <a href=\"https://haroboz.com/portfolio/#nus\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Nus &amp; Attributs</a>\n                            <a href=\"https://haroboz.com/portfolio/galerie-couples/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Couples &amp; Duos</a>\n                            <a href=\"https://haroboz.com/portfolio/#creation\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Création d'art</a>\n                            <a href=\"https://haroboz.com/portfolio/#reportages\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Reportages</a>\n                        </div>\n                    </div>\n                </div>\n                    <a href=\"https://haroboz.com/a-propos/\" class=\"text-sm font-medium hover:text-brand-light transition-colors\">L'Univers</a>\n                </nav>\n                <div class=\"hidden lg:flex items-center\"><button onclick=\"openPopup()\" class=\"bg-brand text-white px-6 py-2.5 rounded-full text-sm font-medium hover:bg-brand-light shadow-md flex items-center cursor-pointer\"><i data-lucide=\"calendar\" class=\"w-4 h-4 mr-2\"></i> Prendre RDV gratuit</button></div>\n                <div class=\"flex items-center lg:hidden\"><button id=\"mobile-menu-btn\" class=\"text-brand hover:text-brand-light p-2\"><i data-lucide=\"menu\" class=\"w-7 h-7\"></i></button></div>\n            </div>\n        </div>\n    </header>\n\n    <!-- MOBILE MENU -->\n    <div id=\"mobile-menu\" class=\"fixed inset-y-0 right-0 w-full max-w-sm bg-white shadow-2xl z-50 transform translate-x-full overflow-y-auto\">\n        <div class=\"p-6\">\n            <div class=\"flex items-center justify-between mb-8\"><span class=\"font-serif text-2xl font-bold text-brand\">HAROBOZ</span><button id=\"close-menu-btn\" class=\"text-gray-500 hover:text-brand\"><i data-lucide=\"x\" class=\"w-7 h-7\"></i></button></div>\n            <nav class=\"space-y-2\">\n                <div class=\"border-b border-gray-100 py-3\"><button class=\"flex justify-between items-center w-full text-left font-medium text-brand mobile-accordion-btn\">Nos Séances <i data-lucide=\"chevron-down\" class=\"w-4 h-4\"></i></button><div class=\"hidden mt-3 space-y-3 pl-4 border-l-2 border-brand-50\"><a href=\"https://haroboz.com/packs-shooting/portrait-studio/\" class=\"block text-sm text-gray-600 hover:text-brand\">Portrait en Studio</a><a href=\"https://haroboz.com/packs-shooting/shooting-exterieur/\" class=\"block text-sm text-gray-600 hover:text-brand\">Shooting en Extérieur</a><a href=\"https://haroboz.com/packs-shooting/photo-domicile/\" class=\"block text-sm text-gray-600 hover:text-brand\">Photo à Domicile</a><a href=\"https://haroboz.com/packs-shooting/shooting-duo-couple/\" class=\"block text-sm text-gray-600 hover:text-brand\">Shooting Duo &amp; Couple</a></div></div>\n                <div class=\"border-b border-gray-100 py-3\"><button class=\"flex justify-between items-center w-full text-left font-medium text-brand mobile-accordion-btn\">Votre Objectif <i data-lucide=\"chevron-down\" class=\"w-4 h-4\"></i></button><div class=\"hidden mt-3 space-y-3 pl-4 border-l-2 border-brand-50\"><a href=\"https://haroboz.com/votre-experience/retrouver-confiance-corps/\" class=\"block text-sm text-gray-600 hover:text-brand\">Confiance &amp; Acceptation</a><a href=\"https://haroboz.com/votre-experience/book-modele-professionnel/\" class=\"block text-sm text-gray-600 hover:text-brand\">Book Professionnel</a><a href=\"https://haroboz.com/votre-experience/cadeau-couple-original/\" class=\"block text-sm text-gray-600 hover:text-brand\">Immortaliser son Couple</a><a href=\"https://haroboz.com/votre-experience/premier-shooting-nu/\" class=\"block text-sm text-gray-600 hover:text-brand\">Cadeau &amp; Célébration</a></div></div>\n                <div class=\"border-b border-gray-100 py-3\"><button class=\"flex justify-between items-center w-full text-left font-medium text-brand mobile-accordion-btn\">Où me trouver ? <i data-lucide=\"chevron-down\" class=\"w-4 h-4\"></i></button><div class=\"hidden mt-3 space-y-3 pl-4 border-l-2 border-brand-50\"><a href=\"https://haroboz.com/photographe/photographe-marseille/\" class=\"block text-sm text-gray-600 hover:text-brand\">Marseille</a><a href=\"https://haroboz.com/photographe/photographe-toulon/\" class=\"block text-sm text-gray-600 hover:text-brand\">Toulon</a><a href=\"https://haroboz.com/photographe/photographe-nice/\" class=\"block text-sm text-gray-600 hover:text-brand\">Nice</a><a href=\"https://haroboz.com/photographe/photographe-paris/\" class=\"block text-sm text-gray-600 hover:text-brand\">Paris</a></div></div>\n                <div class=\"border-b border-gray-100 py-3\"><button class=\"flex justify-between items-center w-full text-left font-medium text-brand mobile-accordion-btn\">L'Oeuvre <i data-lucide=\"chevron-down\" class=\"w-4 h-4\"></i></button><div class=\"hidden mt-3 space-y-3 pl-4 border-l-2 border-brand-50\"><a href=\"https://haroboz.com/portfolio/\" class=\"block text-sm text-gray-600 hover:text-brand\">Toutes les oeuvres</a><a href=\"https://haroboz.com/portfolio/galerie-portraits-hommes/\" class=\"block text-sm text-gray-600 hover:text-brand\">Portraits</a><a href=\"https://haroboz.com/portfolio/#nus\" class=\"block text-sm text-gray-600 hover:text-brand\">Nus &amp; Attributs</a><a href=\"https://haroboz.com/portfolio/galerie-couples/\" class=\"block text-sm text-gray-600 hover:text-brand\">Couples &amp; Duos</a><a href=\"https://haroboz.com/portfolio/#creation\" class=\"block text-sm text-gray-600 hover:text-brand\">Création d'art</a><a href=\"https://haroboz.com/portfolio/#reportages\" class=\"block text-sm text-gray-600 hover:text-brand\">Reportages</a></div></div>\n                <div class=\"border-b border-gray-100 py-3\"><a href=\"https://haroboz.com/a-propos/\" class=\"block font-medium text-brand\">L'Univers</a></div>\n            </nav>\n            <div class=\"mt-8\"><button onclick=\"openPopup(); toggleMobileMenu();\" class=\"w-full bg-brand text-white px-6 py-4 rounded-xl font-medium hover:bg-brand-light shadow-md flex justify-center items-center cursor-pointer\"><i data-lucide=\"calendar\" class=\"w-5 h-5 mr-2\"></i> Prendre RDV gratuit</button></div>\n        </div>\n    </div>\n    <div id=\"mobile-overlay\" class=\"fixed inset-0 bg-brand bg-opacity-50 z-40 hidden\"></div>\n\n    <main class=\"w-full\">\n        <!-- PAGE HERO -->\n        <section class=\"bg-brand pt-28 lg:pt-32 pb-12 lg:pb-16 relative overflow-hidden\">\n            <div class=\"absolute top-0 right-0 -translate-y-1/3 translate-x-1/4 w-96 h-96 bg-brand-light rounded-full opacity-30 blur-3xl\"></div>\n            <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10\">\n                <nav class=\"text-sm text-white/60 mb-6\" aria-label=\"Fil d'Ariane\">\n                    <a href=\"https://haroboz.com/\" class=\"hover:text-white\">Accueil</a> <span class=\"mx-2\">/</span> <span class=\"text-white/90\">Portfolio</span>\n                </nav>\n                <p class=\"text-white/70 text-sm uppercase tracking-widest mb-3\">L'univers visuel de Haroboz</p>\n                <h1 class=\"text-3xl md:text-4xl lg:text-5xl font-serif font-bold text-white mb-4\">Portfolio</h1>\n                <p class=\"text-white/70 text-base md:text-lg max-w-2xl\">Plongez dans l'univers photographique de Luc Desbois. Chaque image raconte une histoire de confiance, de lâcher-prise et de beauté masculine révélée dans l'intimité d'un shooting privé.</p>\n            </div>\n        </section>\n\n        <!-- RÉALISATIONS — Galerie immédiate avec toutes les catégories -->\n        <section class=\"py-10 lg:py-14 bg-gray-50\">\n            <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <h2 class=\"text-2xl md:text-3xl font-serif text-brand mb-6 text-center\">Réalisations</h2>\n                <div class=\"grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4\">\n                    <!-- Portraits -->\n                    <div class=\"aspect-square rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300\"><img src=\"https://haroboz.com/wp-content/uploads/2025/12/Photoroom_20251014_223830.png\" alt=\"Portrait masculin extérieur\" class=\"w-full h-full object-cover object-top hover:scale-105 transition-transform duration-500\" loading=\"lazy\"></div>\n                    <div class=\"aspect-square rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300\"><img src=\"https://haroboz.com/wp-content/uploads/2026/02/Photoroom_20260215_194643.png\" alt=\"Portrait masculin mur\" class=\"w-full h-full object-cover object-top hover:scale-105 transition-transform duration-500\" loading=\"lazy\"></div>\n                    <!-- Nus -->\n                    <div id=\"nus\" class=\"aspect-square rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300\"><img src=\"https://haroboz.com/wp-content/uploads/2026/03/Photoroom_20260306_172002.png\" alt=\"Nu artistique N&amp;B studio\" class=\"w-full h-full object-cover object-top hover:scale-105 transition-transform duration-500\" loading=\"lazy\"></div>\n                    <div class=\"aspect-square rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300\"><img src=\"https://haroboz.com/wp-content/uploads/2026/04/Photoroom_20250330_154516-1-scaled.png\" alt=\"Portrait clair-obscur studio\" class=\"w-full h-full object-cover object-top hover:scale-105 transition-transform duration-500\" loading=\"lazy\"></div>\n                    <!-- Couples -->\n                    <div class=\"aspect-square rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300\"><img src=\"https://haroboz.com/wp-content/uploads/2026/04/IMG_0267-1-scaled.png\" alt=\"Duo masculin extérieur mer\" class=\"w-full h-full object-cover object-top hover:scale-105 transition-transform duration-500\" loading=\"lazy\"></div>\n                    <!-- Création d'art -->\n                    <div id=\"creation\" class=\"aspect-square rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300\"><img src=\"https://haroboz.com/wp-content/uploads/2026/04/1FA73D10-9F52-4260-9BA2-22029F3661A0.png\" alt=\"Double exposition portrait mer\" class=\"w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500\" loading=\"lazy\"></div>\n                    <div class=\"aspect-square rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300\"><img src=\"https://haroboz.com/wp-content/uploads/2026/04/Photoroom_20260106_205955.png\" alt=\"Portrait sculpture antique\" class=\"w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500\" loading=\"lazy\"></div>\n                    <div class=\"aspect-square rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300\"><img src=\"https://haroboz.com/wp-content/uploads/2026/02/Photoroom_20260219_085201.png\" alt=\"Double exposition arbre lac\" class=\"w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500\" loading=\"lazy\"></div>\n                    <!-- Reportages -->\n                    <div id=\"reportages\" class=\"aspect-square rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300\"><img src=\"https://haroboz.com/wp-content/uploads/2026/04/Photoroom_20250615_213259-1-scaled.png\" alt=\"Portrait rochers extérieur\" class=\"w-full h-full object-cover object-top hover:scale-105 transition-transform duration-500\" loading=\"lazy\"></div>\n                    <div class=\"aspect-square rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300\"><img src=\"https://haroboz.com/wp-content/uploads/2025/12/Photoroom_20251215_133315.png\" alt=\"Portrait profil arc-en-ciel\" class=\"w-full h-full object-cover object-top hover:scale-105 transition-transform duration-500\" loading=\"lazy\"></div>\n                    <!-- Plus de portraits -->\n                    <div class=\"aspect-square rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300\"><img src=\"https://haroboz.com/wp-content/uploads/2026/04/Photoroom_20260125_171037-1-scaled.png\" alt=\"Portrait gros plan yeux verts\" class=\"w-full h-full object-cover object-top hover:scale-105 transition-transform duration-500\" loading=\"lazy\"></div>\n                    <div class=\"aspect-square rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300\"><img src=\"https://haroboz.com/wp-content/uploads/2026/03/Photoroom_20260213_102220.png\" alt=\"Portrait verre brisé création\" class=\"w-full h-full object-cover object-center hover:scale-105 transition-transform duration-500\" loading=\"lazy\"></div>\n                </div>\n            </div>\n        </section>\n\n        <!-- SEO CONTENT: Introduction -->\n        <section class=\"py-12 lg:py-20 bg-white\">\n            <div class=\"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <h2 class=\"text-2xl md:text-3xl font-serif text-brand mt-0 mb-4\">Une galerie d'art au masculin</h2>\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Le portfolio Haroboz est bien plus qu'une simple collection de photographies. C'est le reflet d'une démarche artistique portée par la lumière méditerranéenne et nourrie par des années de pratique du <strong>nu masculin artistique</strong>. Chaque cliché présenté ici est le fruit d'une rencontre unique entre le photographe et son modèle, dans un cadre où la bienveillance et la discrétion ne sont jamais négociables.</p>\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Luc Desbois, le fondateur de Haroboz, croit fermement que la beauté masculine mérite d'être célébrée avec la même exigence artistique que celle accordée traditionnellement au corps féminin. Son travail s'inscrit dans une tradition photographique héritée des grands maîtres du portrait, tout en revendiquant une modernité et une sensibilité propres à notre époque. Le résultat&nbsp;: des images qui allient puissance et vulnérabilité, ombre et lumière, force brute et douceur assumée.</p>\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Que vous soyez curieux de découvrir notre approche avant de <a href=\"https://haroboz.com/packs-shooting/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4 transition-colors\">réserver un pack shooting</a>, ou simplement sensible à la photographie d'art, ce portfolio vous invite à explorer trois univers complémentaires. Les <a href=\"https://haroboz.com/portfolio/galerie-portraits-hommes/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4 transition-colors\">portraits d'hommes</a> révèlent la singularité de chaque modèle, la <a href=\"https://haroboz.com/portfolio/galerie-couples/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4 transition-colors\">galerie couples</a> capture la complicité intime à deux, et nos <a href=\"https://haroboz.com/portfolio/temoignages-clients/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4 transition-colors\">témoignages clients</a> vous offrent un regard authentique sur l'<a href=\"https://haroboz.com/votre-experience/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4 transition-colors\">expérience Haroboz</a>.</p>\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Toutes les photographies présentées sont réalisées avec le consentement explicite des modèles. La confidentialité est au coeur de notre pratique&nbsp;: aucune image n'est publiée sans accord préalable, et chaque client dispose d'un contrôle total sur l'utilisation de ses clichés via sa <a href=\"https://haroboz.com/boutique/galerie-privee-client/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4 transition-colors\">galerie privée sécurisée</a>.</p>\n            </div>\n        </section>\n\n        <!-- INSTAGRAM -->\n        <section class=\"py-12 lg:py-16 bg-gray-50\">\n            <div class=\"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center\">\n                <h2 class=\"text-2xl md:text-3xl font-serif text-brand mb-4\">Suivez l'univers Haroboz sur Instagram</h2>\n                <p class=\"text-gray-600 leading-relaxed mb-8\">Retrouvez nos dernières publications, les coulisses de nos shootings et l'actualité de notre studio marseillais sur le compte <strong>@hbozart</strong>.</p>\n                <div class=\"grid grid-cols-2 md:grid-cols-4 gap-3 mb-8\">\n                    <div class=\"aspect-square rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow\"><img src=\"https://haroboz.com/wp-content/uploads/2026/04/Photoroom_20250506_212353-1-scaled.png\" alt=\"Portrait homme studio\" class=\"w-full h-full object-cover hover:scale-105 transition-transform duration-500\" loading=\"lazy\"></div>\n                    <div class=\"aspect-square rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow\"><img src=\"https://haroboz.com/wp-content/uploads/2026/04/Photoroom_20250604_205115-1-scaled.png\" alt=\"Couple shooting artistique\" class=\"w-full h-full object-cover hover:scale-105 transition-transform duration-500\" loading=\"lazy\"></div>\n                    <div class=\"aspect-square rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow hidden md:block\"><img src=\"https://haroboz.com/wp-content/uploads/2026/03/Photoroom_20260128_103932.png\" alt=\"Portrait lumière naturelle\" class=\"w-full h-full object-cover hover:scale-105 transition-transform duration-500\" loading=\"lazy\"></div>\n                    <div class=\"aspect-square rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow hidden md:block\"><img src=\"https://haroboz.com/wp-content/uploads/2026/03/Photoroom_20251015_135313.png\" alt=\"Duo complicité\" class=\"w-full h-full object-cover hover:scale-105 transition-transform duration-500\" loading=\"lazy\"></div>\n                </div>\n                <a href=\"https://www.instagram.com/hbozart/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"inline-flex items-center border-2 border-brand text-brand px-6 py-3 rounded-full font-medium hover:bg-brand hover:text-white transition-colors\"><i data-lucide=\"instagram\" class=\"w-5 h-5 mr-2\"></i> Suivre @hbozart sur Instagram</a>\n            </div>\n        </section>\n\n        <!-- GALLERY HUB CARDS -->\n        <section class=\"py-12 lg:py-20 bg-white\">\n            <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <h2 class=\"text-2xl md:text-3xl font-serif text-brand mb-10 text-center\">Explorez nos galeries</h2>\n                <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\">\n\n                    <a href=\"https://haroboz.com/portfolio/galerie-portraits-hommes/\" class=\"group bg-brand-50 rounded-2xl p-8 border border-brand/10 hover:shadow-xl transition-all duration-300 hover:-translate-y-1\">\n                        <div class=\"w-14 h-14 bg-brand/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-brand/20 transition-colors\">\n                            <i data-lucide=\"user\" class=\"w-7 h-7 text-brand\"></i>\n                        </div>\n                        <h3 class=\"text-xl font-serif text-brand mb-3\">Galerie Portraits Hommes</h3>\n                        <p class=\"text-gray-600 leading-relaxed mb-4\">Découvrez notre collection de portraits masculins réalisés en studio et en extérieur dans le sud de la France. Chaque image capture l'essence et la singularité de son modèle, entre clair-obscur et lumière naturelle méditerranéenne.</p>\n                        <span class=\"text-brand font-medium group-hover:text-brand-light transition-colors inline-flex items-center\">Voir la galerie <i data-lucide=\"arrow-right\" class=\"w-4 h-4 ml-2\"></i></span>\n                    </a>\n\n                    <a href=\"https://haroboz.com/portfolio/galerie-couples/\" class=\"group bg-brand-50 rounded-2xl p-8 border border-brand/10 hover:shadow-xl transition-all duration-300 hover:-translate-y-1\">\n                        <div class=\"w-14 h-14 bg-brand/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-brand/20 transition-colors\">\n                            <i data-lucide=\"heart\" class=\"w-7 h-7 text-brand\"></i>\n                        </div>\n                        <h3 class=\"text-xl font-serif text-brand mb-3\">Galerie Couples</h3>\n                        <p class=\"text-gray-600 leading-relaxed mb-4\">L'intimité partagée sublimée par l'objectif. Nos shootings duo capturent la complicité, la tendresse et la sensualité des couples dans un cadre confidentiel et respectueux.</p>\n                        <span class=\"text-brand font-medium group-hover:text-brand-light transition-colors inline-flex items-center\">Voir la galerie <i data-lucide=\"arrow-right\" class=\"w-4 h-4 ml-2\"></i></span>\n                    </a>\n\n                    <a href=\"https://haroboz.com/portfolio/temoignages-clients/\" class=\"group bg-brand-50 rounded-2xl p-8 border border-brand/10 hover:shadow-xl transition-all duration-300 hover:-translate-y-1\">\n                        <div class=\"w-14 h-14 bg-brand/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-brand/20 transition-colors\">\n                            <i data-lucide=\"message-circle\" class=\"w-7 h-7 text-brand\"></i>\n                        </div>\n                        <h3 class=\"text-xl font-serif text-brand mb-3\">Témoignages Clients</h3>\n                        <p class=\"text-gray-600 leading-relaxed mb-4\">Ils ont vécu l'expérience Haroboz et partagent leur ressenti. Des mots sincères qui témoignent de la bienveillance, du professionnalisme et de l'impact transformateur d'une séance avec Luc Desbois.</p>\n                        <span class=\"text-brand font-medium group-hover:text-brand-light transition-colors inline-flex items-center\">Lire les témoignages <i data-lucide=\"arrow-right\" class=\"w-4 h-4 ml-2\"></i></span>\n                    </a>\n\n                </div>\n            </div>\n        </section>\n\n        <!-- SEO CONTENT: Approche -->\n        <section class=\"py-12 lg:py-20 bg-gray-50\">\n            <div class=\"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <h2 class=\"text-2xl md:text-3xl font-serif text-brand mt-0 mb-4\">Notre approche photographique</h2>\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Le travail de Haroboz repose sur trois piliers fondamentaux&nbsp;: l'<strong>écoute</strong>, la <strong>direction artistique</strong> et le <strong>tirage d'art</strong>. Avant chaque séance, un échange approfondi permet de définir ensemble le ton, l'ambiance et les limites de la prise de vue. Cette phase préparatoire est essentielle pour garantir un résultat qui vous ressemble véritablement.</p>\n                <p class=\"text-gray-600 leading-relaxed mb-4\">En studio, Luc travaille avec un éclairage soigneusement calibré qui sculpte les volumes et magnifie les textures de la peau. En extérieur, la lumière naturelle méditerranéenne offre une palette incomparable, des dorures du coucher de soleil aux reflets argentés de la Méditerranée. Dans les deux cas, la direction artistique est pensée pour vous mettre en valeur tout en respectant votre zone de confort.</p>\n                <p class=\"text-gray-600 leading-relaxed mb-4\">L'expérience ne s'arrête pas au déclenchement. Chaque tirage est réalisé sur des supports d'exception &mdash; papier fine art, plexiglas mat, toile &mdash; pour transformer votre portrait en une véritable oeuvre d'art. Découvrez les différentes options dans notre <a href=\"https://haroboz.com/boutique/tirages-art-edition-limitee/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4 transition-colors\">boutique tirages d'art</a>.</p>\n            </div>\n        </section>\n\n        <!-- CTA -->\n        <section class=\"bg-brand py-16 lg:py-20 relative overflow-hidden\">\n            <div class=\"absolute top-0 right-0 -translate-y-1/2 translate-x-1/3 w-96 h-96 bg-brand-light rounded-full opacity-50 blur-3xl\"></div>\n            <div class=\"absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/3 w-96 h-96 bg-[#3a00a8] rounded-full opacity-50 blur-3xl\"></div>\n            <div class=\"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10\">\n                <h2 class=\"text-3xl md:text-4xl font-serif text-white mb-4\">Envie de figurer dans notre portfolio&nbsp;?</h2>\n                <p class=\"text-brand-50 text-base md:text-lg mb-8 max-w-2xl mx-auto\">Réservez votre shooting privé — Marseille, Toulon, Nice, Paris</p>\n                <button onclick=\"openPopup()\" class=\"bg-white text-brand px-8 py-4 rounded-full text-lg font-bold hover:bg-gray-100 shadow-xl flex items-center justify-center cursor-pointer mx-auto\"><i data-lucide=\"calendar\" class=\"w-5 h-5 mr-2\"></i> Être rappelé sous 24h</button>\n            </div>\n        </section>\n    </main>\n\n    <!-- FOOTER -->\n    <footer class=\"bg-brand text-white border-t border-brand-light/20\">\n        <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16\">\n            <div class=\"grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12\">\n                <div><div class=\"font-serif text-lg font-bold mb-4\">Nos Packs</div><ul class=\"space-y-2\"><li><a href=\"https://haroboz.com/packs-shooting/portrait-studio/\" class=\"text-sm text-gray-300 hover:text-white\">Portrait Studio</a></li><li><a href=\"https://haroboz.com/packs-shooting/shooting-exterieur/\" class=\"text-sm text-gray-300 hover:text-white\">Shooting Extérieur</a></li><li><a href=\"https://haroboz.com/packs-shooting/shooting-duo-couple/\" class=\"text-sm text-gray-300 hover:text-white\">Duo &amp; Couple</a></li><li><a href=\"https://haroboz.com/packs-shooting/photo-domicile/\" class=\"text-sm text-gray-300 hover:text-white\">Photo à Domicile</a></li></ul></div>\n                <div><div class=\"font-serif text-lg font-bold mb-4\">Lieux</div><ul class=\"space-y-2\"><li><a href=\"https://haroboz.com/photographe/photographe-marseille/\" class=\"text-sm text-gray-300 hover:text-white\">Marseille</a></li><li><a href=\"https://haroboz.com/photographe/photographe-toulon/\" class=\"text-sm text-gray-300 hover:text-white\">Toulon</a></li><li><a href=\"https://haroboz.com/photographe/photographe-nice/\" class=\"text-sm text-gray-300 hover:text-white\">Nice</a></li><li><a href=\"https://haroboz.com/photographe/photographe-paris/\" class=\"text-sm text-gray-300 hover:text-white\">Paris</a></li></ul></div>\n                <div><div class=\"font-serif text-lg font-bold mb-4\">Expérience</div><ul class=\"space-y-2\"><li><a href=\"https://haroboz.com/votre-experience/premier-shooting-nu/\" class=\"text-sm text-gray-300 hover:text-white\">Premier Shooting</a></li><li><a href=\"https://haroboz.com/votre-experience/retrouver-confiance-corps/\" class=\"text-sm text-gray-300 hover:text-white\">Retrouver Confiance</a></li><li><a href=\"https://haroboz.com/votre-experience/book-modele-professionnel/\" class=\"text-sm text-gray-300 hover:text-white\">Book Modèle Pro</a></li><li><a href=\"https://haroboz.com/portfolio/temoignages-clients/\" class=\"text-sm text-gray-300 hover:text-white\">Témoignages</a></li></ul></div>\n                <div><div class=\"font-serif text-lg font-bold mb-4\">Haroboz</div><ul class=\"space-y-2\"><li><a href=\"https://haroboz.com/a-propos/\" class=\"text-sm text-gray-300 hover:text-white\">À Propos</a></li><li><a href=\"https://haroboz.com/portfolio/\" class=\"text-sm text-gray-300 hover:text-white\">Réalisations</a></li><li><a href=\"https://haroboz.com/contact/\" class=\"text-sm text-gray-300 hover:text-white\">Contact</a></li><li><a href=\"https://haroboz.com/mentions-legales/\" class=\"text-sm text-gray-300 hover:text-white\">Mentions légales</a></li></ul></div>\n            </div>\n            <div class=\"border-t border-white/10 mt-10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4\">\n                <p class=\"text-sm text-gray-400\">&copy; 2026 Haroboz — Luc Desbois | Photographe Art Masculin | Marseille, Toulon, Nice, Paris</p>\n                <div class=\"flex items-center gap-4\"><a href=\"https://www.instagram.com/hbozart/\" target=\"_blank\" class=\"text-gray-400 hover:text-white\"><i data-lucide=\"instagram\" class=\"w-5 h-5\"></i></a><a href=\"https://haroboz.com/mentions-legales/\" class=\"text-sm text-gray-400 hover:text-white\">Mentions légales</a></div>\n            </div>\n        </div>\n    </footer>\n\n    <!-- POPUP -->\n    <div id=\"booking-popup\" class=\"fixed inset-0 z-[100] flex items-center justify-center p-4 popup-hidden\">\n        <div class=\"absolute inset-0 bg-brand/60 backdrop-blur-sm\" onclick=\"closePopup()\"></div>\n        <div id=\"popup-content\" class=\"relative bg-white rounded-2xl shadow-2xl max-w-lg w-full max-h-[90vh] overflow-y-auto\">\n            <div class=\"bg-brand rounded-t-2xl p-6 text-center relative\"><button onclick=\"closePopup()\" class=\"absolute top-4 right-4 text-white/70 hover:text-white cursor-pointer\"><i data-lucide=\"x\" class=\"w-6 h-6\"></i></button><h3 class=\"text-xl font-serif text-white font-bold\">Réservez votre séance</h3><p class=\"text-white/70 text-sm mt-1\">Réponse confidentielle sous 24h</p></div>\n            <form id=\"booking-form\" class=\"p-6\" onsubmit=\"handleSubmit(event)\">\n                <div class=\"space-y-4\">\n                    <div><label class=\"block text-sm font-medium text-brand mb-1\">Prénom *</label><input type=\"text\" required placeholder=\"Votre prénom\" name=\"prenom\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-brand placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand\"></div>\n                    <div><label class=\"block text-sm font-medium text-brand mb-1\">Email *</label><input type=\"email\" required placeholder=\"votre@email.com\" name=\"email\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-brand placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand\"></div>\n                    <div><label class=\"block text-sm font-medium text-brand mb-1\">Téléphone *</label><input type=\"tel\" required placeholder=\"06 XX XX XX XX\" name=\"telephone\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-brand placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand\"></div>\n                    <div><label class=\"block text-sm font-medium text-brand mb-1\">Message</label><textarea rows=\"3\" placeholder=\"Parlez-moi de votre projet...\" name=\"message\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-brand placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand resize-none\"></textarea></div>\n                </div>\n                <button type=\"submit\" class=\"w-full mt-6 bg-brand text-white py-4 rounded-xl font-bold hover:bg-brand-light shadow-lg flex items-center justify-center cursor-pointer\"><i data-lucide=\"send\" class=\"w-5 h-5 mr-2\"></i> Envoyer ma demande</button>\n                <p class=\"text-center text-xs text-gray-400 mt-3\"><i data-lucide=\"lock\" class=\"w-3 h-3 inline\"></i> 100% confidentiel</p>\n            </form>\n            <div id=\"popup-success\" class=\"hidden p-8 text-center\"><div class=\"w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4\"><i data-lucide=\"check-circle\" class=\"w-8 h-8 text-green-600\"></i></div><h3 class=\"text-2xl font-serif text-brand mb-2\">Demande envoyée !</h3><p class=\"text-gray-600 mb-6\">Je vous recontacte sous 24h.</p><button onclick=\"closePopup()\" class=\"bg-brand text-white px-6 py-3 rounded-xl font-medium hover:bg-brand-light cursor-pointer\">Fermer</button></div>\n        </div>\n    </div>\n\n    <div id=\"floating-cta\" class=\"fixed bottom-6 right-6 z-50 opacity-0 translate-y-4 transition-all duration-300 pointer-events-none\">\n        <button onclick=\"openPopup()\" class=\"relative bg-brand text-white w-14 h-14 md:w-auto md:h-auto md:px-6 md:py-3 rounded-full shadow-2xl hover:bg-brand-light flex items-center justify-center cursor-pointer pulse-ring text-brand\"><i data-lucide=\"calendar\" class=\"w-6 h-6 md:w-5 md:h-5 md:mr-2\"></i><span class=\"hidden md:inline font-medium\">Prendre RDV</span></button>\n    </div>\n</div>",
