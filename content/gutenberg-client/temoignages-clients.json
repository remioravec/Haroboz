  "content_raw": "<style>\n\n        .mega-menu-content { visibility: hidden; opacity: 0; transform: translateY(10px); transition: all 0.3s ease-in-out; }\n        .mega-menu-item:hover .mega-menu-content { visibility: visible; opacity: 1; transform: translateY(0); pointer-events: auto; }\n        #mobile-menu { transition: transform 0.3s ease-in-out; }\n        .menu-open { transform: translateX(0) !important; }\n        #booking-popup { transition: opacity 0.3s ease, visibility 0.3s ease; }\n        #booking-popup.popup-hidden { opacity: 0; visibility: hidden; }\n        #booking-popup.popup-visible { opacity: 1; visibility: visible; }\n        #popup-content { transition: transform 0.3s ease, opacity 0.3s ease; }\n        #booking-popup.popup-hidden #popup-content { transform: scale(0.95) translateY(20px); opacity: 0; }\n        #booking-popup.popup-visible #popup-content { transform: scale(1) translateY(0); opacity: 1; }\n        @keyframes pulse-ring { 0% { transform: scale(1); opacity: 1; } 80%, 100% { transform: scale(1.4); opacity: 0; } }\n        .pulse-ring::before { content: ''; position: absolute; inset: -4px; border-radius: 9999px; border: 2px solid currentColor; animation: pulse-ring 2s ease-out infinite; }\n        .faq-content { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }\n    \n</style>\n<div class=\"haroboz-page\">\n<!-- HEADER -->\n    <header id=\"main-header\" class=\"fixed top-0 left-0 w-full z-50 bg-white shadow-sm transition-all duration-300\">\n        <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n            <div class=\"flex justify-between items-center h-20\">\n                <div class=\"flex-shrink-0\"><a href=\"https://haroboz.com/\" class=\"font-serif text-2xl lg:text-3xl font-bold tracking-tight text-brand\">HAROBOZ</a></div>\n                <nav class=\"hidden lg:flex space-x-8 h-full items-center\">\n                    <div class=\"mega-menu-item relative h-full flex items-center\"><button class=\"flex items-center text-sm font-medium hover:text-brand-light transition-colors py-8\">Nos Séances <i data-lucide=\"chevron-down\" class=\"ml-1 w-4 h-4\"></i></button><div class=\"mega-menu-content absolute top-20 left-1/2 -translate-x-1/2 w-64 bg-white shadow-xl rounded-b-lg border-t border-gray-100\"><div class=\"py-2\"><a href=\"https://haroboz.com/packs-shooting/portrait-studio/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand\">Portrait en Studio</a><a href=\"https://haroboz.com/packs-shooting/shooting-exterieur/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand\">Shooting en Extérieur</a><a href=\"https://haroboz.com/packs-shooting/photo-domicile/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand\">Photo à Domicile</a><a href=\"https://haroboz.com/packs-shooting/shooting-duo-couple/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand\">Shooting Duo &amp; Couple</a></div></div></div>\n                    <div class=\"mega-menu-item relative h-full flex items-center\"><button class=\"flex items-center text-sm font-medium hover:text-brand-light transition-colors py-8\">Votre Objectif <i data-lucide=\"chevron-down\" class=\"ml-1 w-4 h-4\"></i></button><div class=\"mega-menu-content absolute top-20 left-1/2 -translate-x-1/2 w-80 bg-white shadow-xl rounded-b-lg border-t border-gray-100\"><div class=\"py-2\"><a href=\"https://haroboz.com/votre-experience/retrouver-confiance-corps/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand\">Confiance &amp; Acceptation</a><a href=\"https://haroboz.com/votre-experience/book-modele-professionnel/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand\">Book Professionnel</a><a href=\"https://haroboz.com/votre-experience/cadeau-couple-original/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand\">Immortaliser son Couple</a><a href=\"https://haroboz.com/votre-experience/premier-shooting-nu/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand\">Cadeau &amp; Célébration</a></div></div></div>\n                    <div class=\"mega-menu-item relative h-full flex items-center\"><button class=\"flex items-center text-sm font-medium hover:text-brand-light transition-colors py-8\">Où me trouver ? <i data-lucide=\"chevron-down\" class=\"ml-1 w-4 h-4\"></i></button><div class=\"mega-menu-content absolute top-20 left-1/2 -translate-x-1/2 w-48 bg-white shadow-xl rounded-b-lg border-t border-gray-100\"><div class=\"py-2\"><a href=\"https://haroboz.com/photographe/photographe-marseille/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Marseille</a><a href=\"https://haroboz.com/photographe/photographe-toulon/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Toulon</a><a href=\"https://haroboz.com/photographe/photographe-nice/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand\">Nice</a><a href=\"https://haroboz.com/photographe/photographe-paris/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Paris</a></div></div></div>\n                    <div class=\"mega-menu-item relative h-full flex items-center\">\n                    <button class=\"flex items-center text-sm font-medium hover:text-brand-light transition-colors py-8\">L'Oeuvre <i data-lucide=\"chevron-down\" class=\"ml-1 w-4 h-4\"></i></button>\n                    <div class=\"mega-menu-content absolute top-20 left-1/2 -translate-x-1/2 w-64 bg-white shadow-xl rounded-b-lg border-t border-gray-100 overflow-hidden\">\n                        <div class=\"py-2\">\n                            <a href=\"https://haroboz.com/portfolio/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Toutes les oeuvres</a>\n                            <a href=\"https://haroboz.com/portfolio/galerie-portraits-hommes/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Portraits</a>\n                            <a href=\"https://haroboz.com/portfolio/#nus\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Nus &amp; Attributs</a>\n                            <a href=\"https://haroboz.com/portfolio/galerie-couples/\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Couples &amp; Duos</a>\n                            <a href=\"https://haroboz.com/portfolio/#creation\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Création d'art</a>\n                            <a href=\"https://haroboz.com/portfolio/#reportages\" class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\">Reportages</a>\n                        </div>\n                    </div>\n                </div>\n                    <a href=\"https://haroboz.com/a-propos/\" class=\"text-sm font-medium hover:text-brand-light transition-colors\">L'Univers</a>\n                </nav>\n                <div class=\"hidden lg:flex items-center\"><button onclick=\"openPopup()\" class=\"bg-brand text-white px-6 py-2.5 rounded-full text-sm font-medium hover:bg-brand-light shadow-md flex items-center cursor-pointer\"><i data-lucide=\"calendar\" class=\"w-4 h-4 mr-2\"></i> Prendre RDV gratuit</button></div>\n                <div class=\"flex items-center lg:hidden\"><button id=\"mobile-menu-btn\" class=\"text-brand hover:text-brand-light p-2\"><i data-lucide=\"menu\" class=\"w-7 h-7\"></i></button></div>\n            </div>\n        </div>\n    </header>\n\n    <!-- MOBILE MENU -->\n    <div id=\"mobile-menu\" class=\"fixed inset-y-0 right-0 w-full max-w-sm bg-white shadow-2xl z-50 transform translate-x-full overflow-y-auto\">\n        <div class=\"p-6\">\n            <div class=\"flex items-center justify-between mb-8\"><span class=\"font-serif text-2xl font-bold text-brand\">HAROBOZ</span><button id=\"close-menu-btn\" class=\"text-gray-500 hover:text-brand\"><i data-lucide=\"x\" class=\"w-7 h-7\"></i></button></div>\n            <nav class=\"space-y-2\">\n                <div class=\"border-b border-gray-100 py-3\"><button class=\"flex justify-between items-center w-full text-left font-medium text-brand mobile-accordion-btn\">Nos Séances <i data-lucide=\"chevron-down\" class=\"w-4 h-4\"></i></button><div class=\"hidden mt-3 space-y-3 pl-4 border-l-2 border-brand-50\"><a href=\"https://haroboz.com/packs-shooting/portrait-studio/\" class=\"block text-sm text-gray-600 hover:text-brand\">Portrait en Studio</a><a href=\"https://haroboz.com/packs-shooting/shooting-exterieur/\" class=\"block text-sm text-gray-600 hover:text-brand\">Shooting en Extérieur</a><a href=\"https://haroboz.com/packs-shooting/photo-domicile/\" class=\"block text-sm text-gray-600 hover:text-brand\">Photo à Domicile</a><a href=\"https://haroboz.com/packs-shooting/shooting-duo-couple/\" class=\"block text-sm text-gray-600 hover:text-brand\">Shooting Duo &amp; Couple</a></div></div>\n                <div class=\"border-b border-gray-100 py-3\"><button class=\"flex justify-between items-center w-full text-left font-medium text-brand mobile-accordion-btn\">Votre Objectif <i data-lucide=\"chevron-down\" class=\"w-4 h-4\"></i></button><div class=\"hidden mt-3 space-y-3 pl-4 border-l-2 border-brand-50\"><a href=\"https://haroboz.com/votre-experience/retrouver-confiance-corps/\" class=\"block text-sm text-gray-600 hover:text-brand\">Confiance &amp; Acceptation</a><a href=\"https://haroboz.com/votre-experience/book-modele-professionnel/\" class=\"block text-sm text-gray-600 hover:text-brand\">Book Professionnel</a><a href=\"https://haroboz.com/votre-experience/cadeau-couple-original/\" class=\"block text-sm text-gray-600 hover:text-brand\">Immortaliser son Couple</a><a href=\"https://haroboz.com/votre-experience/premier-shooting-nu/\" class=\"block text-sm text-gray-600 hover:text-brand\">Cadeau &amp; Célébration</a></div></div>\n                <div class=\"border-b border-gray-100 py-3\"><button class=\"flex justify-between items-center w-full text-left font-medium text-brand mobile-accordion-btn\">Où me trouver ? <i data-lucide=\"chevron-down\" class=\"w-4 h-4\"></i></button><div class=\"hidden mt-3 space-y-3 pl-4 border-l-2 border-brand-50\"><a href=\"https://haroboz.com/photographe/photographe-marseille/\" class=\"block text-sm text-gray-600 hover:text-brand\">Marseille</a><a href=\"https://haroboz.com/photographe/photographe-toulon/\" class=\"block text-sm text-gray-600 hover:text-brand\">Toulon</a><a href=\"https://haroboz.com/photographe/photographe-nice/\" class=\"block text-sm text-gray-600 hover:text-brand\">Nice</a><a href=\"https://haroboz.com/photographe/photographe-paris/\" class=\"block text-sm text-gray-600 hover:text-brand\">Paris</a></div></div>\n                <div class=\"border-b border-gray-100 py-3\"><button class=\"flex justify-between items-center w-full text-left font-medium text-brand mobile-accordion-btn\">L'Oeuvre <i data-lucide=\"chevron-down\" class=\"w-4 h-4\"></i></button><div class=\"hidden mt-3 space-y-3 pl-4 border-l-2 border-brand-50\"><a href=\"https://haroboz.com/portfolio/\" class=\"block text-sm text-gray-600 hover:text-brand\">Toutes les oeuvres</a><a href=\"https://haroboz.com/portfolio/galerie-portraits-hommes/\" class=\"block text-sm text-gray-600 hover:text-brand\">Portraits</a><a href=\"https://haroboz.com/portfolio/#nus\" class=\"block text-sm text-gray-600 hover:text-brand\">Nus &amp; Attributs</a><a href=\"https://haroboz.com/portfolio/galerie-couples/\" class=\"block text-sm text-gray-600 hover:text-brand\">Couples &amp; Duos</a><a href=\"https://haroboz.com/portfolio/#creation\" class=\"block text-sm text-gray-600 hover:text-brand\">Création d'art</a><a href=\"https://haroboz.com/portfolio/#reportages\" class=\"block text-sm text-gray-600 hover:text-brand\">Reportages</a></div></div>\n                <div class=\"border-b border-gray-100 py-3\"><a href=\"https://haroboz.com/a-propos/\" class=\"block font-medium text-brand\">L'Univers</a></div>\n            </nav>\n            <div class=\"mt-8\"><button onclick=\"openPopup(); toggleMobileMenu();\" class=\"w-full bg-brand text-white px-6 py-4 rounded-xl font-medium hover:bg-brand-light shadow-md flex justify-center items-center cursor-pointer\"><i data-lucide=\"calendar\" class=\"w-5 h-5 mr-2\"></i> Prendre RDV gratuit</button></div>\n        </div>\n    </div>\n    <div id=\"mobile-overlay\" class=\"fixed inset-0 bg-brand bg-opacity-50 z-40 hidden\"></div>\n\n    <main class=\"w-full\">\n        <!-- PAGE HERO -->\n        <section class=\"bg-brand pt-28 lg:pt-32 pb-12 lg:pb-16 relative overflow-hidden\">\n            <div class=\"absolute top-0 right-0 -translate-y-1/3 translate-x-1/4 w-96 h-96 bg-brand-light rounded-full opacity-30 blur-3xl\"></div>\n            <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10\">\n                <nav class=\"text-sm text-white/60 mb-6\" aria-label=\"Fil d'Ariane\">\n                    <a href=\"https://haroboz.com/\" class=\"hover:text-white\">Accueil</a> <span class=\"mx-2\">/</span> <a href=\"https://haroboz.com/portfolio/\" class=\"hover:text-white\">Portfolio</a> <span class=\"mx-2\">/</span> <span class=\"text-white/90\">Témoignages Clients</span>\n                </nav>\n                <p class=\"text-white/70 text-sm uppercase tracking-widest mb-3\">Ce que nos clients disent de leur expérience</p>\n                <h1 class=\"text-3xl md:text-4xl lg:text-5xl font-serif font-bold text-white mb-4\">Témoignages Clients</h1>\n                <p class=\"text-white/70 text-base md:text-lg max-w-2xl\">Ils ont franchi le pas et vécu l'expérience Haroboz. Découvrez leurs mots, leurs émotions et leur regard sur une séance photographique qui a changé leur perception d'eux-mêmes.</p>\n            </div>\n        </section>\n\n        <!-- SEO CONTENT: Introduction -->\n        <section class=\"py-12 lg:py-20 bg-white\">\n            <div class=\"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Chez Haroboz, nous savons que réserver un <a href=\"https://haroboz.com/votre-experience/premier-shooting-nu/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4 transition-colors\">premier shooting</a> de nu masculin artistique demande du courage. C'est une démarche profondément personnelle, souvent motivée par l'envie de se reconnecter avec son image, de célébrer un moment de vie ou simplement de s'offrir une expérience hors du commun. C'est pourquoi les témoignages de nos clients sont si précieux&nbsp;: ils reflètent la réalité d'une séance avec Luc Desbois, dans notre studio privé à <strong>Marseille</strong>, bien loin des clichés et des appréhensions.</p>\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Chaque retour publié ici l'est avec l'accord explicite de son auteur. Pour préserver la <strong>confidentialité</strong> qui est au coeur de notre engagement, seuls le prénom et l'initiale du nom sont mentionnés. Retrouvez également nos galeries pour découvrir visuellement le résultat de ces expériences&nbsp;: <a href=\"https://haroboz.com/portfolio/galerie-portraits-hommes/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4 transition-colors\">portraits hommes</a> et <a href=\"https://haroboz.com/portfolio/galerie-couples/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4 transition-colors\">galerie couples</a>.</p>\n            </div>\n        </section>\n\n        <!-- TESTIMONIALS -->\n        <section class=\"py-12 lg:py-20 bg-gray-50\">\n            <div class=\"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <h2 class=\"text-2xl md:text-3xl font-serif text-brand mb-10 text-center\">Ils ont vécu l'expérience Haroboz</h2>\n\n                <div class=\"space-y-6\">\n\n                    <!-- Témoignage 1 -->\n                    <div class=\"bg-brand-50 rounded-2xl p-6 md:p-8 border border-brand/10\">\n                        <div class=\"flex items-start gap-4\">\n                            <div class=\"flex-shrink-0 mt-1\"><img src=\"https://haroboz.com/wp-content/uploads/2026/03/Photoroom_20251222_144602.png\" alt=\"Portrait client Marc D.\" class=\"w-14 h-14 rounded-full object-cover shadow-md\"></div>\n                            <div>\n                                <p class=\"text-gray-600 leading-relaxed mb-4\">&laquo;&nbsp;J'ai longtemps hésité avant de contacter Luc. À 42 ans, je ne pensais pas qu'un shooting comme celui-là était fait pour moi. Dès le premier échange téléphonique, j'ai compris que j'étais entre de bonnes mains. La séance en studio a été un moment de lâcher-prise total. Quand j'ai vu les photos dans ma galerie privée, j'ai eu du mal à croire que c'était moi. Un regard que je ne me connaissais pas, une confiance que je ne soupçonnais pas. Le tirage sur papier fine art trône désormais dans mon bureau. Merci Luc, sincèrement.&nbsp;&raquo;</p>\n                                <p class=\"font-medium text-brand\"><strong>Marc D.</strong>, Marseille &mdash; Pack Portrait Studio</p>\n                            </div>\n                        </div>\n                    </div>\n\n                    <!-- Témoignage 2 -->\n                    <div class=\"bg-brand-50 rounded-2xl p-6 md:p-8 border border-brand/10\">\n                        <div class=\"flex items-start gap-4\">\n                            <div class=\"flex-shrink-0 mt-1\"><img src=\"https://haroboz.com/wp-content/uploads/2026/04/IMG_2909-1-scaled.png\" alt=\"Portrait client Julien R.\" class=\"w-14 h-14 rounded-full object-cover shadow-md\"></div>\n                            <div>\n                                <p class=\"text-gray-600 leading-relaxed mb-4\">&laquo;&nbsp;Mon compagnon m'a offert une carte cadeau Haroboz pour notre anniversaire. Au départ, j'étais sceptique. Mais l'accueil de Luc, sa patience et son oeil artistique ont transformé cette journée en un souvenir inoubliable. Nous avons opté pour un shooting duo et le résultat dépasse tout ce que nous imaginions. Les photos capturent notre complicité avec une justesse qui nous émeut encore aujourd'hui. La discrétion totale tout au long du processus nous a vraiment rassurés.&nbsp;&raquo;</p>\n                                <p class=\"font-medium text-brand\"><strong>Julien R.</strong>, Nice &mdash; Pack Duo &amp; Couple</p>\n                            </div>\n                        </div>\n                    </div>\n\n                    <!-- Témoignage 3 -->\n                    <div class=\"bg-brand-50 rounded-2xl p-6 md:p-8 border border-brand/10\">\n                        <div class=\"flex items-start gap-4\">\n                            <div class=\"flex-shrink-0 mt-1\"><img src=\"https://haroboz.com/wp-content/uploads/2025/11/IMG_2919.png\" alt=\"Portrait client Thomas L.\" class=\"w-14 h-14 rounded-full object-cover shadow-md\"></div>\n                            <div>\n                                <p class=\"text-gray-600 leading-relaxed mb-4\">&laquo;&nbsp;Je suis venu en vacances sur la Sud de la France et j'avais découvert le travail de Haroboz sur Instagram. La qualité des images m'a convaincu de tenter l'expérience. Luc a un talent rare pour mettre à l'aise. En quelques minutes, la gêne disparaît et on se laisse guider par sa direction artistique. Le shooting en extérieur avec la lumière du soir sur les rochers était magique. J'ai choisi un tirage sur plexiglas mat&nbsp;: c'est une oeuvre d'art que je chéris. Si vous hésitez, foncez les yeux fermés.&nbsp;&raquo;</p>\n                                <p class=\"font-medium text-brand\"><strong>Thomas L.</strong>, Lyon (en vacances à Toulon) &mdash; Pack Extérieur</p>\n                            </div>\n                        </div>\n                    </div>\n\n                    <!-- Témoignage 4 -->\n                    <div class=\"bg-brand-50 rounded-2xl p-6 md:p-8 border border-brand/10\">\n                        <div class=\"flex items-start gap-4\">\n                            <div class=\"flex-shrink-0 mt-1\"><img src=\"https://haroboz.com/wp-content/uploads/2026/04/Photoroom_20250615_213259-1-scaled.png\" alt=\"Portrait client David M.\" class=\"w-14 h-14 rounded-full object-cover shadow-md\"></div>\n                            <div>\n                                <p class=\"text-gray-600 leading-relaxed mb-4\">&laquo;&nbsp;Après une période difficile dans ma vie, j'avais besoin de me réconcilier avec mon image. Un ami m'a parlé de Haroboz et du projet Mentoo. L'échange préalable avec Luc a posé un cadre rassurant et bienveillant. Pendant la séance, j'ai ressenti quelque chose que je n'attendais pas&nbsp;: de la fierté. Pas de l'orgueil, mais une fierté tranquille d'être là, d'oser, d'exister pleinement devant l'objectif. Les photos sont belles, mais ce que je retiens avant tout, c'est cette sensation de libération.&nbsp;&raquo;</p>\n                                <p class=\"font-medium text-brand\"><strong>David M.</strong>, Paris &mdash; Pack Portrait Studio</p>\n                            </div>\n                        </div>\n                    </div>\n\n                    <!-- Témoignage 5 -->\n                    <div class=\"bg-brand-50 rounded-2xl p-6 md:p-8 border border-brand/10\">\n                        <div class=\"flex items-start gap-4\">\n                            <div class=\"flex-shrink-0 mt-1\"><img src=\"https://haroboz.com/wp-content/uploads/2026/03/Photoroom_20260121_170132.png\" alt=\"Portrait client Philippe B.\" class=\"w-14 h-14 rounded-full object-cover shadow-md\"></div>\n                            <div>\n                                <p class=\"text-gray-600 leading-relaxed mb-4\">&laquo;&nbsp;Pour mes 50 ans, je voulais marquer le coup. Pas un cadeau matériel, mais une expérience. Le shooting chez moi, dans mon appartement avec vue sur la baie de Marseille, a été l'une des meilleures décisions de ma vie. Luc transforme n'importe quel espace en studio photo. Sa maîtrise de la lumière naturelle est impressionnante. Le résultat est à la fois intime et artistique. La galerie privée en ligne est un vrai plus&nbsp;: on prend le temps de choisir, sans pression, les clichés qui nous touchent le plus.&nbsp;&raquo;</p>\n                                <p class=\"font-medium text-brand\"><strong>Philippe B.</strong>, Marseille &mdash; Pack Photo à Domicile</p>\n                            </div>\n                        </div>\n                    </div>\n\n                    <!-- Témoignage 6 -->\n                    <div class=\"bg-brand-50 rounded-2xl p-6 md:p-8 border border-brand/10\">\n                        <div class=\"flex items-start gap-4\">\n                            <div class=\"flex-shrink-0 mt-1\"><img src=\"https://haroboz.com/wp-content/uploads/2025/12/Photoroom_20251206_222612.png\" alt=\"Portrait client Alexandre G.\" class=\"w-14 h-14 rounded-full object-cover shadow-md\"></div>\n                            <div>\n                                <p class=\"text-gray-600 leading-relaxed mb-4\">&laquo;&nbsp;En tant que modèle amateur, j'avais besoin d'un book professionnel qui sorte de l'ordinaire. Luc a su capter ma personnalité avec une authenticité que je n'avais trouvée chez aucun autre photographe. Son approche est véritablement artistique&nbsp;: il ne cherche pas la pose parfaite mais le moment vrai. Les retouches sont subtiles, respectueuses de la réalité. Mon book m'a ouvert des portes que je n'espérais plus. Je recommande Haroboz sans la moindre réserve à tous ceux qui cherchent un photographe à la fois talentueux et profondément humain.&nbsp;&raquo;</p>\n                                <p class=\"font-medium text-brand\"><strong>Alexandre G.</strong>, Grasse &mdash; Pack Book Modèle</p>\n                            </div>\n                        </div>\n                    </div>\n\n                </div>\n            </div>\n        </section>\n\n        <!-- FAQ -->\n        <section class=\"py-12 lg:py-16 bg-white\" itemscope itemtype=\"https://schema.org/FAQPage\">\n            <div class=\"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <h2 class=\"text-2xl md:text-3xl font-serif text-brand mb-8 text-center\">Questions fréquentes sur les témoignages</h2>\n                <div class=\"space-y-3\">\n\n                    <div class=\"faq-card bg-white rounded-xl shadow-sm border border-gray-100\" itemscope itemprop=\"mainEntity\" itemtype=\"https://schema.org/Question\">\n                        <button onclick=\"toggleFaq(this)\" class=\"w-full flex justify-between items-center p-5 text-left cursor-pointer\">\n                            <span class=\"font-medium text-brand pr-4\" itemprop=\"name\">Les témoignages sont-ils authentiques ?</span>\n                            <i data-lucide=\"chevron-down\" class=\"faq-chevron w-5 h-5 text-gray-400 flex-shrink-0 transition-transform duration-200\"></i>\n                        </button>\n                        <div class=\"faq-content px-5 pb-5\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https://schema.org/Answer\">\n                            <p class=\"text-gray-600 leading-relaxed\" itemprop=\"text\">Oui, chaque témoignage est rédigé par un client ayant vécu l'expérience Haroboz. Nous publions uniquement les avis que nos clients nous autorisent expressément à partager. Pour protéger leur vie privée, seuls le prénom et l'initiale du nom de famille sont mentionnés.</p>\n                        </div>\n                    </div>\n\n                    <div class=\"faq-card bg-white rounded-xl shadow-sm border border-gray-100\" itemscope itemprop=\"mainEntity\" itemtype=\"https://schema.org/Question\">\n                        <button onclick=\"toggleFaq(this)\" class=\"w-full flex justify-between items-center p-5 text-left cursor-pointer\">\n                            <span class=\"font-medium text-brand pr-4\" itemprop=\"name\">Puis-je laisser un témoignage après ma séance ?</span>\n                            <i data-lucide=\"chevron-down\" class=\"faq-chevron w-5 h-5 text-gray-400 flex-shrink-0 transition-transform duration-200\"></i>\n                        </button>\n                        <div class=\"faq-content px-5 pb-5\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https://schema.org/Answer\">\n                            <p class=\"text-gray-600 leading-relaxed\" itemprop=\"text\">Bien sûr. Après votre shooting, nous vous invitons à partager votre ressenti si vous le souhaitez. C'est entièrement volontaire et vous gardez le contrôle total sur le contenu publié. Vous pouvez nous transmettre votre avis par email ou via votre galerie privée client.</p>\n                        </div>\n                    </div>\n\n                    <div class=\"faq-card bg-white rounded-xl shadow-sm border border-gray-100\" itemscope itemprop=\"mainEntity\" itemtype=\"https://schema.org/Question\">\n                        <button onclick=\"toggleFaq(this)\" class=\"w-full flex justify-between items-center p-5 text-left cursor-pointer\">\n                            <span class=\"font-medium text-brand pr-4\" itemprop=\"name\">Mon identité sera-t-elle protégée ?</span>\n                            <i data-lucide=\"chevron-down\" class=\"faq-chevron w-5 h-5 text-gray-400 flex-shrink-0 transition-transform duration-200\"></i>\n                        </button>\n                        <div class=\"faq-content px-5 pb-5\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https://schema.org/Answer\">\n                            <p class=\"text-gray-600 leading-relaxed\" itemprop=\"text\">Absolument. La confidentialité est une valeur fondamentale chez Haroboz. Votre nom complet, votre visage et toute information permettant de vous identifier ne seront jamais publiés sans votre consentement explicite et détaillé.</p>\n                        </div>\n                    </div>\n\n                </div>\n            </div>\n        </section>\n\n        <!-- CTA -->\n        <section class=\"bg-brand py-16 lg:py-20 relative overflow-hidden\">\n            <div class=\"absolute top-0 right-0 -translate-y-1/2 translate-x-1/3 w-96 h-96 bg-brand-light rounded-full opacity-50 blur-3xl\"></div>\n            <div class=\"absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/3 w-96 h-96 bg-[#3a00a8] rounded-full opacity-50 blur-3xl\"></div>\n            <div class=\"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10\">\n                <h2 class=\"text-3xl md:text-4xl font-serif text-white mb-4\">Prêt à écrire votre propre témoignage&nbsp;?</h2>\n                <p class=\"text-brand-50 text-base md:text-lg mb-8 max-w-2xl mx-auto\">Vivez l'expérience Haroboz &mdash; Shooting privé — Marseille, Toulon, Nice, Paris</p>\n                <button onclick=\"openPopup()\" class=\"bg-white text-brand px-8 py-4 rounded-full text-lg font-bold hover:bg-gray-100 shadow-xl flex items-center justify-center cursor-pointer mx-auto\"><i data-lucide=\"calendar\" class=\"w-5 h-5 mr-2\"></i> Être rappelé sous 24h</button>\n            </div>\n        </section>\n    </main>\n\n    <!-- FOOTER -->\n    <footer class=\"bg-brand text-white border-t border-brand-light/20\">\n        <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16\">\n            <div class=\"grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12\">\n                <div><div class=\"font-serif text-lg font-bold mb-4\">Nos Packs</div><ul class=\"space-y-2\"><li><a href=\"https://haroboz.com/packs-shooting/portrait-studio/\" class=\"text-sm text-gray-300 hover:text-white\">Portrait Studio</a></li><li><a href=\"https://haroboz.com/packs-shooting/shooting-exterieur/\" class=\"text-sm text-gray-300 hover:text-white\">Shooting Extérieur</a></li><li><a href=\"https://haroboz.com/packs-shooting/shooting-duo-couple/\" class=\"text-sm text-gray-300 hover:text-white\">Duo &amp; Couple</a></li><li><a href=\"https://haroboz.com/packs-shooting/photo-domicile/\" class=\"text-sm text-gray-300 hover:text-white\">Photo à Domicile</a></li></ul></div>\n                <div><div class=\"font-serif text-lg font-bold mb-4\">Lieux</div><ul class=\"space-y-2\"><li><a href=\"https://haroboz.com/photographe/photographe-marseille/\" class=\"text-sm text-gray-300 hover:text-white\">Marseille</a></li><li><a href=\"https://haroboz.com/photographe/photographe-toulon/\" class=\"text-sm text-gray-300 hover:text-white\">Toulon</a></li><li><a href=\"https://haroboz.com/photographe/photographe-nice/\" class=\"text-sm text-gray-300 hover:text-white\">Nice</a></li><li><a href=\"https://haroboz.com/photographe/photographe-paris/\" class=\"text-sm text-gray-300 hover:text-white\">Paris</a></li></ul></div>\n                <div><div class=\"font-serif text-lg font-bold mb-4\">Expérience</div><ul class=\"space-y-2\"><li><a href=\"https://haroboz.com/votre-experience/premier-shooting-nu/\" class=\"text-sm text-gray-300 hover:text-white\">Premier Shooting</a></li><li><a href=\"https://haroboz.com/votre-experience/retrouver-confiance-corps/\" class=\"text-sm text-gray-300 hover:text-white\">Retrouver Confiance</a></li><li><a href=\"https://haroboz.com/votre-experience/book-modele-professionnel/\" class=\"text-sm text-gray-300 hover:text-white\">Book Modèle Pro</a></li><li><a href=\"https://haroboz.com/portfolio/temoignages-clients/\" class=\"text-sm text-gray-300 hover:text-white\">Témoignages</a></li></ul></div>\n                <div><div class=\"font-serif text-lg font-bold mb-4\">Haroboz</div><ul class=\"space-y-2\"><li><a href=\"https://haroboz.com/a-propos/\" class=\"text-sm text-gray-300 hover:text-white\">À Propos</a></li><li><a href=\"https://haroboz.com/portfolio/\" class=\"text-sm text-gray-300 hover:text-white\">Réalisations</a></li><li><a href=\"https://haroboz.com/contact/\" class=\"text-sm text-gray-300 hover:text-white\">Contact</a></li><li><a href=\"https://haroboz.com/mentions-legales/\" class=\"text-sm text-gray-300 hover:text-white\">Mentions légales</a></li></ul></div>\n            </div>\n            <div class=\"border-t border-white/10 mt-10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4\">\n                <p class=\"text-sm text-gray-400\">&copy; 2026 Haroboz — Luc Desbois | Photographe Art Masculin | Marseille, Toulon, Nice, Paris</p>\n                <div class=\"flex items-center gap-4\"><a href=\"https://www.instagram.com/hbozart/\" target=\"_blank\" class=\"text-gray-400 hover:text-white\"><i data-lucide=\"instagram\" class=\"w-5 h-5\"></i></a><a href=\"https://haroboz.com/mentions-legales/\" class=\"text-sm text-gray-400 hover:text-white\">Mentions légales</a></div>\n            </div>\n        </div>\n    </footer>\n\n    <!-- POPUP -->\n    <div id=\"booking-popup\" class=\"fixed inset-0 z-[100] flex items-center justify-center p-4 popup-hidden\">\n        <div class=\"absolute inset-0 bg-brand/60 backdrop-blur-sm\" onclick=\"closePopup()\"></div>\n        <div id=\"popup-content\" class=\"relative bg-white rounded-2xl shadow-2xl max-w-lg w-full max-h-[90vh] overflow-y-auto\">\n            <div class=\"bg-brand rounded-t-2xl p-6 text-center relative\"><button onclick=\"closePopup()\" class=\"absolute top-4 right-4 text-white/70 hover:text-white cursor-pointer\"><i data-lucide=\"x\" class=\"w-6 h-6\"></i></button><h3 class=\"text-xl font-serif text-white font-bold\">Réservez votre séance</h3><p class=\"text-white/70 text-sm mt-1\">Réponse confidentielle sous 24h</p></div>\n            <form id=\"booking-form\" class=\"p-6\" onsubmit=\"handleSubmit(event)\">\n                <div class=\"space-y-4\">\n                    <div><label class=\"block text-sm font-medium text-brand mb-1\">Prénom *</label><input type=\"text\" required placeholder=\"Votre prénom\" name=\"prenom\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-brand placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand\"></div>\n                    <div><label class=\"block text-sm font-medium text-brand mb-1\">Email *</label><input type=\"email\" required placeholder=\"votre@email.com\" name=\"email\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-brand placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand\"></div>\n                    <div><label class=\"block text-sm font-medium text-brand mb-1\">Téléphone *</label><input type=\"tel\" required placeholder=\"06 XX XX XX XX\" name=\"telephone\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-brand placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand\"></div>\n                    <div><label class=\"block text-sm font-medium text-brand mb-1\">Message</label><textarea rows=\"3\" placeholder=\"Parlez-moi de votre projet...\" name=\"message\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-brand placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand resize-none\"></textarea></div>\n                </div>\n                <button type=\"submit\" class=\"w-full mt-6 bg-brand text-white py-4 rounded-xl font-bold hover:bg-brand-light shadow-lg flex items-center justify-center cursor-pointer\"><i data-lucide=\"send\" class=\"w-5 h-5 mr-2\"></i> Envoyer ma demande</button>\n                <p class=\"text-center text-xs text-gray-400 mt-3\"><i data-lucide=\"lock\" class=\"w-3 h-3 inline\"></i> 100% confidentiel</p>\n            </form>\n            <div id=\"popup-success\" class=\"hidden p-8 text-center\"><div class=\"w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4\"><i data-lucide=\"check-circle\" class=\"w-8 h-8 text-green-600\"></i></div><h3 class=\"text-2xl font-serif text-brand mb-2\">Demande envoyée !</h3><p class=\"text-gray-600 mb-6\">Je vous recontacte sous 24h.</p><button onclick=\"closePopup()\" class=\"bg-brand text-white px-6 py-3 rounded-xl font-medium hover:bg-brand-light cursor-pointer\">Fermer</button></div>\n        </div>\n    </div>\n\n    <div id=\"floating-cta\" class=\"fixed bottom-6 right-6 z-50 opacity-0 translate-y-4 transition-all duration-300 pointer-events-none\">\n        <button onclick=\"openPopup()\" class=\"relative bg-brand text-white w-14 h-14 md:w-auto md:h-auto md:px-6 md:py-3 rounded-full shadow-2xl hover:bg-brand-light flex items-center justify-center cursor-pointer pulse-ring text-brand\"><i data-lucide=\"calendar\" class=\"w-6 h-6 md:w-5 md:h-5 md:mr-2\"></i><span class=\"hidden md:inline font-medium\">Prendre RDV</span></button>\n    </div>\n</div>",
