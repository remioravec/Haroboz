ace-y-2\">\n                <div class=\"border-b border-gray-100 py-3\"><button class=\"flex justify-between items-center w-full text-left font-medium text-brand mobile-accordion-btn\">Nos Séances <i data-lucide=\"chevron-down\" class=\"w-4 h-4\"></i></button><div class=\"hidden mt-3 space-y-3 pl-4 border-l-2 border-brand-50\"><a href=\"https://haroboz.com/packs-shooting/portrait-studio/\" class=\"block text-sm text-gray-600 hover:text-brand\">Portrait en Studio</a><a href=\"https://haroboz.com/packs-shooting/shooting-exterieur/\" class=\"block text-sm text-gray-600 hover:text-brand\">Shooting en Extérieur</a><a href=\"https://haroboz.com/packs-shooting/photo-domicile/\" class=\"block text-sm text-gray-600 hover:text-brand\">Photo à Domicile</a><a href=\"https://haroboz.com/packs-shooting/shooting-duo-couple/\" class=\"block text-sm text-gray-600 hover:text-brand\">Shooting Duo &amp; Couple</a></div></div>\n                <div class=\"border-b border-gray-100 py-3\"><button class=\"flex justify-between items-center w-full text-left font-medium text-brand mobile-accordion-btn\">Votre Objectif <i data-lucide=\"chevron-down\" class=\"w-4 h-4\"></i></button><div class=\"hidden mt-3 space-y-3 pl-4 border-l-2 border-brand-50\"><a href=\"https://haroboz.com/votre-experience/retrouver-confiance-corps/\" class=\"block text-sm text-gray-600 hover:text-brand\">Confiance &amp; Acceptation</a><a href=\"https://haroboz.com/votre-experience/book-modele-professionnel/\" class=\"block text-sm text-gray-600 hover:text-brand\">Book Professionnel</a><a href=\"https://haroboz.com/votre-experience/cadeau-couple-original/\" class=\"block text-sm text-gray-600 hover:text-brand\">Immortaliser son Couple</a><a href=\"https://haroboz.com/votre-experience/premier-shooting-nu/\" class=\"block text-sm text-gray-600 hover:text-brand\">Cadeau &amp; Célébration</a></div></div>\n                <div class=\"border-b border-gray-100 py-3\"><button class=\"flex justify-between items-center w-full text-left font-medium text-brand mobile-accordion-btn\">Où me trouver ? <i data-lucide=\"chevron-down\" class=\"w-4 h-4\"></i></button><div class=\"hidden mt-3 space-y-3 pl-4 border-l-2 border-brand-50\"><a href=\"https://haroboz.com/photographe/photographe-marseille/\" class=\"block text-sm text-gray-600 hover:text-brand\">Marseille</a><a href=\"https://haroboz.com/photographe/photographe-toulon/\" class=\"block text-sm text-gray-600 hover:text-brand\">Toulon</a><a href=\"https://haroboz.com/photographe/photographe-nice/\" class=\"block text-sm text-gray-600 hover:text-brand\">Nice</a><a href=\"https://haroboz.com/photographe/photographe-paris/\" class=\"block text-sm text-gray-600 hover:text-brand\">Paris</a></div></div>\n                <div class=\"border-b border-gray-100 py-3\"><button class=\"flex justify-between items-center w-full text-left font-medium text-brand mobile-accordion-btn\">L'Oeuvre <i data-lucide=\"chevron-down\" class=\"w-4 h-4\"></i></button><div class=\"hidden mt-3 space-y-3 pl-4 border-l-2 border-brand-50\"><a href=\"https://haroboz.com/portfolio/\" class=\"block text-sm text-gray-600 hover:text-brand\">Toutes les oeuvres</a><a href=\"https://haroboz.com/portfolio/galerie-portraits-hommes/\" class=\"block text-sm text-gray-600 hover:text-brand\">Portraits</a><a href=\"https://haroboz.com/portfolio/#nus\" class=\"block text-sm text-gray-600 hover:text-brand\">Nus &amp; Attributs</a><a href=\"https://haroboz.com/portfolio/galerie-couples/\" class=\"block text-sm text-gray-600 hover:text-brand\">Couples &amp; Duos</a><a href=\"https://haroboz.com/portfolio/#creation\" class=\"block text-sm text-gray-600 hover:text-brand\">Création d'art</a><a href=\"https://haroboz.com/portfolio/#reportages\" class=\"block text-sm text-gray-600 hover:text-brand\">Reportages</a></div></div>\n                <div class=\"border-b border-gray-100 py-3\"><a href=\"https://haroboz.com/a-propos/\" class=\"block font-medium text-brand\">L'Univers</a></div>\n            </nav>\n            <div class=\"mt-8\"><button onclick=\"openPopup(); toggleMobileMenu();\" class=\"w-full bg-brand text-white px-6 py-4 rounded-xl font-medium hover:bg-brand-light shadow-md flex justify-center items-center cursor-pointer\"><i data-lucide=\"calendar\" class=\"w-5 h-5 mr-2\"></i> Prendre RDV gratuit</button></div>\n        </div>\n    </div>\n    <div id=\"mobile-overlay\" class=\"fixed inset-0 bg-brand bg-opacity-50 z-40 hidden\"></div>\n\n    <main class=\"w-full\">\n\n        <!-- HERO -->\n        <section class=\"bg-brand pt-28 lg:pt-32 pb-16 lg:pb-20\">\n            <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <nav class=\"mb-8\" aria-label=\"Fil d'Ariane\">\n                    <ol class=\"flex items-center space-x-2 text-sm text-white/60\" itemscope itemtype=\"https://schema.org/BreadcrumbList\">\n                        <li itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\"><a itemprop=\"item\" href=\"https://haroboz.com/\" class=\"hover:text-white\"><span itemprop=\"name\">Accueil</span></a><meta itemprop=\"position\" content=\"1\"></li>\n                        <li><i data-lucide=\"chevron-right\" class=\"w-4 h-4\"></i></li>\n                        <li itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\"><a itemprop=\"item\" href=\"https://haroboz.com/boutique/\" class=\"hover:text-white\"><span itemprop=\"name\">Boutique</span></a><meta itemprop=\"position\" content=\"2\"></li>\n                        <li><i data-lucide=\"chevron-right\" class=\"w-4 h-4\"></i></li>\n                        <li itemprop=\"itemListElement\" itemscope itemtype=\"https://schema.org/ListItem\"><span itemprop=\"name\" class=\"text-white/90\">Carte Cadeau</span><meta itemprop=\"position\" content=\"3\"></li>\n                    </ol>\n                </nav>\n                <p class=\"text-white/70 text-sm font-medium tracking-widest uppercase mb-4\">Un cadeau qui change un regard</p>\n                <h1 class=\"text-4xl md:text-5xl lg:text-6xl font-serif font-bold text-white mb-6\">Carte Cadeau</h1>\n                <p class=\"text-lg md:text-xl text-white/80 max-w-2xl leading-relaxed\">Offrez bien plus qu'un objet. La carte cadeau Haroboz est une invitation à vivre une expérience photographique intime, libératrice et inoubliable, o&ugrave; que vous soyez.</p>\n            </div>\n        </section>\n\n        <!-- INTRODUCTION -->\n        <section class=\"py-12 lg:py-20 bg-white\">\n            <div class=\"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <h2 class=\"text-2xl md:text-3xl font-serif text-brand mt-12 mb-4\">Offrir l'expérience Haroboz</h2>\n\n                <p class=\"text-gray-600 leading-relaxed mb-4\">La carte cadeau Haroboz est née d'un constat simple&nbsp;: beaucoup de nos clients nous confient qu'ils n'auraient jamais osé réserver un shooting par eux-m&ecirc;mes. C'est souvent un proche — compagnon, ami, frère — qui a fait le premier pas en leur offrant cette expérience. Et dans la grande majorité des cas, cette initiative a transformé leur perception d'eux-m&ecirc;mes.</p>\n\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Offrir une carte cadeau Haroboz, c'est offrir un moment de <strong>l&acirc;cher-prise</strong>, de <strong>confiance en soi</strong> et de <strong>reconnexion</strong> avec sa propre image. C'est dire à quelqu'un&nbsp;: &laquo;&nbsp;Tu mérites de te voir tel que tu es&nbsp;: beau, unique, digne d'&ecirc;tre célébré.&nbsp;&raquo; Dans notre <a href=\"https://haroboz.com/boutique/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4\">boutique</a>, c'est le cadeau le plus personnel et le plus transformateur que nous proposons.</p>\n\n                <p class=\"text-gray-600 leading-relaxed mb-4\">La carte est utilisable sur l'ensemble de nos <a href=\"https://haroboz.com/packs-shooting/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4\">packs shooting</a>, du <a href=\"https://haroboz.com/packs-shooting/portrait-studio/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4\">portrait studio</a> au <a href=\"https://haroboz.com/packs-shooting/shooting-duo-couple/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4\">shooting duo</a>, en passant par les séances en <a href=\"https://haroboz.com/packs-shooting/shooting-exterieur/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4\">extérieur</a>. Chaque pack inclut la séance photo, la direction artistique et un <a href=\"https://haroboz.com/boutique/tirages-art-edition-limitee/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4\">tirage d'art</a> sur le support au choix du bénéficiaire.</p>\n            </div>\n        </section>\n\n        <!-- COMMENT ÇA MARCHE -->\n        <section class=\"py-12 lg:py-20 bg-gray-50\">\n            <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <h2 class=\"text-2xl md:text-3xl font-serif text-brand text-center mb-12\">Comment &ccedil;a fonctionne</h2>\n\n                <div class=\"grid md:grid-cols-3 gap-8\">\n\n                    <div class=\"bg-white rounded-2xl shadow-sm border border-gray-100 p-8 text-center hover:shadow-lg transition-shadow duration-300\">\n                        <div class=\"w-14 h-14 bg-brand rounded-full flex items-center justify-center mx-auto mb-6\"><span class=\"text-white text-xl font-bold\">1</span></div>\n                        <h3 class=\"text-xl font-serif font-semibold text-brand mb-3\">Vous choisissez</h3>\n                        <p class=\"text-gray-600 leading-relaxed\">Contactez-nous pour définir le montant ou le pack que vous souhaitez offrir. Nous personnalisons la carte cadeau avec un message de votre part. Vous pouvez opter pour un montant libre ou un pack spécifique — portrait studio, extérieur, duo ou domicile.</p>\n                    </div>\n\n                    <div class=\"bg-white rounded-2xl shadow-sm border border-gray-100 p-8 text-center hover:shadow-lg transition-shadow duration-300\">\n                        <div class=\"w-14 h-14 bg-brand rounded-full flex items-center justify-center mx-auto mb-6\"><span class=\"text-white text-xl font-bold\">2</span></div>\n                        <h3 class=\"text-xl font-serif font-semibold text-brand mb-3\">Nous créons</h3>\n                        <p class=\"text-gray-600 leading-relaxed\">Votre carte cadeau est préparée avec soin. Elle peut &ecirc;tre envoyée par email au format numérique (idéal pour les cadeaux de dernière minute) ou imprimée sur un support premium et expédiée dans un écrin élégant, pr&ecirc;t à offrir.</p>\n                    </div>\n\n                    <div class=\"bg-white rounded-2xl shadow-sm border border-gray-100 p-8 text-center hover:shadow-lg transition-shadow duration-300\">\n                        <div class=\"w-14 h-14 bg-brand rounded-full flex items-center justify-center mx-auto mb-6\"><span class=\"text-white text-xl font-bold\">3</span></div>\n                        <h3 class=\"text-xl font-serif font-semibold text-brand mb-3\">Il ou elle vit l'expérience</h3>\n                        <p class=\"text-gray-600 leading-relaxed\">Le bénéficiaire nous contacte quand il le souhaite pour planifier sa séance. Luc prend le temps d'un échange confidentiel pour comprendre ses envies et le mettre en confiance avant le jour J. L'<a href=\"https://haroboz.com/votre-experience/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4\">expérience complète</a> l'attend.</p>\n                    </div>\n\n                </div>\n            </div>\n        </section>\n\n        <!-- POUR QUI -->\n        <section class=\"py-12 lg:py-20 bg-white\">\n            <div class=\"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <h2 class=\"text-2xl md:text-3xl font-serif text-brand mt-12 mb-4\">Pour qui est cette carte cadeau ?</h2>\n\n                <h3 class=\"text-xl font-serif text-brand mt-8 mb-3\">Pour votre compagnon</h3>\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Un anniversaire de couple, la Saint-Valentin, ou simplement l'envie de lui offrir quelque chose d'unique&nbsp;: la carte cadeau Haroboz est le moyen le plus élégant de dire à votre partenaire combien vous le trouvez beau. Et pourquoi ne pas opter pour un <a href=\"https://haroboz.com/packs-shooting/shooting-duo-couple/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4\">shooting duo</a> pour vivre l'expérience ensemble&nbsp;?</p>\n\n                <h3 class=\"text-xl font-serif text-brand mt-8 mb-3\">Pour un ami qui mérite de se voir autrement</h3>\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Nous avons tous dans notre entourage quelqu'un qui se dévalorise, qui ne voit pas sa propre beauté. Offrir un shooting Haroboz, c'est lui tendre un miroir bienveillant et lui permettre de <a href=\"https://haroboz.com/votre-experience/retrouver-confiance-corps/\" class=\"text-brand font-medium hover:text-brand-light underline underline-offset-4\">retrouver confiance en son image</a>. Un cadeau qui dépasse de loin tout objet matériel.</p>\n\n                <h3 class=\"text-xl font-serif text-brand mt-8 mb-3\">Pour un passionné de photographie d'art</h3>\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Les amateurs d'art et de photographie seront sensibles à la démarche artistique de Haroboz. Au-delà de la séance, c'est la rencontre avec un photographe dont le travail s'inscrit dans une tradition noble — celle du portrait masculin — qui fait de cette carte cadeau une expérience culturelle et esthétique à part entière.</p>\n\n                <h3 class=\"text-xl font-serif text-brand mt-8 mb-3\">Pour vous-m&ecirc;me</h3>\n                <p class=\"text-gray-600 leading-relaxed mb-4\">Personne n'a dit que la carte cadeau devait &ecirc;tre pour quelqu'un d'autre. Si vous repoussez depuis longtemps l'idée d'un shooting, considérez-la comme une manière de vous engager envers vous-m&ecirc;me. Achetez-la, fixez une date et offrez-vous cette parenthèse que vous méritez.</p>\n            </div>\n        </section>\n\n        <!-- FAQ -->\n        <section class=\"py-12 lg:py-20 bg-gray-50\" itemscope itemtype=\"https://schema.org/FAQPage\">\n            <div class=\"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <h2 class=\"text-2xl md:text-3xl font-serif text-brand text-center mb-12\">Questions fréquentes</h2>\n\n                <div class=\"space-y-4\">\n\n                    <div class=\"faq-card bg-white rounded-xl shadow-sm border border-gray-100\" itemscope itemprop=\"mainEntity\" itemtype=\"https://schema.org/Question\">\n                        <button onclick=\"toggleFaq(this)\" class=\"w-full flex justify-between items-center p-6 text-left cursor-pointer\">\n                            <h3 class=\"text-base font-semibold text-brand pr-4\" itemprop=\"name\">Quelle est la durée de validité de la carte cadeau ?</h3>\n                            <i data-lucide=\"chevron-down\" class=\"faq-chevron w-5 h-5 text-brand flex-shrink-0 transition-transform duration-300\"></i>\n                        </button>\n                        <div class=\"faq-content\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https://schema.org/Answer\">\n                            <p class=\"px-6 pb-6 text-gray-600 leading-relaxed\" itemprop=\"text\">La carte cadeau Haroboz est valable 12 mois à compter de sa date d'achat. Ce délai permet au bénéficiaire de choisir le moment idéal pour vivre son expérience, sans précipitation.</p>\n                        </div>\n                    </div>\n\n                    <div class=\"faq-card bg-white rounded-xl shadow-sm border border-gray-100\" itemscope itemprop=\"mainEntity\" itemtype=\"https://schema.org/Question\">\n                        <button onclick=\"toggleFaq(this)\" class=\"w-full flex justify-between items-center p-6 text-left cursor-pointer\">\n                            <h3 class=\"text-base font-semibold text-brand pr-4\" itemprop=\"name\">Puis-je choisir un pack spécifique ou un montant libre ?</h3>\n                            <i data-lucide=\"chevron-down\" class=\"faq-chevron w-5 h-5 text-brand flex-shrink-0 transition-transform duration-300\"></i>\n                        </button>\n                        <div class=\"faq-content\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https://schema.org/Answer\">\n                            <p class=\"px-6 pb-6 text-gray-600 leading-relaxed\" itemprop=\"text\">Les deux options sont possibles. Vous pouvez offrir un pack précis (Portrait Studio, Extérieur, Duo, Domicile) ou un montant libre que le bénéficiaire utilisera selon ses préférences. N'hésitez pas à nous contacter pour des conseils personnalisés.</p>\n                        </div>\n                    </div>\n\n                    <div class=\"faq-card bg-white rounded-xl shadow-sm border border-gray-100\" itemscope itemprop=\"mainEntity\" itemtype=\"https://schema.org/Question\">\n                        <button onclick=\"toggleFaq(this)\" class=\"w-full flex justify-between items-center p-6 text-left cursor-pointer\">\n                            <h3 class=\"text-base font-semibold text-brand pr-4\" itemprop=\"name\">Le bénéficiaire saura-t-il exactement en quoi consiste le cadeau ?</h3>\n                            <i data-lucide=\"chevron-down\" class=\"faq-chevron w-5 h-5 text-brand flex-shrink-0 transition-transform duration-300\"></i>\n                        </button>\n                        <div class=\"faq-content\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https://schema.org/Answer\">\n                            <p class=\"px-6 pb-6 text-gray-600 leading-relaxed\" itemprop=\"text\">La carte cadeau mentionne le type d'expérience offerte de manière élégante et discrète. Le bénéficiaire est ensuite guidé par Luc lors d'un premier échange confidentiel qui lui permettra de poser toutes ses questions et de se sentir parfaitement à l'aise.</p>\n                        </div>\n                    </div>\n\n                    <div class=\"faq-card bg-white rounded-xl shadow-sm border border-gray-100\" itemscope itemprop=\"mainEntity\" itemtype=\"https://schema.org/Question\">\n                        <button onclick=\"toggleFaq(this)\" class=\"w-full flex justify-between items-center p-6 text-left cursor-pointer\">\n                            <h3 class=\"text-base font-semibold text-brand pr-4\" itemprop=\"name\">La carte cadeau est-elle transférable ?</h3>\n                            <i data-lucide=\"chevron-down\" class=\"faq-chevron w-5 h-5 text-brand flex-shrink-0 transition-transform duration-300\"></i>\n                        </button>\n                        <div class=\"faq-content\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https://schema.org/Answer\">\n                            <p class=\"px-6 pb-6 text-gray-600 leading-relaxed\" itemprop=\"text\">Oui, la carte cadeau est nominative mais peut &ecirc;tre transférée à une autre personne avec l'accord de l'acheteur. Il suffit de nous prévenir par email ou téléphone pour mettre à jour les coordonnées du bénéficiaire.</p>\n                        </div>\n                    </div>\n\n                </div>\n            </div>\n        </section>\n\n        \n        <!-- RÉALISATIONS — Mini galerie -->\n        <section class=\"py-12 md:py-16 bg-gray-50 border-y border-gray-100\">\n            <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n                <div class=\"text-center mb-8\">\n                    <span class=\"text-xs font-bold tracking-widest text-gray-400 uppercase block mb-2\">Réalisations</span>\n                    <h3 class=\"text-2xl md:text-3xl font-serif text-brand\">Un aperçu de nos créations</h3>\n                </div>\n                <div class=\"grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4\">\n                    <img src=\"https://haroboz.com/wp-content/uploads/2026/04/Photoroom_20250506_212353-1-scaled.png\" alt=\"Réalisation Haroboz\" class=\"aspect-[3/4] rounded-2xl object-cover w-full shadow-md hover:shadow-xl transition-shadow duration-300\" loading=\"lazy\">\n                    <img src=\"https://haroboz.com/wp-content/uploads/2026/03/Photoroom_20260128_103932.png\" alt=\"Réalisation Haroboz\" class=\"aspect-[3/4] rounded-2xl object-cover w-full shadow-md hover:shadow-xl transition-shadow duration-300\" loading=\"lazy\">\n                    <img src=\"https://haroboz.com/wp-content/uploads/2026/03/Photoroom_20251222_144602.png\" alt=\"Réalisation Haroboz\" class=\"aspect-[3/4] rounded-2xl object-cover w-full shadow-md hover:shadow-xl transition-shadow duration-300 hidden md:block\" loading=\"lazy\">\n                    <img src=\"https://haroboz.com/wp-content/uploads/2026/04/IMG_2909-1-scaled.png\" alt=\"Réalisation Haroboz\" class=\"aspect-[3/4] rounded-2xl object-cover w-full shadow-md hover:shadow-xl transition-shadow duration-300 hidden md:block\" loading=\"lazy\">\n                </div>\n                <div class=\"text-center mt-8\">\n                    <a href=\"https://haroboz.com/portfolio/\" class=\"inline-flex items-center text-brand font-medium hover:text-brand-light transition-colors group\">\n                        <span>Voir toutes les réalisations</span>\n                        <i data-lucide=\"arrow-right\" class=\"w-4 h-4 ml-2 group-hover:translate-x-1 transition-transform\"></i>\n                    </a>\n                </div>\n            </div>\n        </section>\n\n<!-- CTA -->\n        <section class=\"bg-brand py-16 lg:py-20\">\n            <div class=\"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center\">\n                <h2 class=\"text-3xl md:text-4xl font-serif font-bold text-white mb-4\">Offrez une expérience inoubliable</h2>\n                <p class=\"text-white/70 text-lg mb-8\">Carte cadeau shooting privé — Marseille, Toulon, Nice, Paris</p>\n                <button onclick=\"openPopup()\" class=\"bg-white text-brand px-8 py-4 rounded-full text-lg font-medium hover:bg-gray-100 shadow-lg inline-flex items-center cursor-pointer\"><i data-lucide=\"gift\" class=\"w-5 h-5 mr-2\"></i> Commander une carte cadeau</button>\n            </div>\n        </section>\n\n    </main>\n\n    <!-- FOOTER -->\n    <footer class=\"bg-brand text-white border-t border-brand-light/20\">\n        <div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16\">\n            <div class=\"grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12\">\n                <div><div class=\"font-serif text-lg font-bold mb-4\">Nos Packs</div><ul class=\"space-y-2\"><li><a href=\"https://haroboz.com/packs-shooting/portrait-studio/\" class=\"text-sm text-gray-300 hover:text-white\">Portrait Studio</a></li><li><a href=\"https://haroboz.com/packs-shooting/shooting-exterieur/\" class=\"text-sm text-gray-300 hover:text-white\">Shooting Extérieur</a></li><li><a href=\"https://haroboz.com/packs-shooting/shooting-duo-couple/\" class=\"text-sm text-gray-300 hover:text-white\">Duo &amp; Couple</a></li><li><a href=\"https://haroboz.com/packs-shooting/photo-domicile/\" class=\"text-sm text-gray-300 hover:text-white\">Photo à Domicile</a></li></ul></div>\n                <div><div class=\"font-serif text-lg font-bold mb-4\">Lieux</div><ul class=\"space-y-2\"><li><a href=\"https://haroboz.com/photographe/photographe-marseille/\" class=\"text-sm text-gray-300 hover:text-white\">Marseille</a></li><li><a href=\"https://haroboz.com/photographe/photographe-toulon/\" class=\"text-sm text-gray-300 hover:text-white\">Toulon</a></li><li><a href=\"https://haroboz.com/photographe/photographe-nice/\" class=\"text-sm text-gray-300 hover:text-white\">Nice</a></li><li><a href=\"https://haroboz.com/photographe/photographe-paris/\" class=\"text-sm text-gray-300 hover:text-white\">Paris</a></li></ul></div>\n                <div><div class=\"font-serif text-lg font-bold mb-4\">Expérience</div><ul class=\"space-y-2\"><li><a href=\"https://haroboz.com/votre-experience/premier-shooting-nu/\" class=\"text-sm text-gray-300 hover:text-white\">Premier Shooting</a></li><li><a href=\"https://haroboz.com/votre-experience/retrouver-confiance-corps/\" class=\"text-sm text-gray-300 hover:text-white\">Retrouver Confiance</a></li><li><a href=\"https://haroboz.com/votre-experience/book-modele-professionnel/\" class=\"text-sm text-gray-300 hover:text-white\">Book Modèle Pro</a></li><li><a href=\"https://haroboz.com/portfolio/temoignages-clients/\" class=\"text-sm text-gray-300 hover:text-white\">Témoignages</a></li></ul></div>\n                <div><div class=\"font-serif text-lg font-bold mb-4\">Haroboz</div><ul class=\"space-y-2\"><li><a href=\"https://haroboz.com/a-propos/\" class=\"text-sm text-gray-300 hover:text-white\">&Agrave; Propos</a></li><li><a href=\"https://haroboz.com/portfolio/\" class=\"text-sm text-gray-300 hover:text-white\">Réalisations</a></li><li><a href=\"https://haroboz.com/contact/\" class=\"text-sm text-gray-300 hover:text-white\">Contact</a></li><li><a href=\"https://haroboz.com/mentions-legales/\" class=\"text-sm text-gray-300 hover:text-white\">Mentions légales</a></li></ul></div>\n            </div>\n            <div class=\"border-t border-white/10 mt-10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4\">\n                <p class=\"text-sm text-gray-400\">&copy; 2026 Haroboz — Luc Desbois | Photographe Art Masculin | Marseille, Toulon, Nice, Paris</p>\n                <div class=\"flex items-center gap-4\"><a href=\"https://www.instagram.com/hbozart/\" target=\"_blank\" class=\"text-gray-400 hover:text-white\"><i data-lucide=\"instagram\" class=\"w-5 h-5\"></i></a><a href=\"https://haroboz.com/mentions-legales/\" class=\"text-sm text-gray-400 hover:text-white\">Mentions légales</a></div>\n            </div>\n        </div>\n    </footer>\n\n    <!-- POPUP -->\n    <div id=\"booking-popup\" class=\"fixed inset-0 z-[100] flex items-center justify-center p-4 popup-hidden\">\n        <div class=\"absolute inset-0 bg-brand/60 backdrop-blur-sm\" onclick=\"closePopup()\"></div>\n        <div id=\"popup-content\" class=\"relative bg-white rounded-2xl shadow-2xl max-w-lg w-full max-h-[90vh] overflow-y-auto\">\n            <div class=\"bg-brand rounded-t-2xl p-6 text-center relative\"><button onclick=\"closePopup()\" class=\"absolute top-4 right-4 text-white/70 hover:text-white cursor-pointer\"><i data-lucide=\"x\" class=\"w-6 h-6\"></i></button><h3 class=\"text-xl font-serif text-white font-bold\">Réservez votre séance</h3><p class=\"text-white/70 text-sm mt-1\">Réponse confidentielle sous 24h</p></div>\n            <form id=\"booking-form\" class=\"p-6\" onsubmit=\"handleSubmit(event)\"><div class=\"space-y-4\"><div><label class=\"block text-sm font-medium text-brand mb-1\">Prénom *</label><input type=\"text\" required placeholder=\"Votre prénom\" name=\"prenom\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-brand placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand\"></div><div><label class=\"block text-sm font-medium text-brand mb-1\">Email *</label><input type=\"email\" required placeholder=\"votre@email.com\" name=\"email\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-brand placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand\"></div><div><label class=\"block text-sm font-medium text-brand mb-1\">Téléphone *</label><input type=\"tel\" required placeholder=\"06 XX XX XX XX\" name=\"telephone\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-brand placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand\"></div><div><label class=\"block text-sm font-medium text-brand mb-1\">Message</label><textarea rows=\"3\" placeholder=\"Parlez-moi de votre projet...\" name=\"message\" class=\"w-full px-4 py-3 border border-gray-200 rounded-xl text-brand placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand resize-none\"></textarea></div></div><button type=\"submit\" class=\"w-full mt-6 bg-brand text-white py-4 rounded-xl font-bold hover:bg-brand-light shadow-lg flex items-center justify-center cursor-pointer\"><i data-lucide=\"send\" class=\"w-5 h-5 mr-2\"></i> Envoyer ma demande</button><p class=\"text-center text-xs text-gray-400 mt-3\"><i data-lucide=\"lock\" class=\"w-3 h-3 inline\"></i> 100% confidentiel</p></form>\n            <div id=\"popup-success\" class=\"hidden p-8 text-center\"><div class=\"w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4\"><i data-lucide=\"check-circle\" class=\"w-8 h-8 text-green-600\"></i></div><h3 class=\"text-2xl font-serif text-brand mb-2\">Demande envoyée !</h3><p class=\"text-gray-600 mb-6\">Je vous recontacte sous 24h.</p><button onclick=\"closePopup()\" class=\"bg-brand text-white px-6 py-3 rounded-xl font-medium hover:bg-brand-light cursor-pointer\">Fermer</button></div>\n        </div>\n    </div>\n    <div id=\"floating-cta\" class=\"fixed bottom-6 right-6 z-50 opacity-0 translate-y-4 transition-all duration-300 pointer-events-none\"><button onclick=\"openPopup()\" class=\"relative bg-brand text-white w-14 h-14 md:w-auto md:h-auto md:px-6 md:py-3 rounded-full shadow-2xl hover:bg-brand-light flex items-center justify-center cursor-pointer pulse-ring text-brand\"><i data-lucide=\"calendar\" class=\"w-6 h-6 md:w-5 md:h-5 md:mr-2\"></i><span class=\"hidden md:inline font-medium\">Prendre RDV</span></button></div>\n</div>",
