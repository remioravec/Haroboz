  "content_raw": "<style>\n<p>        .mega-menu-content { visibility: hidden; opacity: 0; transform: translateY(10px); transition: all 0.3s ease-in-out; }<br />\n        .mega-menu-item:hover .mega-menu-content { visibility: visible; opacity: 1; transform: translateY(0); pointer-events: auto; }<br />\n        #mobile-menu { transition: transform 0.3s ease-in-out; }<br />\n        .menu-open { transform: translateX(0) !important; }<br />\n        #booking-popup { transition: opacity 0.3s ease, visibility 0.3s ease; }<br />\n        #booking-popup.popup-hidden { opacity: 0; visibility: hidden; }<br />\n        #booking-popup.popup-visible { opacity: 1; visibility: visible; }<br />\n        #popup-content { transition: transform 0.3s ease, opacity 0.3s ease; }<br />\n        #booking-popup.popup-hidden #popup-content { transform: scale(0.95) translateY(20px); opacity: 0; }<br />\n        #booking-popup.popup-visible #popup-content { transform: scale(1) translateY(0); opacity: 1; }<br />\n        @keyframes pulse-ring { 0% { transform: scale(1); opacity: 1; } 80%, 100% { transform: scale(1.4); opacity: 0; } }<br />\n        .pulse-ring::before { content: ''; position: absolute; inset: -4px; border-radius: 9999px; border: 2px solid currentColor; animation: pulse-ring 2s ease-out infinite; }<br />\n        .faq-content { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }</p>\n</style>\n<div class=\"haroboz-page\"><!-- HEADER --><header id=\"main-header\" class=\"fixed top-0 left-0 w-full z-50 bg-white shadow-sm transition-all duration-300\">\n<div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n<div class=\"flex justify-between items-center h-20\">\n<div class=\"flex-shrink-0\"><a class=\"font-serif text-2xl lg:text-3xl font-bold tracking-tight text-brand\" href=\"https://haroboz.com/\">HAROBOZ</a></div>\n<nav class=\"hidden lg:flex space-x-8 h-full items-center\">\n<div class=\"mega-menu-item relative h-full flex items-center\"><button class=\"flex items-center text-sm font-medium hover:text-brand-light transition-colors py-8\">Nos Séances <i class=\"ml-1 w-4 h-4\" data-lucide=\"chevron-down\"></i></button>\n<div class=\"mega-menu-content absolute top-20 left-1/2 -translate-x-1/2 w-64 bg-white shadow-xl rounded-b-lg border-t border-gray-100\">\n<div class=\"py-2\"><a class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\" href=\"https://haroboz.com/packs-shooting/portrait-studio/\">Portrait en Studio</a><a class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\" href=\"https://haroboz.com/packs-shooting/shooting-exterieur/\">Shooting en Extérieur</a><a class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\" href=\"https://haroboz.com/packs-shooting/photo-domicile/\">Photo à Domicile</a><a class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\" href=\"https://haroboz.com/packs-shooting/shooting-duo-couple/\">Shooting Duo &amp; Couple</a></div>\n</div>\n</div>\n<div class=\"mega-menu-item relative h-full flex items-center\"><button class=\"flex items-center text-sm font-medium hover:text-brand-light transition-colors py-8\">Votre Objectif <i class=\"ml-1 w-4 h-4\" data-lucide=\"chevron-down\"></i></button>\n<div class=\"mega-menu-content absolute top-20 left-1/2 -translate-x-1/2 w-80 bg-white shadow-xl rounded-b-lg border-t border-gray-100\">\n<div class=\"py-2\"><a class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\" href=\"https://haroboz.com/votre-experience/retrouver-confiance-corps/\">Confiance &amp; Acceptation</a><a class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\" href=\"https://haroboz.com/votre-experience/book-modele-professionnel/\">Book Professionnel</a><a class=\"block px-6 py-3 text-sm hover:bg-brand-50 hover:text-brand transition-colors\" href=\"https://haroboz.com/votre-experience/cadeau-couple-original/\"