d=\"floating-cta\" class=\"fixed bottom-6 right-6 z-50 opacity-0 translate-y-4 transition-all duration-300 pointer-events-none\"><button class=\"relative bg-brand text-white w-14 h-14 md:w-auto md:h-auto md:px-6 md:py-3 rounded-full shadow-2xl hover:bg-brand-light flex items-center justify-center cursor-pointer pulse-ring text-brand\"><i class=\"w-6 h-6 md:w-5 md:h-5 md:mr-2\" data-lucide=\"calendar\"></i><span class=\"hidden md:inline font-medium\">Prendre RDV</span></button></div>\n</div>",
